@page "/not-found"
@layout MainLayout
@inherits DMRS.Client.Components.LocalizedComponentBase
@inject NavigationManager Navigation

<PageTitle>@Loc["errors.notFound.pageTitle"]</PageTitle>

<StatusCard Title="@Loc["errors.notFound.title"]"
            Subtitle="@Loc["errors.notFound.subtitle"]"
            Tone="StatusCard.CardTone.Brand">
    <Icon>
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.7"
                    stroke-linecap="round" stroke-linejoin="round" />
            <path d="m20 20-3.5-3.5" stroke="currentColor" stroke-width="1.7"
                  stroke-linecap="round" stroke-linejoin="round" />
            <path d="M11 8v3.5" stroke="currentColor" stroke-width="1.7"
                  stroke-linecap="round" stroke-linejoin="round" />
            <path d="M11 14h.01" stroke="currentColor" stroke-width="2"
                  stroke-linecap="round" stroke-linejoin="round" />
        </svg>
    </Icon>
    <Actions>
        <button class="btn btn-primary" @onclick="GoHome">@Loc["common.returnToDashboard"]</button>
        <button class="btn btn-outline-primary" @onclick="GoBack">@Loc["common.goBack"]</button>
    </Actions>
</StatusCard>

@code {
    [Inject] private IJSRuntime JS { get; set; } = default!;

    private void GoHome() => Navigation.NavigateTo("/");

    private async Task GoBack() => await JS.InvokeVoidAsync("history.back");
}
