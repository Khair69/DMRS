@page "/"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN,ROLE_PRACTITIONER,ROLE_PATIENT")]
@using DMRS.Client.Features.Dashboard
@using DMRS.Client.Features.Dashboard.Models
@using DMRS.Client.Features.Dashboard.Components
@inherits DMRS.Client.Components.LocalizedComponentBase
@inject DMRS.Client.Features.Dashboard.Services.DashboardFeatureService DashboardService
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>@Loc["app.brand"]</PageTitle>

@if (showOrgAdminDashboard)
{
    <OrgAdminDashboard />
}
else if (showDoctorDashboard)
{
    <DoctorDashboard />
}
else if (showPatientDashboard)
{
    <PatientDashboard />
}
else
{

<div class="workspace-hero">
    <div>
        <span class="workspace-eyebrow">@Loc["dashboard.workspace.eyebrow"]</span>
        <h1>@Loc["dashboard.workspace.title"]</h1>
        <p>@Loc["dashboard.workspace.subtitle"]</p>
    </div>
    <div class="workspace-hero__actions">
        <a class="btn btn-light" href="/patients/new">@Loc["dashboard.registerPatient"]</a>
        <a class="btn btn-outline-light" href="/cds/admin">@Loc["dashboard.openCdsAdmin"]</a>
    </div>
</div>

@if (isLoading)
{
    <div class="dmrs-loading-shell">
        <div class="spinner-border text-primary" role="status"></div>
    </div>
}
else if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
else
{
    <section class="dmrs-metrics-grid">
        @foreach (var metric in snapshot.Metrics)
        {
            <a class="dmrs-metric-card @metric.AccentClass" href="@metric.Href">
                <div class="dmrs-metric-card__label">@Loc[metric.LabelKey]</div>
                <div class="dmrs-metric-card__value">@metric.Value</div>
                <div class="dmrs-metric-card__helper">@Loc[metric.HelperKey]</div>
            </a>
        }
    </section>

    <section class="row g-4 mt-1">
        <div class="col-12 col-xl-7">
            <div class="dmrs-panel">
                <div class="dmrs-panel__header">
                    <div>
                        <div class="dmrs-panel__title">@Loc["dashboard.watchlist.title"]</div>
                        <div class="dmrs-panel__subtitle">@Loc["dashboard.watchlist.subtitle"]</div>
                    </div>
                    @{
                        var _total = snapshot.HighRiskCount + snapshot.MediumRiskCount + snapshot.LowRiskCount;
                        const float _r = 34f; // r + half stroke (5) must stay within the 40-unit viewBox radius
                        const float _c = 2f * MathF.PI * _r;
                        float _hd = _total > 0 ? (snapshot.HighRiskCount   / (float)_total) * _c : 0f;
                        float _md = _total > 0 ? (snapshot.MediumRiskCount / (float)_total) * _c : 0f;
                        float _ld = _total > 0 ? (snapshot.LowRiskCount    / (float)_total) * _c : 0f;
                        string Fmt(float v) => v.ToString("0.###", System.Globalization.CultureInfo.InvariantCulture);
                    }
                    <div class="d-flex align-items-center gap-3">
                        <svg width="76" height="76" viewBox="0 0 80 80" aria-hidden="true">
                            <g transform="rotate(-90 40 40)">
                                <circle cx="40" cy="40" r="@Fmt(_r)" fill="none" stroke="#e5e7eb" stroke-width="10"/>
                                @if (snapshot.HighRiskCount > 0)
                                {
                                    <circle cx="40" cy="40" r="@Fmt(_r)" fill="none" stroke="#ef4444" stroke-width="10"
                                            stroke-dasharray="@Fmt(_hd) @Fmt(_c)"
                                            stroke-dashoffset="0"/>
                                }
                                @if (snapshot.MediumRiskCount > 0)
                                {
                                    <circle cx="40" cy="40" r="@Fmt(_r)" fill="none" stroke="#f59e0b" stroke-width="10"
                                            stroke-dasharray="@Fmt(_md) @Fmt(_c)"
                                            stroke-dashoffset="@Fmt(-_hd)"/>
                                }
                                @if (snapshot.LowRiskCount > 0)
                                {
                                    <circle cx="40" cy="40" r="@Fmt(_r)" fill="none" stroke="#22c55e" stroke-width="10"
                                            stroke-dasharray="@Fmt(_ld) @Fmt(_c)"
                                            stroke-dashoffset="@Fmt(-(_hd + _md))"/>
                                }
                            </g>
                            <text x="40" y="36" text-anchor="middle" font-size="15" font-weight="700" fill="#111827">@_total</text>
                            <text x="40" y="49" text-anchor="middle" font-size="9" fill="#6b7280">@Loc["dashboard.assessed"]</text>
                        </svg>
                        <div style="font-size:0.78rem;line-height:1.7;">
                            <div class="d-flex align-items-center gap-1">
                                <span style="width:9px;height:9px;border-radius:50%;background:#ef4444;flex-shrink:0;"></span>
                                <span>@snapshot.HighRiskCount @Loc["dashboard.level.high"]</span>
                            </div>
                            <div class="d-flex align-items-center gap-1">
                                <span style="width:9px;height:9px;border-radius:50%;background:#f59e0b;flex-shrink:0;"></span>
                                <span>@snapshot.MediumRiskCount @Loc["dashboard.level.medium"]</span>
                            </div>
                            <div class="d-flex align-items-center gap-1">
                                <span style="width:9px;height:9px;border-radius:50%;background:#22c55e;flex-shrink:0;"></span>
                                <span>@snapshot.LowRiskCount @Loc["dashboard.level.low"]</span>
                            </div>
                        </div>
                    </div>
                    <a class="btn btn-sm btn-outline-primary" href="/ai-insights">@Loc["dashboard.allAiInsights"]</a>
                </div>
                <div class="dmrs-list">
                    @if (snapshot.HighRiskPatients.Count == 0)
                    {
                        <div class="dmrs-empty-state">@Loc["dashboard.watchlist.empty"]</div>
                    }
                    else
                    {
                        @foreach (var patient in snapshot.HighRiskPatients)
                        {
                            <a class="dmrs-list-item" href="@patient.Href">
                                <div>
                                    <div class="dmrs-list-item__title">@patient.DisplayName</div>
                                    <div class="dmrs-list-item__subtitle">@DashboardText.WatchlistSummary(Loc, patient)</div>
                                </div>
                                <span class="dmrs-pill @RiskLevelPillClass(patient.RiskLevel)">
                                    @DashboardText.RiskLevel(Loc, patient.RiskLevel)
                                </span>
                            </a>
                        }
                    }
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-5">
            <div class="dmrs-panel h-100">
                <div class="dmrs-panel__header">
                    <div>
                        <div class="dmrs-panel__title">@Loc["dashboard.cds.title"]</div>
                        <div class="dmrs-panel__subtitle">
                            <span class="me-3">@Loc["dashboard.cds.liveRules", snapshot.ActiveRuleCount]</span>
                            <span>@Loc["dashboard.cds.draftRules", snapshot.DraftRuleCount]</span>
                        </div>
                    </div>
                    <a class="btn btn-sm btn-outline-primary" href="/cds/admin">@Loc["dashboard.manageRules"]</a>
                </div>

                @if (snapshot.RecentAlerts.Count == 0)
                {
                    <div class="dmrs-empty-state">@Loc["dashboard.cds.empty"]</div>
                }
                else
                {
                    <div class="dmrs-list">
                        @foreach (var alert in snapshot.RecentAlerts.Take(8))
                        {
                            <a class="dmrs-list-item" href="/patients/@alert.PatientId">
                                <div style="min-width:0;">
                                    <div class="dmrs-list-item__title text-truncate">@alert.CardSummary</div>
                                    <div class="dmrs-list-item__subtitle">
                                        @alert.Hook · @TimeAgo(alert.FiredAt)
                                    </div>
                                </div>
                                <span class="dmrs-pill @IndicatorPillClass(alert.Indicator)" style="flex-shrink:0;">
                                    @alert.Indicator
                                </span>
                            </a>
                        }
                    </div>
                }
            </div>
        </div>
    </section>

    <section class="row g-4 mt-1">
        <div class="col-12 col-xl-6">
            <div class="dmrs-panel">
                <div class="dmrs-panel__header">
                    <div>
                        <div class="dmrs-panel__title">@Loc["dashboard.upcoming.title"]</div>
                        <div class="dmrs-panel__subtitle">@Loc["dashboard.upcoming.subtitle"]</div>
                    </div>
                    <a class="btn btn-sm btn-outline-primary" href="/appointments">@Loc["nav.appointments"]</a>
                </div>
                <div class="dmrs-list">
                    @if (snapshot.UpcomingAppointments.Count == 0)
                    {
                        <div class="dmrs-empty-state">@Loc["dashboard.upcoming.empty"]</div>
                    }
                    else
                    {
                        @foreach (var item in snapshot.UpcomingAppointments)
                        {
                            <a class="dmrs-list-item" href="@item.Href">
                                <div>
                                    <div class="dmrs-list-item__title">@item.Title</div>
                                    <div class="dmrs-list-item__subtitle">@item.Subtitle</div>
                                </div>
                                <span class="dmrs-list-item__meta">@item.Meta</span>
                            </a>
                        }
                    }
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-6">
            <div class="dmrs-panel">
                <div class="dmrs-panel__header">
                    <div>
                        <div class="dmrs-panel__title">@Loc["dashboard.recentMed.title"]</div>
                        <div class="dmrs-panel__subtitle">@Loc["dashboard.recentMed.subtitle"]</div>
                    </div>
                    <a class="btn btn-sm btn-outline-primary" href="/medication-requests">@Loc["nav.medicationRequests"]</a>
                </div>
                <div class="dmrs-list">
                    @if (snapshot.RecentMedicationRequests.Count == 0)
                    {
                        <div class="dmrs-empty-state">@Loc["dashboard.recentMed.empty"]</div>
                    }
                    else
                    {
                        @foreach (var item in snapshot.RecentMedicationRequests)
                        {
                            <a class="dmrs-list-item" href="@item.Href">
                                <div>
                                    <div class="dmrs-list-item__title">@item.Title</div>
                                    <div class="dmrs-list-item__subtitle">@item.Subtitle</div>
                                </div>
                                <span class="dmrs-list-item__meta">@item.Meta</span>
                            </a>
                        }
                    }
                </div>
            </div>
        </div>
    </section>
}

}

@code {
    private bool isLoading = true;
    private string? errorMessage;
    private DashboardSnapshotModel snapshot = new();
    private bool showOrgAdminDashboard;
    private bool showDoctorDashboard;
    private bool showPatientDashboard;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        var isAdmin = user.IsInRole("ROLE_SYSTEM_ADMIN");
        var isStaff = isAdmin || user.IsInRole("ROLE_ORG_ADMIN") || user.IsInRole("ROLE_PRACTITIONER");

        // Org admins get the org-scoped dashboard; plain doctors get the clinician "My Patients"
        // dashboard. A system admin keeps the global view even if they also hold these roles.
        showOrgAdminDashboard = user.IsInRole("ROLE_ORG_ADMIN") && !isAdmin;
        showDoctorDashboard = !showOrgAdminDashboard && !isAdmin && user.IsInRole("ROLE_PRACTITIONER");
        // Patients (with no staff role) get the self-service portal dashboard.
        showPatientDashboard = !isStaff && user.IsInRole("ROLE_PATIENT");
        if (showOrgAdminDashboard || showDoctorDashboard || showPatientDashboard)
        {
            isLoading = false;
            return;
        }

        try
        {
            snapshot = await DashboardService.GetSnapshotAsync();
        }
        catch (Exception ex)
        {
            errorMessage = Loc["dashboard.loadFailed", ex.Message];
        }
        finally
        {
            isLoading = false;
        }
    }

    private static string RiskLevelPillClass(string riskLevel) => riskLevel switch
    {
        "High"   => "dmrs-pill--danger",
        "Medium" => "dmrs-pill--warning",
        _        => "dmrs-pill--neutral"
    };

    private static string IndicatorPillClass(string indicator) => indicator switch
    {
        "hard-stop" => "dmrs-pill--danger",
        "warning"   => "dmrs-pill--warning",
        _           => "dmrs-pill--neutral"
    };

    private string TimeAgo(DateTimeOffset firedAt)
    {
        var elapsed = DateTimeOffset.UtcNow - firedAt;
        if (elapsed.TotalSeconds < 60)  return Loc["common.time.justNow"];
        if (elapsed.TotalMinutes < 60)  return Loc["common.time.minutesAgo", (int)elapsed.TotalMinutes];
        if (elapsed.TotalHours < 24)    return Loc["common.time.hoursAgo", (int)elapsed.TotalHours];
        return Loc["common.time.daysAgo", (int)elapsed.TotalDays];
    }
}
