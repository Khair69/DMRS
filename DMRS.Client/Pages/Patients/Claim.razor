@page "/patients/claim"
@attribute [Authorize]
@inherits DMRS.Client.Components.LocalizedComponentBase
@inject DMRS.Client.Features.Patients.Services.PatientFeatureService PatientService
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>@Loc["patients.claim.title"]</PageTitle>

<h1>@Loc["patients.claim.title"]</h1>

@if (isBusy)
{
    <div class="spinner-border" role="status"></div>
}
else
{
    if (!string.IsNullOrWhiteSpace(successMessage))
    {
        <div class="alert alert-success">@successMessage</div>
    }

    if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    <EditForm Model="this" OnSubmit="ClaimInvite">
        <div class="row g-3">
            <div class="col-md-8">
                <label class="form-label">@Loc["patients.claim.codeLabel"]</label>
                <InputText @bind-Value="Code" class="form-control" />
            </div>
            <div class="col-md-4 d-flex align-items-end">
                <button type="submit" class="btn btn-primary w-100" disabled="@isBusy">@Loc["patients.claim.submit"]</button>
            </div>
        </div>
    </EditForm>
}

@code {
    [SupplyParameterFromQuery]
    public string? Code { get; set; }

    [SupplyParameterFromQuery(Name = "auto")]
    public bool AutoClaim { get; set; }

    private bool isBusy;
    private string? errorMessage;
    private string? successMessage;
    private bool hasAutoAttempted;

    protected override async Task OnParametersSetAsync()
    {
        if (AutoClaim && !hasAutoAttempted && !string.IsNullOrWhiteSpace(Code))
        {
            hasAutoAttempted = true;
            await ClaimInvite();
        }
    }

    private async Task ClaimInvite()
    {
        errorMessage = null;
        successMessage = null;

        if (string.IsNullOrWhiteSpace(Code))
        {
            errorMessage = Loc["patients.claim.codeRequired"];
            return;
        }

        isBusy = true;

        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            var keycloakUserId = user.FindFirst("sub")?.Value
                                 ?? user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

            if (string.IsNullOrWhiteSpace(keycloakUserId))
            {
                errorMessage = Loc["patients.claim.noKeycloakId"];
                return;
            }

            var keycloakUsername = user.FindFirst("preferred_username")?.Value
                                   ?? user.Identity?.Name;

            var result = await PatientService.ClaimInviteAsync(Code.Trim(), keycloakUserId, keycloakUsername);
            successMessage = Loc["patients.claim.success", result.PatientId];
        }
        catch (Exception ex)
        {
            errorMessage = Loc["patients.claim.failed", ex.Message];
        }
        finally
        {
            isBusy = false;
        }
    }
}
