@page "/patients/{Id}"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN,ROLE_PRACTITIONER")]
@inherits DMRS.Client.Components.LocalizedComponentBase
@inject DMRS.Client.Features.Patients.Services.PatientFeatureService PatientService
@inject DMRS.Client.Features.Patients.Services.PatientChartFeatureService PatientChartService
@inject DMRS.Client.Features.Documents.Services.PatientDocumentFeatureService DocumentService
@inject DMRS.Client.Features.Organizations.Services.OrganizationFeatureService OrganizationService
@inject DMRS.Client.Features.MedicationRequests.Services.MedicationDecisionSupportService DecisionSupportService
@inject IConfiguration Configuration
@inject NavigationManager NavigationManager
@using DMRS.Client.Features.Dashboard.Models
@using DMRS.Client.Features.Documents.Models
@using DMRS.Client.Features.Patients.Models
@using DMRS.Shared.Constants
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>@Loc["patients.details.title"]</PageTitle>

@if (isBusy)
{
    <div class="dmrs-loading-shell">
        <div class="spinner-border text-primary" role="status"></div>
    </div>
}
else if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
else
{
    <div class="workspace-hero workspace-hero--patient">
        <div>
            <span class="workspace-eyebrow">@Loc["patients.details.eyebrow"]</span>
            <h1>@DisplayPatientName</h1>
            @if (!string.IsNullOrWhiteSpace(PatientNumber))
            {
                <p class="mb-1"><strong>@Loc["patients.field.patientNumber"]:</strong> @PatientNumber</p>
            }
            <p>@DisplayPatientDemographics</p>
        </div>
        <div class="workspace-hero__actions">
            @if (riskAssessment is not null && riskAssessment.FeaturesComplete)
            {
                <span class="dmrs-pill @RiskLevelPillClass(riskAssessment.RiskLevel)">
                    @Loc["patients.details.readmissionPill", riskAssessment.RiskLevel]
                </span>
            }
            <a class="btn btn-light" href="@($"/patients/{Id}/edit")">@Loc["patients.details.editPatient"]</a>
            <a class="btn btn-outline-light" href="@($"/patients/{Id}/history")">@Loc["common.history"]</a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-12 col-xl-8">
            <div class="dmrs-metrics-grid dmrs-metrics-grid--compact">
                <div class="dmrs-metric-card metric-ocean">
                    <div class="dmrs-metric-card__label">@Loc["patients.metric.allergies"]</div>
                    <div class="dmrs-metric-card__value">@allergyCount</div>
                    <div class="dmrs-metric-card__helper">@Loc["patients.metric.allergiesHelper"]</div>
                </div>
                <div class="dmrs-metric-card metric-emerald">
                    <div class="dmrs-metric-card__label">@Loc["patients.metric.conditions"]</div>
                    <div class="dmrs-metric-card__value">@conditionCount</div>
                    <div class="dmrs-metric-card__helper">@Loc["patients.metric.conditionsHelper"]</div>
                </div>
                <div class="dmrs-metric-card metric-gold">
                    <div class="dmrs-metric-card__label">@Loc["patients.metric.medications"]</div>
                    <div class="dmrs-metric-card__value">@medicationCount</div>
                    <div class="dmrs-metric-card__helper">@Loc["patients.metric.medicationsHelper"]</div>
                </div>
                <div class="dmrs-metric-card metric-ink">
                    <div class="dmrs-metric-card__label">@Loc["patients.metric.encounters"]</div>
                    <div class="dmrs-metric-card__value">@encounterCount</div>
                    <div class="dmrs-metric-card__helper">@Loc["patients.metric.encountersHelper"]</div>
                </div>
            </div>

            <div class="dmrs-panel mt-4">
                <div class="dmrs-panel__header">
                    <div>
                        <div class="dmrs-panel__title">@Loc["patients.snapshot.title"]</div>
                        <div class="dmrs-panel__subtitle">@Loc["patients.snapshot.subtitle"]</div>
                    </div>
                </div>
                <div class="row g-3">
                    <div class="col-12 col-lg-6">
                        <div class="dmrs-subpanel">
                            <div class="dmrs-subpanel__title">@Loc["patients.snapshot.activeConditions"]</div>
                            @if (chart?.Conditions.Count > 0)
                            {
                                @foreach (var condition in chart.Conditions)
                                {
                                    <div class="dmrs-mini-row">
                                        <div class="dmrs-mini-row__title">@GetConditionLabel(condition)</div>
                                        <div class="dmrs-mini-row__meta">@condition.ClinicalStatus?.Text</div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="dmrs-empty-state dmrs-empty-state--inline">@Loc["patients.snapshot.noConditions"]</div>
                            }
                        </div>
                    </div>
                    <div class="col-12 col-lg-6">
                        <div class="dmrs-subpanel">
                            <div class="dmrs-subpanel__title">@Loc["patients.snapshot.allergies"]</div>
                            @if (chart?.Allergies.Count > 0)
                            {
                                @foreach (var allergy in chart.Allergies)
                                {
                                    <div class="dmrs-mini-row">
                                        <div class="dmrs-mini-row__title">@GetAllergyLabel(allergy)</div>
                                        <div class="dmrs-mini-row__meta">@allergy.SafeCriticality()</div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="dmrs-empty-state dmrs-empty-state--inline">@Loc["patients.snapshot.noAllergies"]</div>
                            }
                        </div>
                    </div>
                    <div class="col-12 col-lg-6">
                        <div class="dmrs-subpanel">
                            <div class="dmrs-subpanel__title">@Loc["patients.snapshot.observations"]</div>
                            @if (chart?.Observations.Count > 0)
                            {
                                @foreach (var observation in chart.Observations)
                                {
                                    <div class="dmrs-mini-row">
                                        <div class="dmrs-mini-row__title">@GetObservationLabel(observation)</div>
                                        <div class="dmrs-mini-row__meta">@observation.SafeStatus()</div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="dmrs-empty-state dmrs-empty-state--inline">@Loc["patients.snapshot.noObservations"]</div>
                            }
                        </div>
                    </div>
                    <div class="col-12 col-lg-6">
                        <div class="dmrs-subpanel">
                            <div class="dmrs-subpanel__title">@Loc["patients.snapshot.medicationRequests"]</div>
                            @if (chart?.MedicationRequests.Count > 0)
                            {
                                @foreach (var medication in chart.MedicationRequests)
                                {
                                    <div class="dmrs-mini-row">
                                        <div class="dmrs-mini-row__title">@GetMedicationLabel(medication)</div>
                                        <div class="dmrs-mini-row__meta">@medication.SafeStatus() | @medication.SafeIntent()</div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="dmrs-empty-state dmrs-empty-state--inline">@Loc["patients.snapshot.noMedications"]</div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="dmrs-panel mt-4">
                <div class="dmrs-panel__header">
                    <div>
                        <div class="dmrs-panel__title">@Loc["patients.activity.title"]</div>
                        <div class="dmrs-panel__subtitle">@Loc["patients.activity.subtitle"]</div>
                    </div>
                </div>
                <div class="row g-3">
                    <div class="col-12 col-lg-6">
                        <div class="dmrs-subpanel">
                            <div class="dmrs-subpanel__title">@Loc["patients.activity.encounters"]</div>
                            @if (chart?.Encounters.Count > 0)
                            {
                                @foreach (var encounter in chart.Encounters)
                                {
                                    <a class="dmrs-mini-row dmrs-mini-row--link" href="@($"/encounters/{encounter.Id}")">
                                        <div class="dmrs-mini-row__title">@GetEncounterLabel(encounter)</div>
                                        <div class="dmrs-mini-row__meta">@encounter.SafeStatus()</div>
                                    </a>
                                }
                            }
                            else
                            {
                                <div class="dmrs-empty-state dmrs-empty-state--inline">@Loc["patients.activity.noEncounters"]</div>
                            }
                        </div>
                    </div>
                    <div class="col-12 col-lg-6">
                        <div class="dmrs-subpanel">
                            <div class="dmrs-subpanel__title">@Loc["patients.activity.appointments"]</div>
                            @if (chart?.Appointments.Count > 0)
                            {
                                @foreach (var appointment in chart.Appointments)
                                {
                                    <a class="dmrs-mini-row dmrs-mini-row--link" href="@($"/appointments/{appointment.Id}")">
                                        <div class="dmrs-mini-row__title">@GetAppointmentLabel(appointment)</div>
                                        <div class="dmrs-mini-row__meta">@GetAppointmentDate(appointment)</div>
                                    </a>
                                }
                            }
                            else
                            {
                                <div class="dmrs-empty-state dmrs-empty-state--inline">@Loc["patients.activity.noAppointments"]</div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-4">
            <div class="dmrs-panel">
                <div class="dmrs-panel__header">
                    <div>
                        <div class="dmrs-panel__title">@Loc["patients.cds.alertsTitle"]</div>
                        <div class="dmrs-panel__subtitle">@Loc["patients.cds.alertsSubtitle"]</div>
                    </div>
                </div>
                @if (isEvaluatingCds)
                {
                    <div class="dmrs-loading-shell">
                        <div class="spinner-border text-primary" role="status"></div>
                    </div>
                }
                else if (patientCdsCards.Count > 0)
                {
                    <CdsCardList Cards="patientCdsCards" />
                }
                else
                {
                    <div class="dmrs-empty-state dmrs-empty-state--inline">@Loc["patients.cds.noAlerts"]</div>
                }
            </div>

            <div class="dmrs-panel mt-4">
                <div class="dmrs-panel__header">
                    <div>
                        <div class="dmrs-panel__title">@Loc["patients.cds.title"]</div>
                        <div class="dmrs-panel__subtitle">@Loc["patients.cds.subtitle"]</div>
                    </div>
                </div>
                <div class="dmrs-stack">
                    <div class="dmrs-note-card">
                        <div class="dmrs-note-card__title">@Loc["patients.cds.readmission"]</div>
                        @if (riskAssessment is null)
                        {
                            <p>@Loc["patients.cds.noReadmission"]</p>
                        }
                        else if (!riskAssessment.FeaturesComplete)
                        {
                            <p>@Loc["patients.cds.incompleteRisk"]</p>
                        }
                        else
                        {
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <div class="progress flex-grow-1" style="height:8px">
                                    <div class="progress-bar @RiskBarClass(riskAssessment.RiskLevel)"
                                         style="@($"width:{(riskAssessment.CompositeScore * 100).ToString("0")}%")"></div>
                                </div>
                                <strong>@((riskAssessment.CompositeScore * 100).ToString("0"))%</strong>
                                <span class="badge @VerdictBadgeClass(riskAssessment.IsHighRisk)"
                                      title="@Loc["patients.cds.verdictReadmission"]">
                                    @VerdictText(riskAssessment.IsHighRisk)
                                </span>
                            </div>
                            <p class="mb-1">
                                @Loc["patients.cds.riskLevel"] <strong>@riskAssessment.RiskLevel</strong>
                                @if (riskAssessment.HasChronicConditions)
                                {
                                    <span class="badge text-bg-warning ms-1">@Loc["patients.cds.chronic"]</span>
                                }
                            </p>
                            @if (riskAssessment.TopRiskFactors.Count > 0)
                            {
                                <div class="small text-muted mb-0">
                                    <div class="fw-semibold mb-1">@Loc["patients.cds.contributingFactors"]</div>
                                    <ul class="mb-0 ps-3">
                                        @foreach (var factor in riskAssessment.TopRiskFactors)
                                        {
                                            <li>@factor</li>
                                        }
                                    </ul>
                                </div>
                            }
                        }
                    </div>
                    <div class="dmrs-note-card">
                        <div class="dmrs-note-card__title">@Loc["patients.cds.diabetes"]</div>
                        @if (diabetesRisk is null)
                        {
                            <p class="mb-0">@Loc["patients.cds.modelUnavailable"]</p>
                        }
                        else
                        {
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <div class="progress flex-grow-1" style="height:8px">
                                    <div class="progress-bar @RiskBarClass(diabetesRisk.RiskLevel)"
                                         style="@($"width:{((diabetesRisk.Probability ?? 0) * 100).ToString("0")}%")"></div>
                                </div>
                                <strong>@(((diabetesRisk.Probability ?? 0) * 100).ToString("0"))%</strong>
                                <span class="badge @VerdictBadgeClass(diabetesRisk.IsHighRisk)"
                                      title="@Loc["patients.cds.verdictDiabetes"]">
                                    @VerdictText(diabetesRisk.IsHighRisk)
                                </span>
                            </div>
                            <p class="mb-1">@Loc["patients.cds.riskLevel"] <strong>@diabetesRisk.RiskLevel</strong></p>
                            <ul class="mb-1 small text-muted ps-3">
                                <li>@Loc["patients.cds.glucose"] @diabetesRisk.Glucose.ToString("0") mg/dL</li>
                                <li>@Loc["patients.cds.diastolic"] @diabetesRisk.BloodPressure.ToString("0") mm Hg</li>
                                <li>@Loc["patients.cds.bmi"] @diabetesRisk.Bmi.ToString("0.0")</li>
                            </ul>
                            @if (!diabetesRisk.FeaturesComplete)
                            {
                                <div class="small text-warning mb-0">@Loc["patients.cds.demographicEstimate", string.Join(", ", diabetesRisk.ImputedFeatures)]</div>
                            }
                        }
                    </div>
                    <div class="dmrs-note-card">
                        <div class="dmrs-note-card__title">@Loc["patients.cds.cardiovascular"]</div>
                        @if (cardiovascularRisk is null)
                        {
                            <p class="mb-0">@Loc["patients.cds.modelUnavailable"]</p>
                        }
                        else
                        {
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <div class="progress flex-grow-1" style="height:8px">
                                    <div class="progress-bar @RiskBarClass(cardiovascularRisk.RiskLevel)"
                                         style="@($"width:{((cardiovascularRisk.Probability ?? 0) * 100).ToString("0")}%")"></div>
                                </div>
                                <strong>@(((cardiovascularRisk.Probability ?? 0) * 100).ToString("0"))%</strong>
                                <span class="badge @VerdictBadgeClass(cardiovascularRisk.IsHighRisk)"
                                      title="@Loc["patients.cds.verdictCardio"]">
                                    @VerdictText(cardiovascularRisk.IsHighRisk)
                                </span>
                            </div>
                            <p class="mb-1">@Loc["patients.cds.riskLevel"] <strong>@cardiovascularRisk.RiskLevel</strong></p>
                            <ul class="mb-1 small text-muted ps-3">
                                <li>@Loc["patients.cds.restingBp"] @cardiovascularRisk.RestingBloodPressure.ToString("0") mm Hg</li>
                                <li>@Loc["patients.cds.cholesterol"] @cardiovascularRisk.Cholesterol.ToString("0") mg/dL</li>
                                <li>@Loc["patients.cds.maxHeartRate"] @cardiovascularRisk.MaxHeartRate.ToString("0") bpm</li>
                                <li>@Loc["patients.cds.fastingGlucose"] @(cardiovascularRisk.FastingBloodSugar >= 1 ? Loc["common.yes"] : Loc["common.no"])</li>
                            </ul>
                            @if (!cardiovascularRisk.FeaturesComplete)
                            {
                                <div class="small text-warning mb-0">@Loc["patients.cds.demographicEstimate", string.Join(", ", cardiovascularRisk.ImputedFeatures)]</div>
                            }
                        }
                    </div>
                    <div class="dmrs-note-card">
                        <div class="dmrs-note-card__title">@Loc["patients.cds.dataPoints"]</div>
                        @if (riskAssessment?.FeaturesComplete == true)
                        {
                            <ul class="mb-0 small">
                                <li>@Loc["patients.cds.conditionsOnRecord", riskAssessment.ConditionCount]</li>
                                <li>@Loc["patients.cds.activeMedications", riskAssessment.MedicationCount]</li>
                                <li>@Loc["patients.cds.recentVisits", riskAssessment.RecentEncounterCount]</li>
                            </ul>
                        }
                        else
                        {
                            <p class="mb-0">@Loc["patients.cds.notEvaluated"]</p>
                        }
                    </div>
                    <div class="dmrs-note-card">
                        <div class="dmrs-note-card__title">@Loc["patients.cds.quickLinks"]</div>
                        <div class="dmrs-quick-links">
                            <a class="btn btn-sm btn-outline-primary" href="/encounters/new?patient=@Id">🏥 @Loc["patients.quickLinks.encounter"]</a>
                            <a class="btn btn-sm btn-outline-primary" href="/medication-requests/new?patient=@Id">💊 @Loc["patients.quickLinks.medication"]</a>
                            <a class="btn btn-sm btn-outline-primary" href="/conditions/new?patient=@Id">🩺 @Loc["patients.quickLinks.condition"]</a>
                            <a class="btn btn-sm btn-outline-primary" href="/observations/new?patient=@Id">🧪 @Loc["patients.quickLinks.observation"]</a>
                            <a class="btn btn-sm btn-outline-primary" href="/procedures/new?patient=@Id">🔬 @Loc["patients.quickLinks.procedure"]</a>
                            <a class="btn btn-sm btn-outline-primary" href="/service-requests/new?patient=@Id">📋 @Loc["patients.quickLinks.serviceRequest"]</a>
                            <a class="btn btn-sm btn-outline-primary" href="/appointments/new?patient=@Id">📅 @Loc["patients.quickLinks.appointment"]</a>
                            <a class="btn btn-sm btn-outline-primary" href="/allergy-intolerances/new?patient=@Id">⚠️ @Loc["patients.quickLinks.allergy"]</a>
                        </div>
                        <a class="btn btn-sm btn-primary w-100 mt-2 dmrs-quick-links__feature" href="/ai-insights">🧠 @Loc["patients.quickLinks.aiInsights"]</a>
                    </div>
                </div>
            </div>

            <!-- External AI Models Panel -->
            <div class="mt-4">
                <DMRS.Client.Features.ExternalAi.Components.ExternalAiRunPanel PatientId="@Id" />
            </div>

            <!-- Documents Panel -->
            <div class="dmrs-panel mt-4">
                <div class="dmrs-panel__header">
                    <div>
                        <div class="dmrs-panel__title">@Loc["patients.docs.title"]</div>
                        <div class="dmrs-panel__subtitle">@Loc["patients.docs.subtitle"]</div>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(uploadError))
                {
                    <div class="alert alert-danger py-2 small">@uploadError</div>
                }
                @if (!string.IsNullOrWhiteSpace(uploadSuccess))
                {
                    <div class="alert alert-success py-2 small">@uploadSuccess</div>
                }

                <InputFile id="docUpload" OnChange="HandleFileUpload" accept="*/*" class="d-none" />
                <label for="docUpload" class="btn btn-outline-primary btn-sm w-100 mb-3 @(isUploading ? "disabled" : "")">
                    @(isUploading ? Loc["patients.docs.uploading"] : Loc["patients.docs.upload"])
                </label>

                @if (isLoadingDocuments)
                {
                    <div class="text-muted small text-center py-2">@Loc["patients.docs.loading"]</div>
                }
                else if (documents.Count == 0)
                {
                    <div class="dmrs-empty-state dmrs-empty-state--inline">@Loc["patients.docs.empty"]</div>
                }
                else
                {
                    <div class="dmrs-stack">
                        @foreach (var doc in documents)
                        {
                            <div class="dmrs-note-card d-flex justify-content-between align-items-start gap-2">
                                <div class="flex-grow-1 overflow-hidden">
                                    <div class="fw-semibold text-truncate" title="@doc.FileName">
                                        @doc.FileIcon @doc.FileName
                                    </div>
                                    <div class="small text-muted">@doc.SizeDisplay · @doc.UploadedAt.ToLocalTime().ToString("dd MMM yyyy")</div>
                                </div>
                                <div class="d-flex gap-1 flex-shrink-0">
                                    <a href="@DocumentService.GetDownloadUrl(Id, doc.Id)"
                                       target="_blank"
                                       class="btn btn-sm btn-outline-primary">↓</a>
                                    <button class="btn btn-sm btn-outline-danger"
                                            @onclick="() => DeleteDocumentAsync(doc.Id)"
                                            disabled="@isDeletingDocument">✕</button>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="card mt-4">
                <div class="card-header">@Loc["patients.account.title"]</div>
                <div class="card-body">
                    @if (isLinkedToAccount)
                    {
                        <div class="alert alert-success mb-0">@Loc["patients.account.linked"]</div>
                    }
                    else
                    {
                        if (!string.IsNullOrWhiteSpace(inviteError))
                        {
                            <div class="alert alert-danger">@inviteError</div>
                        }

                        if (inviteResult is not null)
                        {
                            <div class="alert alert-success">@Loc["patients.account.inviteGenerated", inviteResult.PatientId]</div>
                        }

                        if (!string.IsNullOrWhiteSpace(existingInviteCode))
                        {
                            <p class="mb-2"><strong>@Loc["patients.invite.code"]</strong>: <code>@existingInviteCode</code></p>
                        }

                        var claimLink = inviteResult?.ClaimLink ?? BuildClaimLink(existingInviteCode);
                        var registrationLink = inviteResult?.RegistrationLink ?? BuildRegistrationLink(existingInviteCode);

                        if (!string.IsNullOrWhiteSpace(registrationLink))
                        {
                            <p class="mb-2"><strong>@Loc["patients.invite.selfRegistration"]</strong>: <a href="@registrationLink" target="_blank">@registrationLink</a></p>
                        }

                        if (!string.IsNullOrWhiteSpace(claimLink))
                        {
                            <p class="mb-0"><strong>@Loc["patients.invite.manualFallback"]</strong>: <a href="@claimLink" target="_blank">@claimLink</a></p>
                        }

                        <button class="btn btn-outline-primary mt-3" disabled="@isGeneratingInvite" @onclick="GenerateInvite">
                            @(string.IsNullOrWhiteSpace(existingInviteCode) ? Loc["patients.account.generateInvite"] : Loc["patients.account.regenerateInvite"])
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;

    private Hl7.Fhir.Model.Patient? patient;
    private PatientChartSnapshotModel? chart;
    private HighUtilizationRiskAssessmentModel? riskAssessment;
    private DiabetesRiskAssessmentModel? diabetesRisk;
    private CardiovascularRiskAssessmentModel? cardiovascularRisk;
    private bool isBusy;
    private string? errorMessage;
    private string? managingOrganizationName;
    private bool isLinkedToAccount;
    private string? existingInviteCode;
    private bool isGeneratingInvite;
    private string? inviteError;
    private DMRS.Client.Features.Patients.Services.PatientInviteResult? inviteResult;
    private int allergyCount;
    private int conditionCount;
    private int medicationCount;
    private int encounterCount;

    // Live CDS cards for this patient's active medications (e.g. max-dose warnings).
    private List<CdsCardModel> patientCdsCards = [];
    private bool isEvaluatingCds;

    private static readonly HashSet<string> ActiveMedicationStatuses =
        new(StringComparer.OrdinalIgnoreCase) { "active", "on-hold" };

    // Documents
    private List<PatientDocumentModel> documents = [];
    private bool isLoadingDocuments;
    private bool isUploading;
    private bool isDeletingDocument;
    private string? uploadError;
    private string? uploadSuccess;

    // Readable patient number (XX12345) shown in the hero; null for legacy rows not yet backfilled.
    private string? PatientNumber =>
        patient?.Identifier.FirstOrDefault(i => i.System == PatientIdentifierSystems.PatientNumber)?.Value;

    private string DisplayPatientName
    {
        get
        {
            var name = patient?.Name.FirstOrDefault();
            var parts = new[] { name?.Given?.FirstOrDefault(), name?.Family }
                .Where(part => !string.IsNullOrWhiteSpace(part));
            var display = string.Join(" ", parts);
            return string.IsNullOrWhiteSpace(display) ? $"Patient {patient?.Id}" : display;
        }
    }

    private string DisplayPatientDemographics
    {
        get
        {
            if (patient is null)
            {
                return string.Empty;
            }

            // Prefer the resolved organization name; fall back to the reference's display, then the
            // raw reference, so the line is still meaningful if the name can't be loaded.
            var managingOrganization = managingOrganizationName
                ?? patient.ManagingOrganization?.Display
                ?? patient.ManagingOrganization?.Reference
                ?? Loc["patients.details.orgNotSet"];

            return Loc["patients.details.demographics",
                patient.Gender?.ToString() ?? string.Empty,
                patient.BirthDate ?? Loc["patients.details.bornUnknown"],
                managingOrganization];
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        errorMessage = null;
        isBusy = true;
        inviteError = null;
        inviteResult = null;

        try
        {
            var chartTask = PatientChartService.GetSnapshotAsync(Id);
            var docsTask = LoadDocumentsAsync();
            await System.Threading.Tasks.Task.WhenAll(chartTask, docsTask);

            chart = chartTask.Result;
            patient = chart?.Patient;
            riskAssessment = chart?.Risk;
            diabetesRisk = chart?.DiabetesRisk;
            cardiovascularRisk = chart?.CardiovascularRisk;

            if (patient is null)
            {
                errorMessage = Loc["patients.notFound", Id];
            }
            else
            {
                isLinkedToAccount = IsLinkedToAccount(patient);
                existingInviteCode = GetInviteCode(patient);
                await LoadManagingOrganizationNameAsync();
                allergyCount = chart?.Allergies.Count ?? 0;
                conditionCount = chart?.Conditions.Count ?? 0;
                medicationCount = chart?.MedicationRequests.Count ?? 0;
                encounterCount = chart?.Encounters.Count ?? 0;
            }
        }
        catch (Exception ex)
        {
            errorMessage = Loc["patients.details.loadError", ex.Message];
        }
        finally
        {
            isBusy = false;
        }

        // Evaluate CDS after the chart is on screen so the page doesn't block on the extra hook calls.
        if (patient is not null && chart is not null)
        {
            await EvaluatePatientCdsAsync();
        }
    }

    // Runs the medication-prescribe CDS hook for each of the patient's active medications and
    // aggregates the resulting warning cards, so the patient page proactively surfaces live rule
    // violations (e.g. a max-dose breach) instead of relying on the volatile dashboard alert feed.
    private async Task EvaluatePatientCdsAsync()
    {
        var activeMeds = chart?.MedicationRequests
            .Where(m => ActiveMedicationStatuses.Contains(m.SafeStatus()))
            .ToList() ?? [];

        if (activeMeds.Count == 0)
        {
            patientCdsCards = [];
            return;
        }

        isEvaluatingCds = true;
        StateHasChanged();

        try
        {
            var results = await System.Threading.Tasks.Task.WhenAll(
                activeMeds.Select(m => DecisionSupportService.EvaluateCardsAsync(m, Id)));

            patientCdsCards = results
                .SelectMany(cards => cards)
                .GroupBy(c => (c.Summary, c.Detail))
                .Select(g => g.First())
                .ToList();
        }
        catch
        {
            // Non-fatal: the alerts panel simply stays empty.
        }
        finally
        {
            isEvaluatingCds = false;
        }
    }

    private async System.Threading.Tasks.Task LoadManagingOrganizationNameAsync()
    {
        managingOrganizationName = null;

        var organizationId = DMRS.Client.Services.FhirReferenceHelper.ExtractReferenceId(
            patient?.ManagingOrganization?.Reference, "organization");
        if (string.IsNullOrWhiteSpace(organizationId))
        {
            return;
        }

        try
        {
            var organization = await OrganizationService.GetAsync(organizationId);
            managingOrganizationName = string.IsNullOrWhiteSpace(organization?.Name) ? null : organization.Name;
        }
        catch
        {
            // Non-fatal: DisplayPatientDemographics falls back to the reference id.
        }
    }

    private async System.Threading.Tasks.Task LoadDocumentsAsync()
    {
        isLoadingDocuments = true;
        try
        {
            documents = (await DocumentService.ListAsync(Id)).ToList();
        }
        catch
        {
            // Non-fatal: documents panel simply stays empty
        }
        finally
        {
            isLoadingDocuments = false;
        }
    }

    private async Task HandleFileUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;

        isUploading = true;
        uploadError = null;
        uploadSuccess = null;

        try
        {
            var uploaded = await DocumentService.UploadAsync(Id, file);
            if (uploaded is not null)
            {
                documents.Insert(0, uploaded);
                uploadSuccess = Loc["patients.docs.uploadSuccess", file.Name];
            }
        }
        catch (Exception ex)
        {
            uploadError = Loc["patients.docs.uploadFailed", ex.Message];
        }
        finally
        {
            isUploading = false;
        }
    }

    private async Task DeleteDocumentAsync(string documentId)
    {
        isDeletingDocument = true;
        try
        {
            await DocumentService.DeleteAsync(Id, documentId);
            documents.RemoveAll(d => d.Id == documentId);
        }
        catch (Exception ex)
        {
            uploadError = Loc["patients.docs.deleteFailed", ex.Message];
        }
        finally
        {
            isDeletingDocument = false;
        }
    }

    private async Task GenerateInvite()
    {
        if (patient?.Id is null)
        {
            return;
        }

        isGeneratingInvite = true;
        inviteError = null;

        try
        {
            inviteResult = await PatientService.GenerateInviteAsync(patient.Id, NavigationManager.BaseUri);
            existingInviteCode = inviteResult.InviteCode;
        }
        catch (Exception ex)
        {
            inviteError = Loc["patients.account.inviteFailed", ex.Message];
        }
        finally
        {
            isGeneratingInvite = false;
        }
    }

    private bool IsLinkedToAccount(Hl7.Fhir.Model.Patient resource)
    {
        var keycloakSystem = BuildKeycloakIdentifierSystem(Configuration["Keycloak:Authority"]);
        return resource.Identifier.Any(i => string.Equals(i.System, keycloakSystem, StringComparison.OrdinalIgnoreCase));
    }

    private string? GetInviteCode(Hl7.Fhir.Model.Patient resource)
    {
        return resource.Identifier
            .FirstOrDefault(i => string.Equals(i.System, InviteCodeIdentifierSystem, StringComparison.OrdinalIgnoreCase))
            ?.Value;
    }

    private static string BuildKeycloakIdentifierSystem(string? authority)
    {
        if (string.IsNullOrWhiteSpace(authority))
        {
            return "https://keycloak.local/users";
        }

        return $"{authority.TrimEnd('/')}/users";
    }

    private string? BuildClaimLink(string? inviteCode)
    {
        if (string.IsNullOrWhiteSpace(inviteCode))
        {
            return null;
        }

        var baseUri = NavigationManager.BaseUri.TrimEnd('/');
        return $"{baseUri}/patients/claim?code={Uri.EscapeDataString(inviteCode)}";
    }

    private string? BuildRegistrationLink(string? inviteCode)
    {
        if (string.IsNullOrWhiteSpace(inviteCode))
        {
            return null;
        }

        var claimLink = BuildClaimLink(inviteCode);
        if (string.IsNullOrWhiteSpace(claimLink))
        {
            return null;
        }

        var autoClaimLink = $"{claimLink}&auto=true";
        var keycloakAuthority = Configuration["Keycloak:Authority"] ?? "http://localhost:8080/realms/DMRS";
        var keycloakClientId = Configuration["Keycloak:ClientId"] ?? "dmrs-api";
        var authBase = keycloakAuthority.TrimEnd('/');

        return $"{authBase}/protocol/openid-connect/registrations"
            + $"?client_id={Uri.EscapeDataString(keycloakClientId)}"
            + "&response_type=code"
            + $"&scope={Uri.EscapeDataString("openid profile")}"
            + $"&redirect_uri={Uri.EscapeDataString(autoClaimLink)}";
    }

    private const string InviteCodeIdentifierSystem = "https://dmrs.local/invites/patient";

    private static string RiskBarClass(string riskLevel) => riskLevel switch
    {
        "High"   => "bg-danger",
        "Medium" => "bg-warning",
        _        => "bg-success"
    };

    private static string RiskLevelPillClass(string riskLevel) => riskLevel switch
    {
        "High"   => "dmrs-pill--danger",
        "Medium" => "dmrs-pill--warning",
        _        => "dmrs-pill--success"
    };

    // The model's binary verdict (positive class at its decision threshold), shown next to the score.
    private static string VerdictBadgeClass(bool isPositive)
        => isPositive ? "text-bg-danger" : "text-bg-success";

    private string VerdictText(bool isPositive)
        => isPositive ? Loc["common.yes"] : Loc["common.no"];

    private static string GetConditionLabel(Hl7.Fhir.Model.Condition condition)
        => condition.Code?.Text
            ?? condition.Code?.Coding.FirstOrDefault()?.Display
            ?? condition.Code?.Coding.FirstOrDefault()?.Code
            ?? "Condition";

    private static string GetAllergyLabel(Hl7.Fhir.Model.AllergyIntolerance allergy)
        => allergy.Code?.Text
            ?? allergy.Code?.Coding.FirstOrDefault()?.Display
            ?? allergy.Code?.Coding.FirstOrDefault()?.Code
            ?? "Allergy";

    private static string GetObservationLabel(Hl7.Fhir.Model.Observation observation)
        => observation.Code?.Text
            ?? observation.Code?.Coding.FirstOrDefault()?.Display
            ?? observation.Code?.Coding.FirstOrDefault()?.Code
            ?? "Observation";

    private static string GetMedicationLabel(Hl7.Fhir.Model.MedicationRequest medicationRequest)
        => medicationRequest.Medication?.Concept?.Text
            ?? medicationRequest.Medication?.Concept?.Coding.FirstOrDefault()?.Display
            ?? medicationRequest.Medication?.Concept?.Coding.FirstOrDefault()?.Code
            ?? medicationRequest.Medication?.Reference?.Reference
            ?? "Medication request";

    private static string GetEncounterLabel(Hl7.Fhir.Model.Encounter encounter)
        => encounter.Type.FirstOrDefault()?.Text
            ?? encounter.Type.FirstOrDefault()?.Coding.FirstOrDefault()?.Display
            ?? encounter.Class?.FirstOrDefault()?.Coding.FirstOrDefault()?.Code
            ?? "Encounter";

    private static string GetAppointmentLabel(Hl7.Fhir.Model.Appointment appointment)
        => appointment.Description
            ?? appointment.AppointmentType?.Text
            ?? appointment.AppointmentType?.Coding.FirstOrDefault()?.Display
            ?? "Appointment";

    private static string GetAppointmentDate(Hl7.Fhir.Model.Appointment appointment)
    {
        if (DateTimeOffset.TryParse(appointment.StartElement?.Value?.ToString(), out var start))
        {
            return start.ToLocalTime().ToString("dd MMM yyyy HH:mm");
        }

        return appointment.SafeStatus().Length > 0 ? appointment.SafeStatus() : "unknown";
    }
}
