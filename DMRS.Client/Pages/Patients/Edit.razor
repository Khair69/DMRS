@page "/patients/{Id}/edit"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN,ROLE_PRACTITIONER")]
@inherits DMRS.Client.Components.LocalizedComponentBase
@inject DMRS.Client.Features.Patients.Services.PatientFeatureService PatientService
@inject DMRS.Client.Services.OrganizationContextService OrgContextService
@inject NavigationManager Navigation

<PageTitle>@Loc["patients.edit.title"]</PageTitle>

<h1>@Loc["patients.edit.title"]</h1>

@if (isLoading)
{
    <div class="spinner-border" role="status"></div>
}
else
{
    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    <PatientForm Model="model" IsBusy="@isSaving" SubmitText="@Loc["patients.edit.submit"]" OnSave="Save" ShowOrganizationField="@showOrganizationField" />
}

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;

    private PatientEditModel model = new();
    private bool isLoading;
    private bool isSaving;
    private string? errorMessage;
    private bool showOrganizationField;

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var patient = await PatientService.GetAsync(Id);
            if (patient is null)
            {
                errorMessage = Loc["patients.notFound", Id];
                return;
            }

            model = PatientEditModel.FromPatient(patient);

            var organizationIds = await OrgContextService.GetOrganizationIdsAsync();
            if (organizationIds.Count > 0 && string.IsNullOrWhiteSpace(model.ManagingOrganizationId))
            {
                model.ManagingOrganizationId = organizationIds[0];
            }

            showOrganizationField = organizationIds.Count != 1;
        }
        catch (Exception ex)
        {
            errorMessage = Loc["patients.loadFailed", ex.Message];
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task Save()
    {
        errorMessage = null;
        isSaving = true;

        try
        {
            if (showOrganizationField && string.IsNullOrWhiteSpace(model.ManagingOrganizationId))
            {
                errorMessage = Loc["patients.orgRequired"];
                return;
            }

            await PatientService.UpdatePatientAsync(Id, model);
            Navigation.NavigateTo($"/patients/{Id}");
        }
        catch (Exception ex)
        {
            errorMessage = Loc["patients.updateFailed", ex.Message];
        }
        finally
        {
            isSaving = false;
        }
    }
}
