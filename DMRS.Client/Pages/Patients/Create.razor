@page "/patients/new"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN,ROLE_PRACTITIONER")]
@inject DMRS.Client.Features.Patients.Services.PatientFeatureService PatientService
@inject DMRS.Client.Services.OrganizationContextService OrgContextService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager

<PageTitle>Create Patient</PageTitle>

<h1>Create Patient</h1>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success">@successMessage</div>
}

@if (inviteResult is not null)
{
    <div class="card mt-3 mb-3">
        <div class="card-header">Invitation Generated</div>
        <div class="card-body">
            <p class="mb-2"><strong>Invite code</strong>: <code>@inviteResult.InviteCode</code></p>
            <p class="mb-2"><strong>Self-registration (auto-claim)</strong>: <a href="@inviteResult.RegistrationLink" target="_blank">@inviteResult.RegistrationLink</a></p>
            <p class="mb-0"><strong>Manual claim fallback</strong>: <a href="@inviteResult.ClaimLink" target="_blank">@inviteResult.ClaimLink</a></p>
        </div>
    </div>
}

<PatientForm Model="model" IsBusy="@isSaving" SubmitText="Create Patient & Invite" OnSave="Save" ShowOrganizationField="@showOrganizationField" OrganizationReadOnly="@organizationReadOnly" />

@code {
    private readonly PatientEditModel model = new();
    private bool isSaving;
    private string? errorMessage;
    private string? successMessage;
    private bool showOrganizationField;
    private bool organizationReadOnly;
    private DMRS.Client.Features.Patients.Services.PatientInviteResult? inviteResult;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var isSystemAdmin = authState.User.IsInRole("ROLE_SYSTEM_ADMIN");

        // A new Patient must carry managingOrganization or it is invisible to org-scoped users
        // (see SmartAuthorizationService.ResolveAccessiblePatientIdsAsync). Default it to the
        // caller's organization so org admins and practitioners can immediately see who they create.
        var organizationIds = await OrgContextService.GetOrganizationIdsAsync();
        var primaryOrganizationId = organizationIds.FirstOrDefault();
        if (!string.IsNullOrWhiteSpace(primaryOrganizationId))
        {
            model.ManagingOrganizationId = primaryOrganizationId;
        }

        // The organization field is always shown. System admins may pick/override it; org admins and
        // practitioners are locked to their own organization (read-only when they have exactly one).
        showOrganizationField = true;
        organizationReadOnly = !isSystemAdmin && organizationIds.Count == 1;
    }

    private async Task Save()
    {
        isSaving = true;
        errorMessage = null;
        successMessage = null;
        inviteResult = null;
        try
        {
            if (string.IsNullOrWhiteSpace(model.ManagingOrganizationId))
            {
                errorMessage = "Managing organization is required.";
                return;
            }

            inviteResult = await PatientService.CreateInviteAsync(model, NavigationManager.BaseUri);
            successMessage = $"Patient created. Invitation ready for Patient/{inviteResult.PatientId}.";
        }
        catch (Exception ex)
        {
            errorMessage = $"An error occurred while creating the patient: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }
}
