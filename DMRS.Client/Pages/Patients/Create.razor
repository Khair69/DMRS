@page "/patients/new"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN,ROLE_PRACTITIONER")]
@inject DMRS.Client.Features.Patients.Services.PatientFeatureService PatientService
@inject DMRS.Client.Services.OrganizationContextService OrgContextService
@inject NavigationManager NavigationManager

<PageTitle>Create Patient</PageTitle>

<h1>Create Patient</h1>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<PatientForm Model="model" IsBusy="@isSaving" SubmitText="Create Patient" OnSave="Save" ShowOrganizationField="@showOrganizationField" />

@code {
    private readonly PatientEditModel model = new();
    private bool isSaving;
    private string? errorMessage;
    private bool showOrganizationField;

    protected override async Task OnInitializedAsync()
    {
        var organizationIds = await OrgContextService.GetOrganizationIdsAsync();
        if (organizationIds.Count > 0)
        {
            model.ManagingOrganizationId = organizationIds[0];
            showOrganizationField = organizationIds.Count != 1;
        }
        else
        {
            showOrganizationField = true;
        }
    }

    private async Task Save()
    {
        isSaving = true;
        errorMessage = null;
        try
        {
            if (showOrganizationField && string.IsNullOrWhiteSpace(model.ManagingOrganizationId))
            {
                errorMessage = "Managing organization is required.";
                return;
            }

            var createdPatient = await PatientService.CreateAsync(model);
            if (createdPatient?.Id is null)
            {
                errorMessage = "Patient was created but no id was returned.";
                return;
            }
            NavigationManager.NavigateTo($"/patients/{createdPatient.Id}");
        }
        catch (Exception ex)
        {
            errorMessage = $"An error occurred while creating the patient: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }
}
