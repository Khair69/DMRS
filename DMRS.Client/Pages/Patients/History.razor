@page "/patients/{Id}/history"
@attribute [Authorize]
@inject DMRS.Client.Features.Patients.Services.PatientFeatureService PatientService

<PageTitle>Patient History</PageTitle>

<h1>Patient History</h1>

@if (isBusy)
{
    <div class="spinner-border" role="status"></div>
}
else
{
    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    <PatientHistoryTable History="history" />
}

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;

    private IReadOnlyList<Hl7.Fhir.Model.Patient> history = [];
    private bool isBusy;
    private string? errorMessage;

    protected override async Task OnParametersSetAsync()
    {
        isBusy = true;
        errorMessage = null;

        try
        {
            history = await PatientService.GetPatientHistoryAsync(Id);
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load history: {ex.Message}";
            history = [];
        }
        finally
        {
            isBusy = false;
        }
    }
}