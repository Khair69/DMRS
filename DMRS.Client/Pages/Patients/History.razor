@page "/patients/{Id}/history"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN,ROLE_PRACTITIONER")]
@inherits DMRS.Client.Components.LocalizedComponentBase
@inject DMRS.Client.Features.Patients.Services.PatientFeatureService PatientService

<PageTitle>@Loc["patients.history.title"]</PageTitle>

<h1>@Loc["patients.history.title"]</h1>

@if (isBusy)
{
    <div class="spinner-border" role="status"></div>
}
else
{
    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    <PatientHistoryTable History="history" />
}

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;

    private IReadOnlyList<Hl7.Fhir.Model.Patient> history = [];
    private bool isBusy;
    private string? errorMessage;

    protected override async Task OnParametersSetAsync()
    {
        isBusy = true;
        errorMessage = null;

        try
        {
            history = await PatientService.GetHistoryAsync(Id);
        }
        catch (Exception ex)
        {
            errorMessage = Loc["patients.loadFailed", ex.Message];
            history = [];
        }
        finally
        {
            isBusy = false;
        }
    }
}
