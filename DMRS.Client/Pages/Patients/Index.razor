@page "/patients"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN,ROLE_PRACTITIONER")]
@inherits DMRS.Client.Components.LocalizedComponentBase
@using DMRS.Client.Features.Patients.Models
@inject DMRS.Client.Features.Patients.Services.PatientFeatureService PatientService
@inject DMRS.Client.Services.OrganizationContextService OrgContextService

<PageTitle>@Loc["patients.title"]</PageTitle>

<ResourceIndexPage TSummary="PatientSummaryViewModel"
                   Title="@Loc["patients.title"]"
                   NewLink="/patients/new"
                   NewLabel="@Loc["patients.new"]"
                   EntityName="@Loc["patients.entityName"]"
                   EmptyText="@Loc["patients.empty"]"
                   SearchFields="SearchFieldList"
                   LoadDefault="LoadPatients"
                   Search="(p, v) => PatientService.SearchAsync(p, v)"
                   Suggest="(p, v) => PatientService.SuggestAsync(p, v)">
    <HeaderTemplate>
        <th>@Loc["common.field.id"]</th>
        <th>@Loc["common.field.name"]</th>
        <th>@Loc["common.field.identifier"]</th>
        <th>@Loc["common.field.gender"]</th>
        <th>@Loc["common.field.birthDate"]</th>
        <th></th>
    </HeaderTemplate>
    <RowTemplate Context="patient">
        <td>@patient.Id</td>
        <td>@patient.DisplayName</td>
        <td>@patient.Identifier</td>
        <td>@patient.Gender</td>
        <td>@patient.BirthDate</td>
        <td class="text-nowrap">
            <NavLink class="btn btn-sm btn-outline-primary me-1" href="@($"/patients/{patient.Id}")">@Loc["common.details"]</NavLink>
            <NavLink class="btn btn-sm btn-outline-secondary me-1" href="@($"/patients/{patient.Id}/edit")">@Loc["common.edit"]</NavLink>
            <NavLink class="btn btn-sm btn-outline-info" href="@($"/patients/{patient.Id}/history")">@Loc["common.history"]</NavLink>
        </td>
    </RowTemplate>
</ResourceIndexPage>

@code {
    // Identifier (patient number / national number) is first so it is the default search field —
    // a precise lookup, unlike names which collide across patients.
    private IReadOnlyList<SearchField> SearchFieldList =>
    [
        new("identifier", Loc["patients.search.identifier.label"], Loc["patients.search.identifier.placeholder"]),
        new("family", Loc["common.field.familyName"], Loc["patients.search.family.placeholder"]),
        new("given", Loc["common.field.givenName"], Loc["patients.search.given.placeholder"]),
        new("organization", Loc["patients.search.organization.label"], Loc["patients.search.organization.placeholder"]),
    ];

    // Default view is scoped to the practitioner/admin's organization when there is one; a system
    // admin with no org context sees the most-recent patients across everything they may read.
    private async Task<IReadOnlyList<PatientSummaryViewModel>> LoadPatients(int cap)
    {
        var orgId = await OrgContextService.GetPrimaryOrganizationIdAsync();
        return string.IsNullOrWhiteSpace(orgId)
            ? await PatientService.ListAsync(cap)
            : await PatientService.ListAsync(cap, new() { ["organization"] = $"Organization/{orgId}" });
    }
}
