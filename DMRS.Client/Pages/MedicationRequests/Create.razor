@page "/medication-requests/new"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN,ROLE_PRACTITIONER")]
@using DMRS.Client.Features.MedicationRequests.Models
@inject DMRS.Client.Features.MedicationRequests.Services.MedicationRequestFeatureService MedicationService
@inject DMRS.Client.Features.MedicationRequests.Services.MedicationDecisionSupportService DecisionSupportService
@inject NavigationManager NavigationManager

<PageTitle>Create Medication Request</PageTitle>

<div class="workspace-hero workspace-hero--patient">
    <div>
        <span class="workspace-eyebrow">Medication Workflow</span>
        <h1>Create Medication Request</h1>
        <p>Capture a coded prescription and preview medication decision support before you save it.</p>
    </div>
    <div class="workspace-hero__actions">
        <button class="btn btn-light" @onclick="PreviewDecisionSupportAsync" disabled="@isPreviewing">Preview CDS</button>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<div class="row g-4">
    <div class="col-12 col-xl-7">
        <div class="dmrs-panel">
            <div class="dmrs-panel__header">
                <div>
                    <div class="dmrs-panel__title">Prescription Draft</div>
                    <div class="dmrs-panel__subtitle">Structured medication fields make CDS and medicine lookup work much better.</div>
                </div>
            </div>

            <MedicationRequestForm Model="model" IsBusy="@isSaving" SubmitText="Create Medication Request" OnSave="Save" />
        </div>
    </div>

    <div class="col-12 col-xl-5">
        <div class="dmrs-panel">
            <div class="dmrs-panel__header">
                <div>
                    <div class="dmrs-panel__title">Clinical Decision Preview</div>
                    <div class="dmrs-panel__subtitle">Use RxCUI plus dose and frequency to trigger the existing CDS rules.</div>
                </div>
            </div>

            <div class="d-grid gap-3">
                <div class="dmrs-note-card">
                    <div class="dmrs-note-card__title">Try These Demo Values</div>
                    <p class="mb-2"><strong>High-dose alert:</strong> Patient `cds-test-patient`, RxCUI `161`, dose `1500`, frequency `3`.</p>
                    <p class="mb-0"><strong>Warmup/knowledge check:</strong> RxCUI `5640` for Ibuprofen.</p>
                </div>

                @if (isPreviewing)
                {
                    <div class="dmrs-loading-shell">
                        <div class="spinner-border text-primary" role="status"></div>
                    </div>
                }
                else if (!string.IsNullOrWhiteSpace(previewError))
                {
                    <div class="alert alert-danger mb-0">@previewError</div>
                }
                else if (snapshot is null)
                {
                    <div class="dmrs-empty-state">Use the preview button to inspect medicine knowledge and CDS cards before saving.</div>
                }
                else
                {
                    <div class="dmrs-note-card">
                        <div class="dmrs-note-card__title">Medicine Knowledge</div>
                        @if (snapshot.Medicine is null)
                        {
                            <p class="mb-0">No normalized medicine record was resolved from the current draft.</p>
                        }
                        else
                        {
                            <p class="mb-1"><strong>@snapshot.Medicine.Name</strong> (RxCUI @snapshot.Medicine.RxCui)</p>
                            <p class="mb-1">Max daily dose: @(snapshot.Medicine.MaxDailyMg?.ToString("0.##") ?? "n/a") mg</p>
                            <p class="mb-0">Ingredients: @string.Join(", ", snapshot.Medicine.Ingredients.Select(i => i.Name))</p>
                        }
                    </div>

                    <div class="dmrs-note-card">
                        <div class="dmrs-note-card__title">CDS Result</div>
                        @if (snapshot.HookResponse?.Cards.Count > 0)
                        {
                            @foreach (var card in snapshot.HookResponse.Cards)
                            {
                                <div class="dmrs-mini-row">
                                    <div class="dmrs-mini-row__title">@card.Summary</div>
                                    <div class="dmrs-mini-row__meta">@card.Detail</div>
                                </div>
                            }
                        }
                        else
                        {
                            <p class="mb-0">The current draft did not trigger any CDS cards.</p>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private readonly MedicationRequestEditModel model = new();
    private bool isSaving;
    private bool isPreviewing;
    private string? errorMessage;
    private string? previewError;
    private MedicationDecisionSupportSnapshotModel? snapshot;

    private async Task Save()
    {
        isSaving = true;
        errorMessage = null;
        try
        {
            var created = await MedicationService.CreateAsync(model);
            if (created?.Id is null)
            {
                errorMessage = "Medication request was created but no id was returned.";
                return;
            }

            NavigationManager.NavigateTo($"/medication-requests/{created.Id}");
        }
        catch (Exception ex)
        {
            errorMessage = $"An error occurred while creating the medication request: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task PreviewDecisionSupportAsync()
    {
        isPreviewing = true;
        previewError = null;

        try
        {
            snapshot = await DecisionSupportService.GetSnapshotAsync(model.ToFhirMedicationRequest(), model.PatientId);
        }
        catch (Exception ex)
        {
            previewError = $"Unable to preview medication decision support: {ex.Message}";
        }
        finally
        {
            isPreviewing = false;
        }
    }
}
