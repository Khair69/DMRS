@page "/medication-requests/new"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN,ROLE_PRACTITIONER")]
@using DMRS.Client.Features.MedicationRequests.Models
@inherits DMRS.Client.Components.LocalizedComponentBase
@inject DMRS.Client.Features.MedicationRequests.Services.MedicationRequestFeatureService MedicationService
@inject DMRS.Client.Features.MedicationRequests.Services.MedicationDecisionSupportService DecisionSupportService
@inject NavigationManager NavigationManager

<PageTitle>@Loc["medications.create.title"]</PageTitle>

<div class="workspace-hero workspace-hero--patient">
    <div>
        <span class="workspace-eyebrow">@Loc["medications.workflow.eyebrow"]</span>
        <h1>@Loc["medications.create.title"]</h1>
        <p>@Loc["medications.preview.heroSubtitle"]</p>
    </div>
    <div class="workspace-hero__actions">
        <button class="btn btn-light" @onclick="PreviewDecisionSupportAsync" disabled="@isPreviewing">@Loc["medications.preview.button"]</button>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<div class="row g-4">
    <div class="col-12 col-xl-7">
        <div class="dmrs-panel">
            <div class="dmrs-panel__header">
                <div>
                    <div class="dmrs-panel__title">@Loc["medications.preview.draftTitle"]</div>
                    <div class="dmrs-panel__subtitle">@Loc["medications.preview.draftSubtitle"]</div>
                </div>
            </div>

            <MedicationRequestForm Model="model" IsBusy="@isSaving" SubmitText="@Loc["medications.create.submit"]" OnSave="Save" />
        </div>
    </div>

    <div class="col-12 col-xl-5">
        <div class="dmrs-panel">
            <div class="dmrs-panel__header">
                <div>
                    <div class="dmrs-panel__title">@Loc["medications.preview.title"]</div>
                    <div class="dmrs-panel__subtitle">@Loc["medications.preview.subtitle"]</div>
                </div>
            </div>

            <div class="d-grid gap-3">
                <div class="dmrs-note-card">
                    <div class="dmrs-note-card__title">@Loc["medications.preview.demoTitle"]</div>
                    <p class="mb-2"><strong>@Loc["medications.preview.demoHighDoseLabel"]</strong> @Loc["medications.preview.demoHighDoseBody"]</p>
                    <p class="mb-0"><strong>@Loc["medications.preview.demoWarmupLabel"]</strong> @Loc["medications.preview.demoWarmupBody"]</p>
                </div>

                @if (isPreviewing)
                {
                    <div class="dmrs-loading-shell">
                        <div class="spinner-border text-primary" role="status"></div>
                    </div>
                }
                else if (!string.IsNullOrWhiteSpace(previewError))
                {
                    <div class="alert alert-danger mb-0">@previewError</div>
                }
                else if (snapshot is null)
                {
                    <div class="dmrs-empty-state">@Loc["medications.preview.empty"]</div>
                }
                else
                {
                    <div class="dmrs-note-card">
                        <div class="dmrs-note-card__title">@Loc["medications.cds.medicineKnowledge"]</div>
                        @if (snapshot.Medicine is null)
                        {
                            <p class="mb-0">@Loc["medications.preview.noMedicineDraft"]</p>
                        }
                        else
                        {
                            <p class="mb-1"><strong>@snapshot.Medicine.Name</strong> (RxCUI @snapshot.Medicine.RxCui)</p>
                            <p class="mb-1">@Loc["medications.cds.maxDailyDose"] @(snapshot.Medicine.MaxDailyMg?.ToString("0.##") ?? Loc["common.notAvailable"]) mg</p>
                            <p class="mb-0">@Loc["medications.cds.ingredients"] @string.Join(", ", snapshot.Medicine.Ingredients.Select(i => i.Name))</p>
                        }
                    </div>

                    <div class="dmrs-note-card">
                        <div class="dmrs-note-card__title">@Loc["medications.preview.cdsResult"]</div>
                        @if (snapshot.HookResponse?.Cards.Count > 0)
                        {
                            <CdsCardList Cards="snapshot.HookResponse.Cards" />
                        }
                        else
                        {
                            <p class="mb-0">@Loc["medications.preview.noCardsDraft"]</p>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private readonly MedicationRequestEditModel model = new();
    private bool isSaving;
    private bool isPreviewing;
    private string? errorMessage;
    private string? previewError;
    private MedicationDecisionSupportSnapshotModel? snapshot;

    private async Task Save()
    {
        isSaving = true;
        errorMessage = null;
        try
        {
            var created = await MedicationService.CreateAsync(model);
            if (created?.Id is null)
            {
                errorMessage = Loc["medications.noIdReturned"];
                return;
            }

            NavigationManager.NavigateTo($"/medication-requests/{created.Id}");
        }
        catch (Exception ex)
        {
            errorMessage = Loc["medications.createError", ex.Message];
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task PreviewDecisionSupportAsync()
    {
        // Validate the patient ID here — the Preview button lives outside the EditForm
        // so normal [Required] validation does not run before this handler is invoked.
        if (string.IsNullOrWhiteSpace(model.PatientId))
        {
            previewError = Loc["medications.preview.patientRequired"];
            return;
        }

        isPreviewing = true;
        previewError = null;

        try
        {
            snapshot = await DecisionSupportService.GetSnapshotAsync(model.ToFhirMedicationRequest(), model.PatientId);
        }
        catch (Exception ex)
        {
            previewError = Loc["medications.preview.failed", ex.Message];
        }
        finally
        {
            isPreviewing = false;
        }
    }
}
