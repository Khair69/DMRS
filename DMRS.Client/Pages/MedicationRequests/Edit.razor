@page "/medication-requests/{Id}/edit"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN,ROLE_PRACTITIONER")]
@inherits DMRS.Client.Components.LocalizedComponentBase
@inject DMRS.Client.Features.MedicationRequests.Services.MedicationRequestFeatureService MedicationService
@inject NavigationManager Navigation

<PageTitle>@Loc["medications.edit.title"]</PageTitle>

<h1>@Loc["medications.edit.title"]</h1>

@if (isLoading)
{
    <div class="spinner-border" role="status"></div>
}
else
{
    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    <MedicationRequestForm Model="model" IsBusy="@isSaving" SubmitText="@Loc["medications.edit.submit"]" OnSave="Save" />
}

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;

    private DMRS.Client.Features.MedicationRequests.Models.MedicationRequestEditModel model = new();
    private bool isLoading;
    private bool isSaving;
    private string? errorMessage;

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var request = await MedicationService.GetAsync(Id);
            if (request is null)
            {
                errorMessage = Loc["medications.notFound", Id];
                return;
            }

            model = DMRS.Client.Features.MedicationRequests.Models.MedicationRequestEditModel.FromMedicationRequest(request);
        }
        catch (Exception ex)
        {
            errorMessage = Loc["medications.loadFailed", ex.Message];
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task Save()
    {
        errorMessage = null;
        isSaving = true;

        try
        {
            await MedicationService.UpdateAsync(Id, model);
            Navigation.NavigateTo($"/medication-requests/{Id}");
        }
        catch (Exception ex)
        {
            errorMessage = Loc["medications.updateFailed", ex.Message];
        }
        finally
        {
            isSaving = false;
        }
    }
}
