@page "/medication-requests/{Id}"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN,ROLE_PRACTITIONER")]
@using DMRS.Client.Features.MedicationRequests.Models
@inherits DMRS.Client.Components.LocalizedComponentBase
@inject DMRS.Client.Features.MedicationRequests.Services.MedicationRequestFeatureService MedicationService
@inject DMRS.Client.Features.MedicationRequests.Services.MedicationDecisionSupportService DecisionSupportService

<PageTitle>@Loc["medications.details.title"]</PageTitle>

@if (isLoading)
{
    <div class="dmrs-loading-shell">
        <div class="spinner-border text-primary" role="status"><span class="visually-hidden">@Loc["common.loading"]</span></div>
    </div>
}
else if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (request is not null)
{
    <div class="workspace-hero workspace-hero--patient">
        <div>
            <span class="workspace-eyebrow">@Loc["medications.workflow.eyebrow"]</span>
            <h1>@DisplayMedicationName</h1>
            <p>@Loc["medications.details.subline", PatientIdDisplay, request.Status?.ToString() ?? "", request.Intent?.ToString() ?? ""]</p>
        </div>
        <div class="workspace-hero__actions">
            <NavLink class="btn btn-light" href="@($"/medication-requests/{Id}/edit")">@Loc["common.edit"]</NavLink>
            <NavLink class="btn btn-outline-light" href="@($"/medication-requests/{Id}/history")">@Loc["common.history"]</NavLink>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-12 col-xl-7">
            <div class="dmrs-panel">
                <div class="dmrs-panel__header">
                    <div>
                        <div class="dmrs-panel__title">@Loc["medications.summary.title"]</div>
                        <div class="dmrs-panel__subtitle">@Loc["medications.summary.subtitle"]</div>
                    </div>
                </div>

                @{
                    var summary = MedicationRequestEditModel.FromMedicationRequest(request);
                }
                <dl class="dmrs-detail-list">
                    <div class="dmrs-detail-list__row">
                        <dt>@Loc["medications.field.medication"]</dt>
                        <dd>@DisplayMedicationName</dd>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(summary.MedicationRxCui))
                    {
                        <div class="dmrs-detail-list__row">
                            <dt>@Loc["medications.field.rxcui"]</dt>
                            <dd>@summary.MedicationRxCui</dd>
                        </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(summary.PatientId))
                    {
                        <div class="dmrs-detail-list__row">
                            <dt>@Loc["medications.field.patient"]</dt>
                            <dd><a href="@($"/patients/{summary.PatientId}")">@summary.PatientId</a></dd>
                        </div>
                    }
                    <div class="dmrs-detail-list__row">
                        <dt>@Loc["medications.field.status"]</dt>
                        <dd><span class="dmrs-pill @StatusPillClass(summary.Status)">@summary.Status</span></dd>
                    </div>
                    <div class="dmrs-detail-list__row">
                        <dt>@Loc["medications.field.intent"]</dt>
                        <dd>@summary.Intent</dd>
                    </div>
                    @if (summary.DoseMg.HasValue)
                    {
                        <div class="dmrs-detail-list__row">
                            <dt>@Loc["medications.field.dose"]</dt>
                            <dd>@summary.DoseMg.Value.ToString("0.##") mg</dd>
                        </div>
                    }
                    @if (summary.FrequencyPerDay.HasValue)
                    {
                        <div class="dmrs-detail-list__row">
                            <dt>@Loc["medications.field.frequency"]</dt>
                            <dd>@Loc["medications.field.frequencyValue", summary.FrequencyPerDay.Value]</dd>
                        </div>
                    }
                    @if (summary.DoseMg.HasValue && summary.FrequencyPerDay.HasValue)
                    {
                        <div class="dmrs-detail-list__row">
                            <dt>@Loc["medications.field.dailyDose"]</dt>
                            <dd>@((summary.DoseMg.Value * summary.FrequencyPerDay.Value).ToString("0.##")) mg/day</dd>
                        </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(AuthoredOnDisplay))
                    {
                        <div class="dmrs-detail-list__row">
                            <dt>@Loc["medications.field.authoredOn"]</dt>
                            <dd>@AuthoredOnDisplay</dd>
                        </div>
                    }
                </dl>

                <details class="dmrs-raw-json">
                    <summary>@Loc["medications.payload.rawToggle"]</summary>
                    <div class="dmrs-raw-json__scroll">
                        <FhirJsonView Resource="request" />
                    </div>
                </details>
            </div>
        </div>

        <div class="col-12 col-xl-5">
            <div class="dmrs-panel">
                <div class="dmrs-panel__header">
                    <div>
                        <div class="dmrs-panel__title">@Loc["medications.cds.snapshotTitle"]</div>
                        <div class="dmrs-panel__subtitle">@Loc["medications.cds.snapshotSubtitle"]</div>
                    </div>
                    <button class="btn btn-sm btn-outline-primary" @onclick="RefreshSnapshotAsync" disabled="@isRefreshing">
                        @(isRefreshing ? Loc["common.refreshing"] : Loc["common.refresh"])
                    </button>
                </div>

                @if (isRefreshing)
                {
                    <div class="dmrs-loading-shell">
                        <div class="spinner-border text-primary" role="status"></div>
                    </div>
                }
                else if (!string.IsNullOrWhiteSpace(snapshotError))
                {
                    <div class="alert alert-danger">@snapshotError</div>
                }
                else if (snapshot is not null)
                {
                    <div class="dmrs-stack">
                        <div class="dmrs-note-card">
                            <div class="dmrs-note-card__title">@Loc["medications.cds.medicineKnowledge"]</div>
                            @if (snapshot.Medicine is null)
                            {
                                <p class="mb-0">@Loc["medications.cds.noMedicineResolved"]</p>
                            }
                            else
                            {
                                <p class="mb-1"><strong>@snapshot.Medicine.Name</strong> (RxCUI @snapshot.Medicine.RxCui)</p>
                                <p class="mb-1">@Loc["medications.cds.maxDailyDose"] @(snapshot.Medicine.MaxDailyMg?.ToString("0.##") ?? Loc["common.notAvailable"]) mg</p>
                                <p class="mb-0">@Loc["medications.cds.ingredients"] @string.Join(", ", snapshot.Medicine.Ingredients.Select(i => i.Name))</p>
                            }
                        </div>

                        <div class="dmrs-note-card">
                            <div class="dmrs-note-card__title">@Loc["medications.cds.triggeredCards"]</div>
                            @if (snapshot.HookResponse?.Cards.Count > 0)
                            {
                                <CdsCardList Cards="snapshot.HookResponse.Cards" />
                            }
                            else
                            {
                                <p class="mb-0">@Loc["medications.cds.noCards"]</p>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;

    private Hl7.Fhir.Model.MedicationRequest? request;
    private string? errorMessage;
    private string? snapshotError;
    private bool isLoading = true;
    private bool isRefreshing;
    private MedicationDecisionSupportSnapshotModel? snapshot;

    private string PatientIdDisplay
        => DMRS.Client.Services.FhirReferenceHelper.ExtractReferenceId(request?.Subject?.Reference, "patient") ?? "unknown";

    private string DisplayMedicationName
        => request?.Medication?.Concept?.Text
            ?? request?.Medication?.Concept?.Coding.FirstOrDefault()?.Display
            ?? request?.Medication?.Concept?.Coding.FirstOrDefault()?.Code
            ?? "Medication Request";

    private string? AuthoredOnDisplay
        => DateTimeOffset.TryParse(request?.AuthoredOn, out var authored)
            ? authored.ToLocalTime().ToString("dd MMM yyyy HH:mm")
            : request?.AuthoredOn;

    private static string StatusPillClass(string? status) => status?.Trim().ToLowerInvariant() switch
    {
        "active" => "dmrs-pill--success",
        "on-hold" or "draft" => "dmrs-pill--warning",
        "stopped" or "cancelled" or "entered-in-error" => "dmrs-pill--danger",
        _ => "dmrs-pill--neutral"
    };

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        errorMessage = null;
        request = null;
        snapshot = null;
        try
        {
            request = await MedicationService.GetAsync(Id);
            if (request is null)
            {
                errorMessage = Loc["medications.notFound", Id];
                return;
            }

            await RefreshSnapshotAsync();
        }
        catch (Exception ex)
        {
            errorMessage = Loc["medications.loadFailed", ex.Message];
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task RefreshSnapshotAsync()
    {
        if (request is null)
        {
            return;
        }

        var patientId = PatientIdDisplay;
        if (string.IsNullOrWhiteSpace(patientId) || patientId == "unknown")
        {
            snapshotError = Loc["medications.cds.cannotEvaluate"];
            return;
        }

        isRefreshing = true;
        snapshotError = null;
        try
        {
            snapshot = await DecisionSupportService.GetSnapshotAsync(request, patientId);
        }
        catch (Exception ex)
        {
            snapshotError = Loc["medications.cds.refreshFailed", ex.Message];
        }
        finally
        {
            isRefreshing = false;
        }
    }
}
