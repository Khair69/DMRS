@page "/medication-requests"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN,ROLE_PRACTITIONER")]
@inherits DMRS.Client.Components.LocalizedComponentBase
@using DMRS.Client.Features.MedicationRequests.Models
@inject DMRS.Client.Features.MedicationRequests.Services.MedicationRequestFeatureService MedicationService

<PageTitle>@Loc["medications.title"]</PageTitle>

<ResourceIndexPage TSummary="MedicationRequestSummaryViewModel"
                   Title="@Loc["medications.title"]"
                   NewLink="/medication-requests/new"
                   NewLabel="@Loc["medications.new"]"
                   EntityName="@Loc["medications.entityName"]"
                   EmptyText="@Loc["medications.empty"]"
                   SearchFields="SearchFieldList"
                   LoadDefault="cap => MedicationService.ListAsync(cap)"
                   Search="(p, v) => MedicationService.SearchAsync(p, v)">
    <HeaderTemplate>
        <th>@Loc["common.field.id"]</th>
        <th>@Loc["common.field.patient"]</th>
        <th>@Loc["common.field.medication"]</th>
        <th>@Loc["common.field.status"]</th>
        <th>@Loc["common.field.intent"]</th>
    </HeaderTemplate>
    <RowTemplate Context="request">
        <td><NavLink href="@($"/medication-requests/{request.Id}")">@request.Id</NavLink></td>
        <td>@request.PatientId</td>
        <td>@request.MedicationText</td>
        <td>@request.Status</td>
        <td>@request.Intent</td>
    </RowTemplate>
</ResourceIndexPage>

@code {
    private IReadOnlyList<SearchField> SearchFieldList =>
    [
        new("patient", Loc["common.field.patient"], Loc["medications.search.patient.placeholder"]),
        new("code", Loc["common.field.medication"], Loc["medications.search.code.placeholder"]),
    ];
}
