@page "/medication-requests"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN,ROLE_PRACTITIONER")]
@using DMRS.Client.Features.MedicationRequests.Models
@inject DMRS.Client.Features.MedicationRequests.Services.MedicationRequestFeatureService MedicationService

<PageTitle>Medication Requests</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Medication Requests</h1>
    <NavLink class="btn btn-primary" href="/medication-requests/new">New Medication Request</NavLink>
</div>

<div class="card mb-3">
    <div class="card-body">
        <EditForm Model="this" OnSubmit="HandleSubmit">
            <div class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label">Search Field</label>
                    <InputSelect @bind-Value="searchParam" class="form-select">
                        <option value="patient">Patient</option>
                        <option value="code">Medication</option>
                    </InputSelect>
                </div>
                <div class="col-md-7">
                    <label class="form-label">Search Value</label>
                    <InputText @bind-Value="searchValue" class="form-control" placeholder="e.g. Patient/123" />
                </div>
                <div class="col-md-2 d-grid">
                    <button class="btn btn-primary" disabled="@isBusy" type="submit">Search</button>
                </div>
            </div>
        </EditForm>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (requests.Count == 0)
{
    <div class="alert alert-secondary">No medication requests found.</div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Id</th>
                <th>Patient</th>
                <th>Medication</th>
                <th>Status</th>
                <th>Intent</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var request in requests)
            {
                <tr>
                    <td>
                        <NavLink href="@($"/medication-requests/{request.Id}")">@request.Id</NavLink>
                    </td>
                    <td>@request.PatientId</td>
                    <td>@request.MedicationText</td>
                    <td>@request.Status</td>
                    <td>@request.Intent</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private string searchParam = "patient";
    private string searchValue = string.Empty;
    private bool isBusy;
    private string? errorMessage;
    private IReadOnlyList<MedicationRequestSummaryViewModel> requests = [];

    private async Task HandleSubmit()
    {
        errorMessage = null;
        isBusy = true;

        if (string.IsNullOrWhiteSpace(searchValue))
        {
            requests = [];
            isBusy = false;
            return;
        }

        try
        {
            requests = await MedicationService.SearchAsync(searchParam, searchValue);
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load medication requests: {ex.Message}";
            requests = [];
        }
        finally
        {
            isBusy = false;
        }
    }
}
