@page "/encounters"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN,ROLE_PRACTITIONER")]
@inherits DMRS.Client.Components.LocalizedComponentBase
@using DMRS.Client.Features.Encounters.Models
@inject DMRS.Client.Features.Encounters.Services.EncounterFeatureService EncounterService

<PageTitle>@Loc["encounters.title"]</PageTitle>

<ResourceIndexPage TSummary="EncounterSummaryViewModel"
                   Title="@Loc["encounters.title"]"
                   NewLink="/encounters/new"
                   NewLabel="@Loc["encounters.new"]"
                   EntityName="@Loc["encounters.entityName"]"
                   EmptyText="@Loc["encounters.empty"]"
                   SearchFields="SearchFieldList"
                   LoadDefault="cap => EncounterService.ListAsync(cap)"
                   Search="(p, v) => EncounterService.SearchAsync(p, v)">
    <HeaderTemplate>
        <th>@Loc["common.field.id"]</th>
        <th>@Loc["common.field.patient"]</th>
        <th>@Loc["common.field.status"]</th>
        <th>@Loc["common.field.classLabel"]</th>
    </HeaderTemplate>
    <RowTemplate Context="encounter">
        <td><NavLink href="@($"/encounters/{encounter.Id}")">@encounter.Id</NavLink></td>
        <td>@encounter.PatientId</td>
        <td>@encounter.Status</td>
        <td>@encounter.ClassCode</td>
    </RowTemplate>
</ResourceIndexPage>

@code {
    private IReadOnlyList<SearchField> SearchFieldList =>
    [
        new("patient", Loc["common.field.patient"], Loc["encounters.search.patient.placeholder"]),
        new("status", Loc["common.field.status"], Loc["encounters.search.status.placeholder"]),
    ];
}
