@page "/encounters"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN,ROLE_PRACTITIONER")]
@using DMRS.Client.Features.Encounters.Models
@inject DMRS.Client.Features.Encounters.Services.EncounterFeatureService EncounterService

<PageTitle>Encounters</PageTitle>

<ResourceIndexPage TSummary="EncounterSummaryViewModel"
                   Title="Encounters"
                   NewLink="/encounters/new"
                   NewLabel="New Encounter"
                   EntityName="encounters"
                   EmptyText="No encounters found."
                   SearchFields="_searchFields"
                   LoadDefault="cap => EncounterService.ListAsync(cap)"
                   Search="(p, v) => EncounterService.SearchAsync(p, v)">
    <HeaderTemplate>
        <th>Id</th>
        <th>Patient</th>
        <th>Status</th>
        <th>Class</th>
    </HeaderTemplate>
    <RowTemplate Context="encounter">
        <td><NavLink href="@($"/encounters/{encounter.Id}")">@encounter.Id</NavLink></td>
        <td>@encounter.PatientId</td>
        <td>@encounter.Status</td>
        <td>@encounter.ClassCode</td>
    </RowTemplate>
</ResourceIndexPage>

@code {
    private static readonly IReadOnlyList<SearchField> _searchFields =
    [
        new("patient", "Patient", "e.g. 123 (patient id)"),
        new("status", "Status", "e.g. in-progress"),
    ];
}
