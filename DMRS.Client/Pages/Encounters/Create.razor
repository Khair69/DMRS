@page "/encounters/new"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN,ROLE_PRACTITIONER")]
@inherits DMRS.Client.Components.LocalizedComponentBase
@inject DMRS.Client.Features.Encounters.Services.EncounterFeatureService EncounterService
@inject NavigationManager NavigationManager

<PageTitle>@Loc["encounters.create.title"]</PageTitle>

<h1>@Loc["encounters.create.title"]</h1>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<EncounterForm Model="model" IsBusy="@isSaving" SubmitText="@Loc["encounters.create.submit"]" OnSave="Save" />

@code {
    private readonly DMRS.Client.Features.Encounters.Models.EncounterEditModel model = new();
    private bool isSaving;
    private string? errorMessage;

    private async Task Save()
    {
        isSaving = true;
        errorMessage = null;
        try
        {
            var created = await EncounterService.CreateAsync(model);
            if (created?.Id is null)
            {
                errorMessage = Loc["encounters.noIdReturned"];
                return;
            }

            NavigationManager.NavigateTo($"/encounters/{created.Id}");
        }
        catch (Exception ex)
        {
            errorMessage = Loc["encounters.createError", ex.Message];
        }
        finally
        {
            isSaving = false;
        }
    }
}
