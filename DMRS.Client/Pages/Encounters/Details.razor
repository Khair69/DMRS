@page "/encounters/{Id}"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN,ROLE_PRACTITIONER")]
@inherits DMRS.Client.Components.LocalizedComponentBase
@inject DMRS.Client.Features.Encounters.Services.EncounterFeatureService EncounterService

<PageTitle>@Loc["encounters.details.title"]</PageTitle>

<h1>@Loc["encounters.details.title"]</h1>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<div class="mb-3">
    <NavLink class="btn btn-sm btn-outline-secondary me-1" href="@($"/encounters/{Id}/edit")">@Loc["common.edit"]</NavLink>
    <NavLink class="btn btn-sm btn-outline-info" href="@($"/encounters/{Id}/history")">@Loc["common.history"]</NavLink>
</div>

<FhirJsonView Resource="encounter" />

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;

    private Hl7.Fhir.Model.Encounter? encounter;
    private string? errorMessage;

    protected override async Task OnParametersSetAsync()
    {
        errorMessage = null;
        try
        {
            encounter = await EncounterService.GetAsync(Id);
            if (encounter is null)
            {
                errorMessage = Loc["encounters.notFound", Id];
            }
        }
        catch (Exception ex)
        {
            errorMessage = Loc["encounters.loadFailed", ex.Message];
        }
    }
}
