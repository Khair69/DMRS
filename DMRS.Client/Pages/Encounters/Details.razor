@page "/encounters/{Id}"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN,ROLE_PRACTITIONER")]
@inject DMRS.Client.Features.Encounters.Services.EncounterFeatureService EncounterService

<PageTitle>Encounter Details</PageTitle>

<h1>Encounter Details</h1>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<div class="mb-3">
    <NavLink class="btn btn-sm btn-outline-secondary me-1" href="@($"/encounters/{Id}/edit")">Edit</NavLink>
    <NavLink class="btn btn-sm btn-outline-info" href="@($"/encounters/{Id}/history")">History</NavLink>
</div>

<FhirJsonView Resource="encounter" />

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;

    private Hl7.Fhir.Model.Encounter? encounter;
    private string? errorMessage;

    protected override async Task OnParametersSetAsync()
    {
        errorMessage = null;
        try
        {
            encounter = await EncounterService.GetAsync(Id);
            if (encounter is null)
            {
                errorMessage = $"Encounter {Id} not found.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load encounter: {ex.Message}";
        }
    }
}
