@page "/ai-insights"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN,ROLE_PRACTITIONER")]
@using DMRS.Client.Features.AiInsights.Models
@using DMRS.Client.Features.Patients.Models
@inherits DMRS.Client.Components.LocalizedComponentBase
@inject DMRS.Client.Features.AiInsights.Services.AiInsightsFeatureService AiInsightsService
@inject DMRS.Client.Features.Patients.Services.PatientFeatureService PatientService

<PageTitle>@Loc["ai.title"]</PageTitle>

<div class="workspace-hero workspace-hero--ai">
    <div>
        <span class="workspace-eyebrow">@Loc["ai.eyebrow"]</span>
        <h1>@Loc["ai.title"]</h1>
        <p>
            @Loc["ai.intro"]
        </p>
    </div>
</div>

@if (isLoading)
{
    <div class="dmrs-loading-shell">
        <div class="spinner-border text-primary" role="status"></div>
    </div>
}
else if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
else
{
    <!-- Model catalog -->
    <div class="dmrs-metrics-grid dmrs-metrics-grid--compact mb-4">
        @foreach (var model in snapshot.Models)
        {
            <div class="dmrs-metric-card @model.AccentClass">
                <div class="dmrs-metric-card__label">@model.Title</div>
                <div class="dmrs-metric-card__value">@model.Total</div>
                <div class="dmrs-metric-card__helper">
                    @Loc["ai.scoredHelper", model.Accuracy, model.Auc]
                </div>
            </div>
        }
    </div>

    @foreach (var model in snapshot.Models)
    {
        <div class="dmrs-panel mb-4">
            <div class="dmrs-panel__header">
                <div>
                    <div class="dmrs-panel__title">@model.Title</div>
                    <div class="dmrs-panel__subtitle">@model.Predicts</div>
                </div>
                <div class="text-end small text-muted">
                    <div>@Loc["ai.trainedOn", model.Dataset]</div>
                    <div>@Loc["ai.accuracyAuc", model.Accuracy, model.Auc]</div>
                </div>
            </div>

            @if (model.Total == 0)
            {
                <div class="dmrs-empty-state">
                    @Loc["ai.modelEmpty"]
                </div>
            }
            else
            {
                var search = GetSearch(model.Key);
                var levelFilter = GetLevelFilter(model.Key);
                var isFiltering = !string.IsNullOrWhiteSpace(search) || levelFilter != "All";
                var rows = FilterRows(model, search, levelFilter);

                <!-- Risk distribution (click a level to filter) + patient search -->
                <div class="d-flex flex-wrap align-items-center gap-3 mb-3">
                    <button type="button" class="dmrs-risk-toggle @(levelFilter == "High" ? "is-active" : "")"
                            @onclick='() => ToggleLevelFilter(model.Key, "High")'
                            title="@Loc["ai.filterHigh"]">
                        <span class="dmrs-pill dmrs-pill--danger">@Loc["ai.level.high"]</span>
                        <strong>@model.HighCount</strong>
                    </button>
                    <button type="button" class="dmrs-risk-toggle @(levelFilter == "Medium" ? "is-active" : "")"
                            @onclick='() => ToggleLevelFilter(model.Key, "Medium")'
                            title="@Loc["ai.filterMedium"]">
                        <span class="dmrs-pill dmrs-pill--warning">@Loc["ai.level.medium"]</span>
                        <strong>@model.MediumCount</strong>
                    </button>
                    <button type="button" class="dmrs-risk-toggle @(levelFilter == "Low" ? "is-active" : "")"
                            @onclick='() => ToggleLevelFilter(model.Key, "Low")'
                            title="@Loc["ai.filterLow"]">
                        <span class="dmrs-pill dmrs-pill--neutral">@Loc["ai.level.low"]</span>
                        <strong>@model.LowCount</strong>
                    </button>
                    @if (levelFilter != "All")
                    {
                        <button type="button" class="btn btn-sm btn-link text-decoration-none p-0"
                                @onclick='() => SetLevelFilter(model.Key, "All")'>
                            @Loc["common.clear"]
                        </button>
                    }
                    <div class="ms-auto" style="min-width:220px; max-width:320px;">
                        <input type="search" class="form-control form-control-sm"
                               placeholder="@Loc["ai.searchPatientPlaceholder"]"
                               value="@search"
                               @oninput="e => SetSearch(model.Key, e.Value?.ToString())" />
                    </div>
                </div>

                <div class="progress mb-2" style="height:10px;">
                    <div class="progress-bar bg-danger"
                         style="@StackWidth(model.HighCount, model.Total)"></div>
                    <div class="progress-bar bg-warning"
                         style="@StackWidth(model.MediumCount, model.Total)"></div>
                    <div class="progress-bar bg-success"
                         style="@StackWidth(model.LowCount, model.Total)"></div>
                </div>

                <div class="d-flex flex-wrap align-items-center gap-3 mb-4 small text-muted">
                    <span>
                        @if (isFiltering)
                        {
                            <span>@Loc["ai.matchCount", rows.Count, model.Total]</span>
                        }
                        else
                        {
                            <span>@Loc["ai.topByRisk", rows.Count, model.Total]</span>
                        }
                    </span>
                    @if (model.ImputedCount > 0)
                    {
                        <span class="ms-auto">
                            @Loc["ai.imputedNote", model.ImputedCount, model.Total]
                        </span>
                    }
                </div>

                <!-- Feature inputs -->
                <div class="mb-3">
                    <span class="small text-muted me-2">@Loc["ai.modelInputs"]</span>
                    @foreach (var feature in model.Features)
                    {
                        <span class="dmrs-pill dmrs-pill--neutral me-1 mb-1">@feature</span>
                    }
                </div>

                <!-- Top-risk watchlist -->
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>@Loc["common.field.patient"]</th>
                                <th>@Loc["ai.col.riskLevel"]</th>
                                <th style="min-width:160px;">@Loc["ai.col.score"]</th>
                                <th>@Loc["common.details"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (rows.Count == 0)
                            {
                                <tr>
                                    <td colspan="4" class="text-center text-muted small py-3">
                                        @Loc["ai.noMatch"]
                                    </td>
                                </tr>
                            }
                            @foreach (var row in rows)
                            {
                                <tr>
                                    <td>
                                        <a href="@row.Href" class="fw-semibold text-decoration-none">@row.DisplayName</a>
                                        @if (!row.FeaturesComplete)
                                        {
                                            <span class="small text-warning ms-1" title="@Loc["ai.imputedTooltip"]">≈</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="dmrs-pill @RiskLevelClass(row.RiskLevel)">@row.RiskLevel</span>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="progress flex-grow-1" style="height:6px; min-width:60px">
                                                <div class="progress-bar @RiskBarClass(row.RiskLevel)"
                                                     style="@($"width:{(row.Score * 100).ToString("0")}%")"></div>
                                            </div>
                                            <small class="text-muted">@((row.Score * 100).ToString("0"))%</small>
                                        </div>
                                    </td>
                                    <td><small class="text-muted">@row.Detail</small></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    }

    <!-- How scoring works -->
    <div class="dmrs-panel mb-4">
        <div class="dmrs-panel__header">
            <div>
                <div class="dmrs-panel__title">@Loc["ai.howTitle"]</div>
                <div class="dmrs-panel__subtitle">@Loc["ai.howSubtitle"]</div>
            </div>
        </div>
        <div class="dmrs-stack">
            <div class="dmrs-note-card">
                <div class="dmrs-note-card__title">@Loc["ai.how.offlineTitle"]</div>
                <p>@Loc["ai.how.offlineBody"]</p>
            </div>
            <div class="dmrs-note-card">
                <div class="dmrs-note-card__title">@Loc["ai.how.featuresTitle"]</div>
                <p>@Loc["ai.how.featuresBody"]</p>
            </div>
            <div class="dmrs-note-card">
                <div class="dmrs-note-card__title">@Loc["ai.how.tiersTitle"]</div>
                <ul class="mb-0 small">
                    <li><strong>@Loc["ai.level.high"]</strong> @Loc["ai.how.tierHigh"]</li>
                    <li><strong>@Loc["ai.level.medium"]</strong> @Loc["ai.how.tierMedium"]</li>
                    <li><strong>@Loc["ai.level.low"]</strong> @Loc["ai.how.tierLow"]</li>
                </ul>
            </div>
            <div class="dmrs-note-card">
                <div class="dmrs-note-card__title">@Loc["ai.how.cdsTitle"]</div>
                <p>@Loc["ai.how.cdsBody"]</p>
            </div>
        </div>
    </div>

    <!-- Population Health -->
    <div class="dmrs-panel">
        <div class="dmrs-panel__header">
            <div>
                <div class="dmrs-panel__title">@Loc["ai.popTitle"]</div>
                <div class="dmrs-panel__subtitle">@Loc["ai.popSubtitle"]</div>
            </div>
        </div>

        @if (snapshot.ConditionPrevalence.Count == 0)
        {
            <div class="dmrs-empty-state">@Loc["ai.popEmpty"]</div>
        }
        else
        {
            <div class="px-1 py-2">
                @foreach (var item in snapshot.ConditionPrevalence)
                {
                    var barPct = maxConditionCount > 0
                        ? (int)((item.Count / (double)maxConditionCount) * 100)
                        : 0;
                    <div class="d-flex align-items-center gap-3 mb-2">
                        <div style="width:200px; font-size:0.82rem; text-align:right; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; flex-shrink:0;"
                             title="@item.Name">
                            @item.Name
                        </div>
                        <div class="flex-grow-1" style="background:#f3f4f6; border-radius:4px; height:22px; overflow:hidden;">
                            <div style="width:@(barPct)%; background: linear-gradient(90deg,#6366f1,#8b5cf6); height:100%; border-radius:4px;
                                        transition:width .4s ease; display:flex; align-items:center; padding-left:8px;">
                                @if (barPct > 15)
                                {
                                    <span style="font-size:0.75rem; color:#fff; font-weight:600;">@item.Count</span>
                                }
                            </div>
                        </div>
                        @if (barPct <= 15)
                        {
                            <span style="font-size:0.78rem; color:#6b7280; width:24px;">@item.Count</span>
                        }
                    </div>
                }
            </div>
        }
    </div>

    <!-- External AI Models -->
    <div class="dmrs-panel mt-4">
        <div class="dmrs-panel__header">
            <div>
                <div class="dmrs-panel__title">@Loc["ai.ext.title"]</div>
                <div class="dmrs-panel__subtitle">@Loc["ai.ext.subtitle"]</div>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(selectedPatientId))
        {
            <div class="d-flex align-items-center flex-wrap gap-2 mb-3">
                <span class="small text-muted">@Loc["ai.ext.patientLabel"]</span>
                <span class="dmrs-pill dmrs-pill--neutral">@selectedPatientName (@selectedPatientId)</span>
                <button class="btn btn-sm btn-outline-secondary" @onclick="ClearPatient">@Loc["ai.ext.change"]</button>
            </div>

            <DMRS.Client.Features.ExternalAi.Components.ExternalAiRunPanel PatientId="@selectedPatientId" @key="selectedPatientId" />
        }
        else
        {
            <div class="row g-2 align-items-end mb-2" style="max-width:640px;">
                <div class="col-md-4">
                    <label class="form-label small mb-1">@Loc["ai.ext.searchBy"]</label>
                    <select class="form-select" @bind="patientSearchField">
                        <option value="family">@Loc["ai.ext.searchByFamily"]</option>
                        <option value="given">@Loc["ai.ext.searchByGiven"]</option>
                        <option value="identifier">@Loc["ai.ext.searchByIdentifier"]</option>
                    </select>
                </div>
                <div class="col-md-8">
                    <label class="form-label small mb-1">@Loc["ai.ext.findPatient"]</label>
                    <input class="form-control" placeholder="@Loc["ai.ext.findPlaceholder"]" autocomplete="off"
                           value="@patientSearchTerm" @oninput="OnPatientSearchInput" />
                </div>
            </div>

            @if (isSearchingPatients)
            {
                <div class="small text-muted">@Loc["common.searching"]</div>
            }
            else if (patientMatches.Count > 0)
            {
                <div class="list-group" style="max-width:640px; max-height:280px; overflow:auto;">
                    @foreach (var match in patientMatches)
                    {
                        <button type="button" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
                                @onclick="() => SelectPatient(match)">
                            <span class="fw-semibold">@match.DisplayName</span>
                            <span class="small text-muted">@match.Gender · @match.BirthDate · @match.Id</span>
                        </button>
                    }
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(patientSearchTerm.Trim()))
            {
                <div class="small text-muted">@Loc["ai.ext.noMatch"]</div>
            }
        }
    </div>
}

@code {
    private bool isLoading = true;
    private string? errorMessage;
    private AiInsightsSnapshot snapshot = new();
    private int maxConditionCount = 1;
    private string selectedPatientId = string.Empty;
    private string selectedPatientName = string.Empty;

    // External AI patient picker — a debounced type-ahead reusing PatientService.SearchAsync,
    // mirroring the Patients index search rather than a select-all combo box.
    private string patientSearchField = "family";
    private string patientSearchTerm = string.Empty;
    private List<PatientSummaryViewModel> patientMatches = [];
    private bool isSearchingPatients;
    private CancellationTokenSource? patientSearchCts;

    private const int FilteredResultCap = 50;
    private readonly Dictionary<string, string> searchByModel = new();
    private readonly Dictionary<string, string> levelFilterByModel = new();

    private string GetSearch(string key) => searchByModel.GetValueOrDefault(key, string.Empty);

    private string GetLevelFilter(string key) => levelFilterByModel.GetValueOrDefault(key, "All");

    private void SetSearch(string key, string? value) => searchByModel[key] = value ?? string.Empty;

    private void SetLevelFilter(string key, string level) => levelFilterByModel[key] = level;

    // Clicking the active level again clears the filter back to "All".
    private void ToggleLevelFilter(string key, string level)
        => levelFilterByModel[key] = GetLevelFilter(key) == level ? "All" : level;

    private static List<AiPatientRiskRow> FilterRows(AiModelCohort model, string search, string levelFilter)
    {
        // No active search/filter: keep the default top-risk watchlist.
        if (string.IsNullOrWhiteSpace(search) && levelFilter == "All")
        {
            return model.Watchlist;
        }

        IEnumerable<AiPatientRiskRow> query = model.AllRows;

        if (levelFilter != "All")
        {
            query = query.Where(r => r.RiskLevel == levelFilter);
        }

        if (!string.IsNullOrWhiteSpace(search))
        {
            var term = search.Trim();
            query = query.Where(r => r.DisplayName.Contains(term, StringComparison.OrdinalIgnoreCase));
        }

        return query.Take(FilteredResultCap).ToList();
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            snapshot = await AiInsightsService.GetSnapshotAsync();
            maxConditionCount = snapshot.ConditionPrevalence.Count > 0
                ? snapshot.ConditionPrevalence.Max(x => x.Count)
                : 1;
        }
        catch (Exception ex)
        {
            errorMessage = Loc["ai.loadFailed", ex.Message];
        }
        finally
        {
            isLoading = false;
        }
    }

    private static string StackWidth(int count, int total)
        => $"width:{(total > 0 ? (count / (double)total) * 100 : 0).ToString("0.##")}%";

    private static string RiskLevelClass(string riskLevel) => riskLevel switch
    {
        "High"   => "dmrs-pill--danger",
        "Medium" => "dmrs-pill--warning",
        _        => "dmrs-pill--neutral"
    };

    private static string RiskBarClass(string riskLevel) => riskLevel switch
    {
        "High"   => "bg-danger",
        "Medium" => "bg-warning",
        _        => "bg-success"
    };

    private async Task OnPatientSearchInput(ChangeEventArgs e)
    {
        patientSearchTerm = e.Value?.ToString() ?? string.Empty;

        // Cancel any in-flight search, then debounce so we issue at most one request per ~250ms of typing.
        patientSearchCts?.Cancel();

        var term = patientSearchTerm.Trim();
        if (term.Length < 2)
        {
            patientMatches = [];
            isSearchingPatients = false;
            return;
        }

        var cts = new CancellationTokenSource();
        patientSearchCts = cts;
        isSearchingPatients = true;
        try
        {
            await Task.Delay(250, cts.Token);
            var results = await PatientService.SearchAsync(patientSearchField, term);
            if (!cts.IsCancellationRequested)
            {
                patientMatches = results.Take(20).ToList();
                isSearchingPatients = false;
                StateHasChanged();
            }
        }
        catch (OperationCanceledException)
        {
            // Superseded by a newer keystroke — ignore.
        }
        catch
        {
            // Search is best-effort; a failure shouldn't break the page.
            patientMatches = [];
            isSearchingPatients = false;
        }
    }

    private void SelectPatient(PatientSummaryViewModel patient)
    {
        selectedPatientId = patient.Id;
        selectedPatientName = patient.DisplayName;
        patientMatches = [];
        patientSearchTerm = string.Empty;
        patientSearchCts?.Cancel();
    }

    private void ClearPatient()
    {
        selectedPatientId = string.Empty;
        selectedPatientName = string.Empty;
        patientMatches = [];
        patientSearchTerm = string.Empty;
    }
}
