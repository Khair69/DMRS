@page "/ai-insights"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN,ROLE_PRACTITIONER")]
@using DMRS.Client.Features.Dashboard.Models
@inject DMRS.Client.Features.Dashboard.Services.DashboardFeatureService DashboardService
@inject DMRS.Client.Services.FhirApiService FhirApi

<PageTitle>AI Insights</PageTitle>

<div class="workspace-hero workspace-hero--ai">
    <div>
        <span class="workspace-eyebrow">Predictive Layer</span>
        <h1>AI Insights</h1>
        <p>30-day readmission risk scored by a model trained on real hospital data, using each patient's FHIR record — age, conditions, medications, recent visits, and procedures.</p>
    </div>
</div>

@if (isLoading)
{
    <div class="dmrs-loading-shell">
        <div class="spinner-border text-primary" role="status"></div>
    </div>
}
else if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
else
{
    <!-- Risk distribution summary row -->
    <div class="dmrs-metrics-grid dmrs-metrics-grid--compact mb-4">
        <div class="dmrs-metric-card metric-rose">
            <div class="dmrs-metric-card__label">High Risk</div>
            <div class="dmrs-metric-card__value">@snapshot.HighRiskPatients.Count(p => p.RiskLevel == "High")</div>
            <div class="dmrs-metric-card__helper">Readmission risk ≥ 65%</div>
        </div>
        <div class="dmrs-metric-card metric-gold">
            <div class="dmrs-metric-card__label">Medium Risk</div>
            <div class="dmrs-metric-card__value">@snapshot.HighRiskPatients.Count(p => p.RiskLevel == "Medium")</div>
            <div class="dmrs-metric-card__helper">Readmission risk 35–65%</div>
        </div>
        <div class="dmrs-metric-card metric-emerald">
            <div class="dmrs-metric-card__label">Low Risk</div>
            <div class="dmrs-metric-card__value">@snapshot.HighRiskPatients.Count(p => p.RiskLevel == "Low")</div>
            <div class="dmrs-metric-card__helper">Readmission risk &lt; 35%</div>
        </div>
        <div class="dmrs-metric-card metric-ocean">
            <div class="dmrs-metric-card__label">With Chronic Conditions</div>
            <div class="dmrs-metric-card__value">@snapshot.HighRiskPatients.Count(p => p.HasChronicConditions)</div>
            <div class="dmrs-metric-card__helper">Detected chronic illness</div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-12 col-xl-8">
            <div class="dmrs-panel">
                <div class="dmrs-panel__header">
                    <div>
                        <div class="dmrs-panel__title">Patient Risk Watchlist</div>
                        <div class="dmrs-panel__subtitle">Ranked by the model's predicted 30-day readmission probability.</div>
                    </div>
                </div>

                @if (snapshot.HighRiskPatients.Count == 0)
                {
                    <div class="dmrs-empty-state">No assessable patients yet. Import sample patients with birth date and gender to activate the risk panel.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Patient</th>
                                    <th>Risk Level</th>
                                    <th>Score</th>
                                    <th>Conditions</th>
                                    <th>Active Meds</th>
                                    <th>Recent Visits</th>
                                    <th>Top Factors</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var p in snapshot.HighRiskPatients)
                                {
                                    <tr>
                                        <td>
                                            <a href="@p.Href" class="fw-semibold text-decoration-none">@p.DisplayName</a>
                                        </td>
                                        <td>
                                            <span class="dmrs-pill @RiskLevelClass(p.RiskLevel)">@p.RiskLevel</span>
                                        </td>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="progress flex-grow-1" style="height:6px; min-width:60px">
                                                    <div class="progress-bar @RiskBarClass(p.RiskLevel)"
                                                         style="@($"width:{(p.CompositeScore * 100).ToString("0")}%")"></div>
                                                </div>
                                                <small class="text-muted">@((p.CompositeScore * 100).ToString("0"))%</small>
                                            </div>
                                        </td>
                                        <td>@p.ConditionCount</td>
                                        <td>@p.MedicationCount</td>
                                        <td>@p.RecentEncounterCount</td>
                                        <td>
                                            <small class="text-muted">@(p.TopRiskFactors?.FirstOrDefault() ?? "—")</small>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <div class="col-12 col-xl-4">
            <div class="dmrs-panel">
                <div class="dmrs-panel__header">
                    <div>
                        <div class="dmrs-panel__title">How Scoring Works</div>
                        <div class="dmrs-panel__subtitle">Model-driven readmission predictor</div>
                    </div>
                </div>
                <div class="dmrs-stack">
                    <div class="dmrs-note-card">
                        <div class="dmrs-note-card__title">The Model</div>
                        <p>An ONNX classifier trained on the UCI "130-US hospitals" dataset to predict the chance a patient is readmitted within 30 days. The model produces the score directly — no hand-tuned rules.</p>
                    </div>
                    <div class="dmrs-note-card">
                        <div class="dmrs-note-card__title">Model Inputs</div>
                        <p class="mb-1">Pulled from each patient's FHIR record:</p>
                        <ul class="mb-0 small">
                            <li>Age and gender</li>
                            <li>Number of conditions</li>
                            <li>Number of active medications</li>
                            <li>Number of recent visits</li>
                            <li>Number of procedures</li>
                        </ul>
                    </div>
                    <div class="dmrs-note-card">
                        <div class="dmrs-note-card__title">Risk Tiers</div>
                        <ul class="mb-0 small">
                            <li><strong>High</strong> — composite ≥ 65%</li>
                            <li><strong>Medium</strong> — 35%–65%</li>
                            <li><strong>Low</strong> — below 35%</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Population Health -->
    <div class="row g-4 mt-1">
        <div class="col-12">
            <div class="dmrs-panel">
                <div class="dmrs-panel__header">
                    <div>
                        <div class="dmrs-panel__title">Population Health — Condition Prevalence</div>
                        <div class="dmrs-panel__subtitle">Top conditions recorded across all patients in this workspace.</div>
                    </div>
                </div>

                @if (conditionPrevalence.Count == 0)
                {
                    <div class="dmrs-empty-state">No condition data available yet. Add conditions to patient records to see prevalence.</div>
                }
                else
                {
                    <div class="px-1 py-2">
                        @foreach (var item in conditionPrevalence)
                        {
                            var barPct = maxConditionCount > 0
                                ? (int)((item.Count / (double)maxConditionCount) * 100)
                                : 0;
                            <div class="d-flex align-items-center gap-3 mb-2">
                                <div style="width:200px; font-size:0.82rem; text-align:right; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; flex-shrink:0;"
                                     title="@item.Name">
                                    @item.Name
                                </div>
                                <div class="flex-grow-1" style="background:#f3f4f6; border-radius:4px; height:22px; overflow:hidden;">
                                    <div style="width:@(barPct)%; background: linear-gradient(90deg,#6366f1,#8b5cf6); height:100%; border-radius:4px;
                                                transition:width .4s ease; display:flex; align-items:center; padding-left:8px;">
                                        @if (barPct > 15)
                                        {
                                            <span style="font-size:0.75rem; color:#fff; font-weight:600;">@item.Count</span>
                                        }
                                    </div>
                                </div>
                                @if (barPct <= 15)
                                {
                                    <span style="font-size:0.78rem; color:#6b7280; width:24px;">@item.Count</span>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    private sealed class ConditionPrevalenceItem
    {
        public string Name { get; set; } = string.Empty;
        public int Count { get; set; }
    }

    private bool isLoading = true;
    private string? errorMessage;
    private DashboardSnapshotModel snapshot = new();
    private List<ConditionPrevalenceItem> conditionPrevalence = [];
    private int maxConditionCount = 1;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var snapshotTask    = DashboardService.GetSnapshotAsync();
            var prevalenceTask  = FhirApi.GetApiJsonAsync<List<ConditionPrevalenceItem>>(
                "analytics/condition-prevalence");

            await Task.WhenAll(snapshotTask, prevalenceTask);

            snapshot             = snapshotTask.Result;
            conditionPrevalence  = prevalenceTask.Result ?? [];
            maxConditionCount    = conditionPrevalence.Count > 0
                ? conditionPrevalence.Max(x => x.Count)
                : 1;
        }
        catch (Exception ex)
        {
            errorMessage = $"Unable to load AI insights: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private static string RiskLevelClass(string riskLevel) => riskLevel switch
    {
        "High"   => "dmrs-pill--danger",
        "Medium" => "dmrs-pill--warning",
        _        => "dmrs-pill--neutral"
    };

    private static string RiskBarClass(string riskLevel) => riskLevel switch
    {
        "High"   => "bg-danger",
        "Medium" => "bg-warning",
        _        => "bg-success"
    };
}
