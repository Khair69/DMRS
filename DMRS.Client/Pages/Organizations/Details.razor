@page "/organizations/{Id}"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN")]
@inherits DMRS.Client.Components.LocalizedComponentBase
@inject DMRS.Client.Features.Organizations.Services.OrganizationFeatureService OrganizationService

<PageTitle>@Loc["organizations.details.title"]</PageTitle>

<h1>@Loc["organizations.details.title"]</h1>

@if (isBusy)
{
    <div class="spinner-border" role="status"></div>
}
else if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
else
{
    <OrganizationDetailsView Organization="organization" />
}

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;

    private Hl7.Fhir.Model.Organization? organization;
    private bool isBusy;
    private string? errorMessage;

    protected override async Task OnParametersSetAsync()
    {
        errorMessage = null;
        isBusy = true;

        try
        {
            organization = await OrganizationService.GetAsync(Id);
            if (organization is null)
            {
                errorMessage = Loc["organizations.notFound", Id];
            }
        }
        catch (Exception ex)
        {
            errorMessage = Loc["organizations.loadError", ex.Message];
        }
        finally
        {
            isBusy = false;
        }
    }
}
