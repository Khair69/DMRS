@page "/organizations/new"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN")]
@inherits DMRS.Client.Components.LocalizedComponentBase
@inject DMRS.Client.Features.Organizations.Services.OrganizationFeatureService OrganizationService
@inject NavigationManager NavigationManager

<PageTitle>@Loc["organizations.create.title"]</PageTitle>

<h1>@Loc["organizations.create.title"]</h1>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<OrganizationForm Model="model" IsBusy="@isSaving" SubmitText="@Loc["organizations.create.submit"]" OnSave="Save" />

@code {
    private readonly OrganizationEditModel model = new();
    private bool isSaving;
    private string? errorMessage;

    private async Task Save()
    {
        isSaving = true;
        errorMessage = null;
        try
        {
            var createdOrganization = await OrganizationService.CreateAsync(model);
            if (createdOrganization?.Id is null)
            {
                errorMessage = Loc["organizations.noIdReturned"];
                return;
            }

            NavigationManager.NavigateTo($"/organizations/{createdOrganization.Id}");
        }
        catch (Exception ex)
        {
            errorMessage = Loc["organizations.createError", ex.Message];
        }
        finally
        {
            isSaving = false;
        }
    }
}
