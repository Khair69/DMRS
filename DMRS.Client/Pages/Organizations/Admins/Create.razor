@page "/organizations/{OrganizationId}/admins/new"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN")]
@inherits DMRS.Client.Components.LocalizedComponentBase
@inject DMRS.Client.Features.Organizations.Services.OrganizationFeatureService OrganizationService
@inject DMRS.Client.Features.Organizations.Services.OrganizationAdminFeatureService OrganizationAdminService
@inject NavigationManager Navigation

<PageTitle>@Loc["organizations.admin.create.title"]</PageTitle>

<h1>@Loc["organizations.admin.create.title"]</h1>

@if (isLoadingOrganization)
{
    <div class="spinner-border" role="status"></div>
}
else if (organization is null)
{
    <div class="alert alert-danger">@organizationError</div>
}
else
{
    <div class="alert alert-info">
        @Loc["organizations.admin.creatingFor"] <strong>@organization.Name</strong> (@organization.Id)
    </div>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(successMessage))
    {
        <div class="alert alert-success">@successMessage</div>
    }

    @if (inviteResult is not null)
    {
        <div class="card mt-3">
            <div class="card-header">@Loc["common.invite.generatedTitle"]</div>
            <div class="card-body">
                <p class="mb-2"><strong>@Loc["common.invite.code"]</strong>: <code>@inviteResult.InviteCode</code></p>
                <p class="mb-2"><strong>@Loc["common.invite.selfRegistration"]</strong>: <a href="@inviteResult.RegistrationLink" target="_blank">@inviteResult.RegistrationLink</a></p>
                <p class="mb-0"><strong>@Loc["common.invite.manualFallback"]</strong>: <a href="@inviteResult.ClaimLink" target="_blank">@inviteResult.ClaimLink</a></p>
            </div>
        </div>
    }

    <OrganizationAdminForm Model="model" IsBusy="@isSaving" SubmitText="@Loc["organizations.admin.create.submit"]" OnSave="Save" />
}

@code {
    [Parameter]
    public string OrganizationId { get; set; } = string.Empty;

    private readonly OrganizationAdminEditModel model = new();
    private Hl7.Fhir.Model.Organization? organization;
    private bool isLoadingOrganization;
    private bool isSaving;
    private string? errorMessage;
    private string? successMessage;
    private string? organizationError;
    private DMRS.Client.Features.Organizations.Services.OrganizationAdminInviteResult? inviteResult;

    protected override async Task OnParametersSetAsync()
    {
        organizationError = null;
        errorMessage = null;
        successMessage = null;
        isLoadingOrganization = true;

        try
        {
            organization = await OrganizationService.GetAsync(OrganizationId);
            if (organization is null)
            {
                organizationError = Loc["organizations.notFound", OrganizationId];
            }
        }
        catch (Exception ex)
        {
            organizationError = Loc["organizations.loadError", ex.Message];
        }
        finally
        {
            isLoadingOrganization = false;
        }
    }

    private async Task Save()
    {
        if (organization is null)
        {
            return;
        }

        isSaving = true;
        errorMessage = null;
        successMessage = null;
        inviteResult = null;

        try
        {
            inviteResult = await OrganizationAdminService.CreateAdminInviteAsync(OrganizationId, model, Navigation.BaseUri);
            successMessage = Loc["organizations.admin.success", inviteResult.PractitionerId, inviteResult.PractitionerRoleId];
        }
        catch (Exception ex)
        {
            errorMessage = Loc["organizations.admin.failed", ex.Message];
        }
        finally
        {
            isSaving = false;
        }
    }
}
