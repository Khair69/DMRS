@page "/organizations"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN")]
@inject DMRS.Client.Features.Organizations.Services.OrganizationFeatureService OrganizationService

<PageTitle>Organizations</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Organizations</h1>
    <NavLink class="btn btn-primary" href="/organizations/new">New Organization</NavLink>
</div>

<OrganizationSearchForm SearchParam="@searchParam" SearchValue="@searchValue" IsBusy="@isBusy" OnSearch="RunSearch" />

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<OrganizationsTable Organizations="@organizations" />

@code {
    private string searchParam = "name";
    private string searchValue = string.Empty;
    private bool isBusy;
    private string? errorMessage;
    private IReadOnlyList<OrganizationSummaryViewModel> organizations = [];

    protected override async Task OnInitializedAsync()
    {
        await RunSearch((searchParam, ""));
    }

    private async Task RunSearch((string SearchParam, string SearchValue) criteria)
    {
        searchParam = criteria.SearchParam;
        searchValue = criteria.SearchValue;
        errorMessage = null;
        isBusy = true;

        if (string.IsNullOrWhiteSpace(searchValue))
        {
            isBusy = false;
            organizations = [];
            return;
        }

        try
        {
            organizations = await OrganizationService.SearchAsync(searchParam, searchValue);
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load organizations: {ex.Message}";
            organizations = [];
        }
        finally
        {
            isBusy = false;
        }
    }
}
