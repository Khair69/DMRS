@page "/organizations/{Id}/edit"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN")]
@inherits DMRS.Client.Components.LocalizedComponentBase
@inject DMRS.Client.Features.Organizations.Services.OrganizationFeatureService OrganizationService
@inject NavigationManager Navigation

<PageTitle>@Loc["organizations.edit.title"]</PageTitle>

<h1>@Loc["organizations.edit.title"]</h1>

@if (isLoading)
{
    <div class="spinner-border" role="status"></div>
}
else
{
    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    <OrganizationForm Model="model" IsBusy="@isSaving" SubmitText="@Loc["organizations.edit.submit"]" OnSave="Save" />
}

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;

    private OrganizationEditModel model = new();
    private bool isLoading;
    private bool isSaving;
    private string? errorMessage;

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var organization = await OrganizationService.GetAsync(Id);
            if (organization is null)
            {
                errorMessage = Loc["organizations.notFound", Id];
                return;
            }

            model = OrganizationEditModel.FromOrganization(organization);
        }
        catch (Exception ex)
        {
            errorMessage = Loc["organizations.loadFailed", ex.Message];
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task Save()
    {
        errorMessage = null;
        isSaving = true;

        try
        {
            await OrganizationService.UpdateAsync(Id, model);
            Navigation.NavigateTo($"/organizations/{Id}");
        }
        catch (Exception ex)
        {
            errorMessage = Loc["organizations.updateFailed", ex.Message];
        }
        finally
        {
            isSaving = false;
        }
    }
}
