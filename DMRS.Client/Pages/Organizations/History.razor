@page "/organizations/{Id}/history"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN")]
@inherits DMRS.Client.Components.LocalizedComponentBase
@inject DMRS.Client.Features.Organizations.Services.OrganizationFeatureService OrganizationService

<PageTitle>@Loc["organizations.history.title"]</PageTitle>

<h1>@Loc["organizations.history.title"]</h1>

@if (isBusy)
{
    <div class="spinner-border" role="status"></div>
}
else
{
    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    <OrganizationHistoryTable History="history" />
}

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;

    private IReadOnlyList<Hl7.Fhir.Model.Organization> history = [];
    private bool isBusy;
    private string? errorMessage;

    protected override async Task OnParametersSetAsync()
    {
        isBusy = true;
        errorMessage = null;

        try
        {
            history = await OrganizationService.GetHistoryAsync(Id);
        }
        catch (Exception ex)
        {
            errorMessage = Loc["common.historyLoadFailed", ex.Message];
            history = [];
        }
        finally
        {
            isBusy = false;
        }
    }
}
