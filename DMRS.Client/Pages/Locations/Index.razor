@page "/locations"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN,ROLE_PRACTITIONER")]
@using DMRS.Client.Features.Locations.Models
@inject DMRS.Client.Features.Locations.Services.LocationFeatureService LocationService

<PageTitle>Locations</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Locations</h1>
    <NavLink class="btn btn-primary" href="/locations/new">New Location</NavLink>
</div>

<div class="card mb-3">
    <div class="card-body">
        <EditForm Model="this" OnSubmit="HandleSubmit">
            <div class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label">Search Field</label>
                    <InputSelect @bind-Value="searchParam" class="form-select">
                        <option value="name">Name</option>
                        <option value="organization">Organization</option>
                    </InputSelect>
                </div>
                <div class="col-md-7">
                    <label class="form-label">Search Value</label>
                    <InputText @bind-Value="searchValue" class="form-control" placeholder="e.g. Main Clinic" />
                </div>
                <div class="col-md-2 d-grid">
                    <button class="btn btn-primary" disabled="@isBusy" type="submit">Search</button>
                </div>
            </div>
        </EditForm>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (locations.Count == 0)
{
    <div class="alert alert-secondary">No locations found.</div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Status</th>
                <th>Org</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var location in locations)
            {
                <tr>
                    <td>
                        <NavLink href="@($"/locations/{location.Id}")">@location.Id</NavLink>
                    </td>
                    <td>@location.Name</td>
                    <td>@location.Status</td>
                    <td>@location.ManagingOrganizationId</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private string searchParam = "name";
    private string searchValue = string.Empty;
    private bool isBusy;
    private string? errorMessage;
    private IReadOnlyList<LocationSummaryViewModel> locations = [];

    private async Task HandleSubmit()
    {
        errorMessage = null;
        isBusy = true;

        if (string.IsNullOrWhiteSpace(searchValue))
        {
            locations = [];
            isBusy = false;
            return;
        }

        try
        {
            locations = await LocationService.SearchAsync(searchParam, searchValue);
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load locations: {ex.Message}";
            locations = [];
        }
        finally
        {
            isBusy = false;
        }
    }
}
