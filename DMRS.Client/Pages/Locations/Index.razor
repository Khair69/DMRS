@page "/locations"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN,ROLE_PRACTITIONER")]
@using DMRS.Client.Features.Locations.Models
@inject DMRS.Client.Features.Locations.Services.LocationFeatureService LocationService

<PageTitle>Locations</PageTitle>

<ResourceIndexPage TSummary="LocationSummaryViewModel"
                   Title="Locations"
                   NewLink="/locations/new"
                   NewLabel="New Location"
                   EntityName="locations"
                   EmptyText="No locations found."
                   SearchFields="_searchFields"
                   LoadDefault="cap => LocationService.ListAsync(cap)"
                   Search="(p, v) => LocationService.SearchAsync(p, v)">
    <HeaderTemplate>
        <th>Id</th>
        <th>Name</th>
        <th>Status</th>
        <th>Org</th>
    </HeaderTemplate>
    <RowTemplate Context="location">
        <td><NavLink href="@($"/locations/{location.Id}")">@location.Id</NavLink></td>
        <td>@location.Name</td>
        <td>@location.Status</td>
        <td>@location.ManagingOrganizationId</td>
    </RowTemplate>
</ResourceIndexPage>

@code {
    private static readonly IReadOnlyList<SearchField> _searchFields =
    [
        new("name", "Name", "e.g. Main Clinic"),
        new("organization", "Organization", "e.g. 7 (organization id)"),
    ];
}
