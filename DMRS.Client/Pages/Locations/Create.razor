@page "/locations/new"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN,ROLE_PRACTITIONER")]
@inherits DMRS.Client.Components.LocalizedComponentBase
@inject DMRS.Client.Features.Locations.Services.LocationFeatureService LocationService
@inject NavigationManager NavigationManager

<PageTitle>@Loc["locations.create.title"]</PageTitle>

<h1>@Loc["locations.create.title"]</h1>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<LocationForm Model="model" IsBusy="@isSaving" SubmitText="@Loc["locations.create.submit"]" OnSave="Save" />

@code {
    private readonly DMRS.Client.Features.Locations.Models.LocationEditModel model = new();
    private bool isSaving;
    private string? errorMessage;

    private async Task Save()
    {
        isSaving = true;
        errorMessage = null;
        try
        {
            var created = await LocationService.CreateAsync(model);
            if (created?.Id is null)
            {
                errorMessage = Loc["locations.noIdReturned"];
                return;
            }

            NavigationManager.NavigateTo($"/locations/{created.Id}");
        }
        catch (Exception ex)
        {
            errorMessage = Loc["locations.createError", ex.Message];
        }
        finally
        {
            isSaving = false;
        }
    }
}
