@page "/locations/new"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN,ROLE_PRACTITIONER")]
@inject DMRS.Client.Features.Locations.Services.LocationFeatureService LocationService
@inject NavigationManager NavigationManager

<PageTitle>Create Location</PageTitle>

<h1>Create Location</h1>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<LocationForm Model="model" IsBusy="@isSaving" SubmitText="Create Location" OnSave="Save" />

@code {
    private readonly DMRS.Client.Features.Locations.Models.LocationEditModel model = new();
    private bool isSaving;
    private string? errorMessage;

    private async Task Save()
    {
        isSaving = true;
        errorMessage = null;
        try
        {
            var created = await LocationService.CreateAsync(model);
            if (created?.Id is null)
            {
                errorMessage = "Location was created but no id was returned.";
                return;
            }

            NavigationManager.NavigateTo($"/locations/{created.Id}");
        }
        catch (Exception ex)
        {
            errorMessage = $"An error occurred while creating the location: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }
}
