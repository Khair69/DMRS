@page "/locations/{Id}"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN,ROLE_PRACTITIONER")]
@inherits DMRS.Client.Components.LocalizedComponentBase
@inject DMRS.Client.Features.Locations.Services.LocationFeatureService LocationService

<PageTitle>@Loc["locations.details.title"]</PageTitle>

<h1>@Loc["locations.details.title"]</h1>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<div class="mb-3">
    <NavLink class="btn btn-sm btn-outline-secondary me-1" href="@($"/locations/{Id}/edit")">@Loc["common.edit"]</NavLink>
    <NavLink class="btn btn-sm btn-outline-info" href="@($"/locations/{Id}/history")">@Loc["common.history"]</NavLink>
</div>

<FhirJsonView Resource="location" />

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;

    private Hl7.Fhir.Model.Location? location;
    private string? errorMessage;

    protected override async Task OnParametersSetAsync()
    {
        errorMessage = null;
        try
        {
            location = await LocationService.GetAsync(Id);
            if (location is null)
            {
                errorMessage = Loc["locations.notFound", Id];
            }
        }
        catch (Exception ex)
        {
            errorMessage = Loc["locations.loadFailed", ex.Message];
        }
    }
}
