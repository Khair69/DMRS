@page "/allergy-intolerances/new"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN,ROLE_PRACTITIONER")]
@inherits DMRS.Client.Components.LocalizedComponentBase
@inject DMRS.Client.Features.AllergyIntolerances.Services.AllergyIntoleranceFeatureService AllergyService
@inject NavigationManager NavigationManager

<PageTitle>@Loc["allergies.create.title"]</PageTitle>

<h1>@Loc["allergies.create.title"]</h1>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<AllergyIntoleranceForm Model="model" IsBusy="@isSaving" SubmitText="@Loc["allergies.create.submit"]" OnSave="Save" />

@code {
    private readonly DMRS.Client.Features.AllergyIntolerances.Models.AllergyIntoleranceEditModel model = new();
    private bool isSaving;
    private string? errorMessage;

    private async Task Save()
    {
        isSaving = true;
        errorMessage = null;
        try
        {
            var created = await AllergyService.CreateAsync(model);
            if (created?.Id is null)
            {
                errorMessage = Loc["allergies.noIdReturned"];
                return;
            }

            NavigationManager.NavigateTo($"/allergy-intolerances/{created.Id}");
        }
        catch (Exception ex)
        {
            errorMessage = Loc["allergies.createError", ex.Message];
        }
        finally
        {
            isSaving = false;
        }
    }
}
