@page "/allergy-intolerances"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN,ROLE_PRACTITIONER")]
@using DMRS.Client.Features.AllergyIntolerances.Models
@inject DMRS.Client.Features.AllergyIntolerances.Services.AllergyIntoleranceFeatureService AllergyService

<PageTitle>Allergy Intolerances</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Allergy Intolerances</h1>
    <NavLink class="btn btn-primary" href="/allergy-intolerances/new">New Allergy</NavLink>
</div>

<div class="card mb-3">
    <div class="card-body">
        <EditForm Model="this" OnSubmit="HandleSubmit">
            <div class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label">Search Field</label>
                    <InputSelect @bind-Value="searchParam" class="form-select">
                        <option value="patient">Patient</option>
                        <option value="code">Code</option>
                    </InputSelect>
                </div>
                <div class="col-md-7">
                    <label class="form-label">Search Value</label>
                    <InputText @bind-Value="searchValue" class="form-control" placeholder="e.g. Patient/123" />
                </div>
                <div class="col-md-2 d-grid">
                    <button class="btn btn-primary" disabled="@isBusy" type="submit">Search</button>
                </div>
            </div>
        </EditForm>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (allergies.Count == 0)
{
    <div class="alert alert-secondary">No allergies found.</div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Id</th>
                <th>Patient</th>
                <th>Code</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var allergy in allergies)
            {
                <tr>
                    <td>
                        <NavLink href="@($"/allergy-intolerances/{allergy.Id}")">@allergy.Id</NavLink>
                    </td>
                    <td>@allergy.PatientId</td>
                    <td>@allergy.CodeText</td>
                    <td>@allergy.ClinicalStatus</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private string searchParam = "patient";
    private string searchValue = string.Empty;
    private bool isBusy;
    private string? errorMessage;
    private IReadOnlyList<AllergyIntoleranceSummaryViewModel> allergies = [];

    private async Task HandleSubmit()
    {
        errorMessage = null;
        isBusy = true;

        if (string.IsNullOrWhiteSpace(searchValue))
        {
            allergies = [];
            isBusy = false;
            return;
        }

        try
        {
            allergies = await AllergyService.SearchAsync(searchParam, searchValue);
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load allergies: {ex.Message}";
            allergies = [];
        }
        finally
        {
            isBusy = false;
        }
    }
}
