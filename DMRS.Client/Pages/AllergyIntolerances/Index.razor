@page "/allergy-intolerances"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN,ROLE_PRACTITIONER")]
@using DMRS.Client.Features.AllergyIntolerances.Models
@inject DMRS.Client.Features.AllergyIntolerances.Services.AllergyIntoleranceFeatureService AllergyService

<PageTitle>Allergy Intolerances</PageTitle>

<ResourceIndexPage TSummary="AllergyIntoleranceSummaryViewModel"
                   Title="Allergy Intolerances"
                   NewLink="/allergy-intolerances/new"
                   NewLabel="New Allergy"
                   EntityName="allergies"
                   EmptyText="No allergies found."
                   SearchFields="_searchFields"
                   LoadDefault="cap => AllergyService.ListAsync(cap)"
                   Search="(p, v) => AllergyService.SearchAsync(p, v)">
    <HeaderTemplate>
        <th>Id</th>
        <th>Patient</th>
        <th>Code</th>
        <th>Status</th>
    </HeaderTemplate>
    <RowTemplate Context="allergy">
        <td><NavLink href="@($"/allergy-intolerances/{allergy.Id}")">@allergy.Id</NavLink></td>
        <td>@allergy.PatientId</td>
        <td>@allergy.CodeText</td>
        <td>@allergy.ClinicalStatus</td>
    </RowTemplate>
</ResourceIndexPage>

@code {
    private static readonly IReadOnlyList<SearchField> _searchFields =
    [
        new("patient", "Patient", "e.g. 123 (patient id)"),
        new("code", "Code", "e.g. 227493005"),
    ];
}
