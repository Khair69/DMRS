@page "/allergy-intolerances/{Id}"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN,ROLE_PRACTITIONER")]
@inherits DMRS.Client.Components.LocalizedComponentBase
@inject DMRS.Client.Features.AllergyIntolerances.Services.AllergyIntoleranceFeatureService AllergyService

<PageTitle>@Loc["allergies.details.title"]</PageTitle>

<h1>@Loc["allergies.details.title"]</h1>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<div class="mb-3">
    <NavLink class="btn btn-sm btn-outline-secondary me-1" href="@($"/allergy-intolerances/{Id}/edit")">@Loc["common.edit"]</NavLink>
    <NavLink class="btn btn-sm btn-outline-info" href="@($"/allergy-intolerances/{Id}/history")">@Loc["common.history"]</NavLink>
</div>

<FhirJsonView Resource="allergy" />

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;

    private Hl7.Fhir.Model.AllergyIntolerance? allergy;
    private string? errorMessage;

    protected override async Task OnParametersSetAsync()
    {
        errorMessage = null;
        try
        {
            allergy = await AllergyService.GetAsync(Id);
            if (allergy is null)
            {
                errorMessage = Loc["allergies.notFound", Id];
            }
        }
        catch (Exception ex)
        {
            errorMessage = Loc["allergies.loadFailed", ex.Message];
        }
    }
}
