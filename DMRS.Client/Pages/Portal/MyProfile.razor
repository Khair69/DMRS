@page "/my-profile"
@attribute [Authorize(Roles = "ROLE_PATIENT")]
@using Hl7.Fhir.Model
@using Microsoft.AspNetCore.Components.Forms
@using DMRS.Client.Features.Patients.Models
@using Task = System.Threading.Tasks.Task
@inherits DMRS.Client.Components.LocalizedComponentBase
@inject DMRS.Client.Features.Patients.Services.PatientPortalFeatureService PortalService

<PageTitle>@Loc["portal.profile.title"]</PageTitle>

<div class="workspace-hero workspace-hero--patient">
    <div>
        <span class="workspace-eyebrow">@Loc["portal.dashboard.eyebrow"]</span>
        <h1>@Loc["portal.profile.title"]</h1>
        <p>@Loc["portal.profile.subtitle"]</p>
    </div>
    <div class="workspace-hero__actions">
        <a class="btn btn-outline-light" href="/my-health">@Loc["nav.myHealth"]</a>
    </div>
</div>

@if (isLoading)
{
    <div class="dmrs-loading-shell">
        <div class="spinner-border text-primary" role="status"></div>
    </div>
}
else if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (model is null)
{
    <div class="dmrs-panel mt-4">
        <div class="dmrs-empty-state">
            @Loc["portal.health.noRecordPre"] <a href="/patients/claim">@Loc["portal.dashboard.claimHere"]</a>@Loc["portal.health.noRecordPost"]
        </div>
    </div>
}
else
{
    <div class="row g-4 mt-1">
        <div class="col-12 col-xl-8">
            <div class="dmrs-panel">
                <div class="dmrs-panel__header">
                    <div>
                        <div class="dmrs-panel__title">@Loc["portal.profile.personalDetails"]</div>
                        <div class="dmrs-panel__subtitle">@Loc["portal.profile.personalSubtitle"]</div>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(successMessage))
                {
                    <div class="alert alert-success">@successMessage</div>
                }
                @if (!string.IsNullOrWhiteSpace(saveError))
                {
                    <div class="alert alert-danger">@saveError</div>
                }

                <EditForm Model="model" OnValidSubmit="SaveAsync">
                    <DataAnnotationsValidator />
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">@Loc["common.field.givenName"]</label>
                            <InputText @bind-Value="model.GivenName" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">@Loc["common.field.familyName"]</label>
                            <InputText @bind-Value="model.FamilyName" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">@Loc["common.field.gender"]</label>
                            <InputSelect @bind-Value="model.Gender" class="form-select">
                                <option value="">@Loc["portal.profile.preferNotToSay"]</option>
                                <option value="male">@Loc["common.male"]</option>
                                <option value="female">@Loc["common.female"]</option>
                                <option value="other">@Loc["common.other"]</option>
                                <option value="unknown">@Loc["common.unknown"]</option>
                            </InputSelect>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">@Loc["common.field.birthDate"]</label>
                            <InputText type="date" @bind-Value="model.BirthDate" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">@Loc["portal.profile.maritalStatus"]</label>
                            <InputSelect @bind-Value="model.MaritalStatus" class="form-select">
                                <option value="">@Loc["portal.profile.marital.notSpecified"]</option>
                                <option value="S">@Loc["portal.profile.marital.single"]</option>
                                <option value="M">@Loc["portal.profile.marital.married"]</option>
                                <option value="D">@Loc["portal.profile.marital.divorced"]</option>
                                <option value="W">@Loc["portal.profile.marital.widowed"]</option>
                                <option value="U">@Loc["portal.profile.marital.unknown"]</option>
                            </InputSelect>
                        </div>

                        <div class="col-12"><hr class="my-1" /></div>

                        <div class="col-md-6">
                            <label class="form-label">@Loc["common.field.phone"]</label>
                            <InputText @bind-Value="model.Phone" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">@Loc["common.field.email"]</label>
                            <InputText @bind-Value="model.Email" class="form-control" />
                        </div>

                        <div class="col-12"><hr class="my-1" /></div>

                        <div class="col-12">
                            <label class="form-label">@Loc["common.field.address"]</label>
                            <InputTextArea @bind-Value="model.AddressLine" class="form-control" rows="2"
                                           placeholder="@Loc["portal.profile.addressPlaceholder"]" />
                        </div>
                        <div class="col-md-5">
                            <label class="form-label">@Loc["common.field.city"]</label>
                            <InputText @bind-Value="model.City" class="form-control" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">@Loc["portal.profile.stateRegion"]</label>
                            <InputText @bind-Value="model.State" class="form-control" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">@Loc["common.field.postalCode"]</label>
                            <InputText @bind-Value="model.PostalCode" class="form-control" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">@Loc["common.field.country"]</label>
                            <InputText @bind-Value="model.Country" class="form-control" />
                        </div>
                    </div>

                    <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="btn btn-primary" disabled="@isSaving">
                            @(isSaving ? Loc["portal.profile.saving"] : Loc["portal.profile.saveChanges"])
                        </button>
                        <button type="button" class="btn btn-outline-secondary" disabled="@isSaving" @onclick="ResetAsync">
                            @Loc["portal.profile.reset"]
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>

        <div class="col-12 col-xl-4">
            <div class="dmrs-panel">
                <div class="dmrs-panel__header">
                    <div>
                        <div class="dmrs-panel__title">@Loc["portal.profile.account"]</div>
                        <div class="dmrs-panel__subtitle">@Loc["portal.profile.accountSubtitle"]</div>
                    </div>
                </div>
                <dl class="row mb-0 small">
                    <dt class="col-5 text-muted">@Loc["portal.profile.recordId"]</dt>
                    <dd class="col-7">@patient?.Id</dd>
                    <dt class="col-5 text-muted">@Loc["portal.profile.managingClinic"]</dt>
                    <dd class="col-7">@(patient?.ManagingOrganization?.Display ?? patient?.ManagingOrganization?.Reference ?? "—")</dd>
                </dl>
                <div class="dmrs-empty-state dmrs-empty-state--inline mt-3">
                    @Loc["portal.profile.restrictedNote"]
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool isLoading = true;
    private bool isSaving;
    private string? errorMessage;
    private string? saveError;
    private string? successMessage;
    private Patient? patient;
    private PatientProfileEditModel? model;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        isLoading = true;
        errorMessage = null;
        try
        {
            patient = await PortalService.GetMyPatientAsync();
            model = patient is null ? null : MapToEditModel(patient);
        }
        catch (Exception ex)
        {
            errorMessage = Loc["portal.profile.loadFailed", ex.Message];
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ResetAsync()
    {
        successMessage = null;
        saveError = null;
        await LoadAsync();
    }

    private async Task SaveAsync()
    {
        if (model is null)
        {
            return;
        }

        isSaving = true;
        saveError = null;
        successMessage = null;

        try
        {
            patient = await PortalService.UpdateProfileAsync(model);
            if (patient is not null)
            {
                model = MapToEditModel(patient);
            }
            successMessage = Loc["portal.profile.saveSuccess"];
        }
        catch (Exception ex)
        {
            saveError = Loc["portal.profile.saveFailed", ex.Message];
        }
        finally
        {
            isSaving = false;
        }
    }

    private static PatientProfileEditModel MapToEditModel(Patient patient)
    {
        var name = patient.Name.FirstOrDefault();
        var phone = patient.Telecom.FirstOrDefault(t => t.System == ContactPoint.ContactPointSystem.Phone)?.Value;
        var email = patient.Telecom.FirstOrDefault(t => t.System == ContactPoint.ContactPointSystem.Email)?.Value;
        var address = patient.Address.FirstOrDefault();

        return new PatientProfileEditModel
        {
            GivenName = name?.Given is null ? null : string.Join(" ", name.Given),
            FamilyName = name?.Family,
            Phone = phone,
            Email = email,
            BirthDate = patient.BirthDate,
            Gender = patient.Gender?.ToString().ToLowerInvariant(),
            MaritalStatus = patient.MaritalStatus?.Coding.FirstOrDefault()?.Code,
            AddressLine = address?.Line is null ? null : string.Join("\n", address.Line),
            City = address?.City,
            State = address?.State,
            PostalCode = address?.PostalCode,
            Country = address?.Country
        };
    }
}
