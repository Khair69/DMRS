@page "/my-health"
@attribute [Authorize(Roles = "ROLE_PATIENT")]
@using Hl7.Fhir.Model
@using DMRS.Client.Features.Patients.Models
@using DMRS.Client.Features.Documents.Models
@using Task = System.Threading.Tasks.Task
@inject DMRS.Client.Features.Patients.Services.PatientPortalFeatureService PortalService
@inject DMRS.Client.Features.Documents.Services.PatientDocumentFeatureService DocumentService

<PageTitle>My Health Records</PageTitle>

<div class="workspace-hero workspace-hero--patient">
    <div>
        <span class="workspace-eyebrow">Patient Portal</span>
        <h1>My Health Records</h1>
        <p>Everything in your medical file — conditions, medications, results, visits, and documents.</p>
    </div>
    <div class="workspace-hero__actions">
        <a class="btn btn-outline-light" href="/my-profile">Edit My Profile</a>
    </div>
</div>

@if (isLoading)
{
    <div class="dmrs-loading-shell">
        <div class="spinner-border text-primary" role="status"></div>
    </div>
}
else if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (records is null)
{
    <div class="dmrs-panel mt-4">
        <div class="dmrs-empty-state">
            We couldn't find a medical record linked to your account. If you have an invitation,
            <a href="/patients/claim">claim it here</a>.
        </div>
    </div>
}
else
{
    <div class="dmrs-tabbar mt-4">
        @foreach (var tab in Tabs)
        {
            <button type="button"
                    class="dmrs-tab @(activeTab == tab.Key ? "dmrs-tab--active" : "")"
                    @onclick="() => activeTab = tab.Key">
                @tab.Label
                @if (tab.Count is int count)
                {
                    <span class="dmrs-tab__count">@count</span>
                }
            </button>
        }
    </div>

    <div class="dmrs-panel mt-3">
        @if (activeTab == "overview")
        {
            <div class="dmrs-panel__header">
                <div>
                    <div class="dmrs-panel__title">Overview</div>
                    <div class="dmrs-panel__subtitle">A quick summary of your record.</div>
                </div>
            </div>
            <div class="dmrs-metrics-grid dmrs-metrics-grid--compact">
                <div class="dmrs-metric-card metric-emerald">
                    <div class="dmrs-metric-card__label">Conditions</div>
                    <div class="dmrs-metric-card__value">@records.Conditions.Count</div>
                </div>
                <div class="dmrs-metric-card metric-gold">
                    <div class="dmrs-metric-card__label">Medications</div>
                    <div class="dmrs-metric-card__value">@records.Medications.Count</div>
                </div>
                <div class="dmrs-metric-card metric-rose">
                    <div class="dmrs-metric-card__label">Allergies</div>
                    <div class="dmrs-metric-card__value">@records.Allergies.Count</div>
                </div>
                <div class="dmrs-metric-card metric-ocean">
                    <div class="dmrs-metric-card__label">Results</div>
                    <div class="dmrs-metric-card__value">@records.Observations.Count</div>
                </div>
                <div class="dmrs-metric-card metric-sky">
                    <div class="dmrs-metric-card__label">Appointments</div>
                    <div class="dmrs-metric-card__value">@records.Appointments.Count</div>
                </div>
                <div class="dmrs-metric-card metric-ink">
                    <div class="dmrs-metric-card__label">Visits</div>
                    <div class="dmrs-metric-card__value">@records.Encounters.Count</div>
                </div>
            </div>
        }
        else if (activeTab == "documents")
        {
            <div class="dmrs-panel__header">
                <div>
                    <div class="dmrs-panel__title">Documents</div>
                    <div class="dmrs-panel__subtitle">Reports and files shared by your clinic.</div>
                </div>
            </div>
            @if (isLoadingDocuments)
            {
                <div class="text-muted small text-center py-2">Loading documents…</div>
            }
            else if (documents.Count == 0)
            {
                <div class="dmrs-empty-state">No documents have been shared with you yet.</div>
            }
            else
            {
                <div class="dmrs-stack">
                    @foreach (var doc in documents)
                    {
                        <div class="dmrs-note-card d-flex justify-content-between align-items-start gap-2">
                            <div class="flex-grow-1 overflow-hidden">
                                <div class="fw-semibold text-truncate" title="@doc.FileName">@doc.FileIcon @doc.FileName</div>
                                <div class="small text-muted">@doc.SizeDisplay · @doc.UploadedAt.ToLocalTime().ToString("dd MMM yyyy")</div>
                            </div>
                            <a href="@DocumentService.GetDownloadUrl(records.Patient!.Id!, doc.Id)"
                               target="_blank" class="btn btn-sm btn-outline-primary flex-shrink-0">Download</a>
                        </div>
                    }
                </div>
            }
        }
        else
        {
            var view = BuildListView(activeTab);
            <div class="dmrs-panel__header">
                <div>
                    <div class="dmrs-panel__title">@view.Title</div>
                </div>
            </div>
            @if (view.Rows.Count == 0)
            {
                <div class="dmrs-empty-state">@view.Empty</div>
            }
            else
            {
                <div class="dmrs-list">
                    @foreach (var row in view.Rows)
                    {
                        <div class="dmrs-list-item">
                            <div style="min-width:0;">
                                <div class="dmrs-list-item__title text-truncate">@row.Title</div>
                                <div class="dmrs-list-item__subtitle">@row.Meta</div>
                            </div>
                        </div>
                    }
                </div>
            }
        }
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "tab")]
    public string? TabFromQuery { get; set; }

    private bool isLoading = true;
    private bool isLoadingDocuments;
    private string? errorMessage;
    private string activeTab = "overview";
    private PatientPortalRecordsModel? records;
    private List<PatientDocumentModel> documents = [];

    private readonly record struct Row(string Title, string Meta);
    private readonly record struct TabDef(string Key, string Label, int? Count);
    private readonly record struct ListView(string Title, string Empty, List<Row> Rows);

    private IEnumerable<TabDef> Tabs =>
    [
        new("overview", "Overview", null),
        new("conditions", "Conditions", records?.Conditions.Count),
        new("medications", "Medications", records?.Medications.Count),
        new("allergies", "Allergies", records?.Allergies.Count),
        new("results", "Results", records?.Observations.Count),
        new("appointments", "Appointments", records?.Appointments.Count),
        new("encounters", "Visits", records?.Encounters.Count),
        new("procedures", "Procedures", records?.Procedures.Count),
        new("documents", "Documents", documents.Count)
    ];

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrWhiteSpace(TabFromQuery))
        {
            activeTab = TabFromQuery.ToLowerInvariant();
        }

        try
        {
            records = await PortalService.GetRecordsAsync();
            if (records?.Patient?.Id is not null)
            {
                await LoadDocumentsAsync(records.Patient.Id);
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Unable to load your records: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadDocumentsAsync(string patientId)
    {
        isLoadingDocuments = true;
        try
        {
            documents = (await DocumentService.ListAsync(patientId)).ToList();
        }
        catch
        {
            // Documents are best-effort; an access failure simply leaves the tab empty.
        }
        finally
        {
            isLoadingDocuments = false;
        }
    }

    private ListView BuildListView(string tab)
    {
        if (records is null)
        {
            return new ListView(string.Empty, string.Empty, []);
        }

        return tab switch
        {
            "conditions" => new ListView("Conditions", "No conditions recorded.",
                records.Conditions.Select(c => new Row(ConditionLabel(c),
                    c.ClinicalStatus?.Text ?? c.RecordedDate ?? "")).ToList()),
            "medications" => new ListView("Medications", "No medications on file.",
                records.Medications.Select(m => new Row(MedicationLabel(m),
                    $"{m.SafeStatus()} · {DosageText(m)}")).ToList()),
            "allergies" => new ListView("Allergies & Intolerances", "No allergies recorded.",
                records.Allergies.Select(a => new Row(AllergyLabel(a), CriticalityText(a))).ToList()),
            "results" => new ListView("Test Results & Measurements", "No results recorded.",
                records.Observations.Select(o => new Row(ObservationLabel(o), ObservationValue(o))).ToList()),
            "appointments" => new ListView("Appointments", "No appointments found.",
                records.Appointments.Select(a => new Row(AppointmentLabel(a), AppointmentWhen(a))).ToList()),
            "encounters" => new ListView("Visits", "No visits recorded.",
                records.Encounters.Select(e => new Row(EncounterLabel(e), e.SafeStatus())).ToList()),
            "procedures" => new ListView("Procedures", "No procedures recorded.",
                records.Procedures.Select(p => new Row(ProcedureLabel(p), p.SafeStatus())).ToList()),
            _ => new ListView("Records", "Nothing to show.", [])
        };
    }

    private static string ConditionLabel(Condition c)
        => c.Code?.Text ?? c.Code?.Coding.FirstOrDefault()?.Display ?? c.Code?.Coding.FirstOrDefault()?.Code ?? "Condition";

    private static string MedicationLabel(MedicationRequest m)
        => m.Medication?.Concept?.Text ?? m.Medication?.Concept?.Coding.FirstOrDefault()?.Display
            ?? m.Medication?.Concept?.Coding.FirstOrDefault()?.Code ?? "Medication";

    private static string DosageText(MedicationRequest m)
        => m.DosageInstruction.FirstOrDefault()?.Text ?? "As directed";

    private static string AllergyLabel(AllergyIntolerance a)
        => a.Code?.Text ?? a.Code?.Coding.FirstOrDefault()?.Display ?? a.Code?.Coding.FirstOrDefault()?.Code ?? "Allergy";

    private static string CriticalityText(AllergyIntolerance a)
    {
        var crit = a.SafeCriticality();
        return string.IsNullOrWhiteSpace(crit) ? "Recorded" : $"Criticality: {crit}";
    }

    private static string ObservationLabel(Observation o)
        => o.Code?.Text ?? o.Code?.Coding.FirstOrDefault()?.Display ?? o.Code?.Coding.FirstOrDefault()?.Code ?? "Measurement";

    private static string ObservationValue(Observation o)
    {
        if (o.Value is Quantity q)
        {
            return $"{q.Value?.ToString("0.#")} {q.Unit}".Trim();
        }
        if (o.Value is CodeableConcept cc)
        {
            return cc.Text ?? cc.Coding.FirstOrDefault()?.Display ?? o.SafeStatus();
        }
        return o.SafeStatus();
    }

    private static string EncounterLabel(Encounter e)
        => e.Type.FirstOrDefault()?.Text ?? e.Type.FirstOrDefault()?.Coding.FirstOrDefault()?.Display
            ?? e.Class?.FirstOrDefault()?.Coding.FirstOrDefault()?.Code ?? "Visit";

    private static string ProcedureLabel(Procedure p)
        => p.Code?.Text ?? p.Code?.Coding.FirstOrDefault()?.Display ?? p.Code?.Coding.FirstOrDefault()?.Code ?? "Procedure";

    private static string AppointmentLabel(Appointment a)
        => a.Description ?? a.AppointmentType?.Text ?? a.AppointmentType?.Coding.FirstOrDefault()?.Display ?? "Appointment";

    private static string AppointmentWhen(Appointment a)
        => DateTimeOffset.TryParse(a.StartElement?.Value?.ToString(), out var start)
            ? start.ToLocalTime().ToString("ddd, dd MMM yyyy · HH:mm")
            : a.SafeStatus();
}
