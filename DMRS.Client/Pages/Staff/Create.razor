@page "/organizations/{OrganizationId}/staff/new"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN")]
@inject DMRS.Client.Features.Organizations.Services.OrganizationFeatureService OrganizationService
@inject DMRS.Client.Features.Staff.Services.StaffFeatureService StaffService
@inject NavigationManager Navigation

<PageTitle>Invite Staff</PageTitle>

<h1>Invite Staff</h1>

@if (isLoadingOrganization)
{
    <div class="spinner-border" role="status"></div>
}
else if (organization is null)
{
    <div class="alert alert-danger">@organizationError</div>
}
else
{
    <div class="alert alert-info">
        Inviting staff for organization: <strong>@organization.Name</strong> (@organization.Id)
    </div>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(successMessage))
    {
        <div class="alert alert-success">@successMessage</div>
    }

    @if (inviteResult is not null)
    {
        <div class="card mt-3 mb-3">
            <div class="card-header">Invitation Generated</div>
            <div class="card-body">
                <p class="mb-2"><strong>Invite code</strong>: <code>@inviteResult.InviteCode</code></p>
                <p class="mb-2"><strong>Self-registration (auto-claim)</strong>: <a href="@inviteResult.RegistrationLink" target="_blank">@inviteResult.RegistrationLink</a></p>
                <p class="mb-0"><strong>Manual claim fallback</strong>: <a href="@inviteResult.ClaimLink" target="_blank">@inviteResult.ClaimLink</a></p>
            </div>
        </div>
    }

    <StaffInviteForm Model="model" IsBusy="@isSaving" SubmitText="Create Invitation" OnSave="Save" />
}

@code {
    [Parameter]
    public string OrganizationId { get; set; } = string.Empty;

    private readonly StaffInviteEditModel model = new();
    private Hl7.Fhir.Model.Organization? organization;
    private bool isLoadingOrganization;
    private bool isSaving;
    private string? errorMessage;
    private string? successMessage;
    private string? organizationError;
    private DMRS.Client.Features.Staff.Services.StaffInviteResult? inviteResult;

    protected override async Task OnParametersSetAsync()
    {
        organizationError = null;
        errorMessage = null;
        successMessage = null;
        isLoadingOrganization = true;

        try
        {
            organization = await OrganizationService.GetAsync(OrganizationId);
            if (organization is null)
            {
                organizationError = $"Organization {OrganizationId} not found.";
            }
        }
        catch (Exception ex)
        {
            organizationError = $"Unable to load organization: {ex.Message}";
        }
        finally
        {
            isLoadingOrganization = false;
        }
    }

    private async Task Save()
    {
        if (organization is null)
        {
            return;
        }

        isSaving = true;
        errorMessage = null;
        successMessage = null;
        inviteResult = null;

        try
        {
            inviteResult = await StaffService.CreateInviteAsync(OrganizationId, model, Navigation.BaseUri);
            successMessage = $"Staff invitation created. Practitioner: {inviteResult.PractitionerId}, PractitionerRole: {inviteResult.PractitionerRoleId}.";
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to create invitation: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }
}
