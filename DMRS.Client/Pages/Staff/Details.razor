@page "/organizations/{OrganizationId}/staff/{PractitionerId}"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN")]
@inherits DMRS.Client.Components.LocalizedComponentBase
@inject DMRS.Client.Features.Staff.Services.StaffFeatureService StaffService

<PageTitle>@Loc["staff.details.title"]</PageTitle>

<h1>@Loc["staff.details.title"]</h1>

@if (isBusy)
{
    <div class="spinner-border" role="status"></div>
}
else if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
else
{
    <StaffDetailsView Practitioner="@practitioner"
                      Roles="@roles"
                      OnProvisionAccount="ProvisionAccountAsync"
                      IsProvisioning="@isProvisioning"
                      ProvisionedCredentials="@provisionedCredentials"
                      ProvisionError="@provisionError" />
}

@code {
    [Parameter]
    public string OrganizationId { get; set; } = string.Empty;

    [Parameter]
    public string PractitionerId { get; set; } = string.Empty;

    private Hl7.Fhir.Model.Practitioner? practitioner;
    private IReadOnlyList<Hl7.Fhir.Model.PractitionerRole> roles = [];
    private bool isBusy;
    private string? errorMessage;
    private bool isProvisioning;
    private string? provisionError;
    private DMRS.Client.Features.Staff.Services.StaffProvisionResult? provisionedCredentials;

    protected override async Task OnParametersSetAsync()
    {
        isBusy = true;
        errorMessage = null;

        try
        {
            practitioner = await StaffService.GetPractitionerAsync(PractitionerId);
            roles = await StaffService.GetPractitionerRolesAsync(PractitionerId);

            if (practitioner is null)
            {
                errorMessage = Loc["staff.details.notFound", PractitionerId];
                roles = [];
                return;
            }

            roles = roles
                .Where(r => string.Equals(r.Organization?.Reference, $"Organization/{OrganizationId}", StringComparison.OrdinalIgnoreCase))
                .ToList();
        }
        catch (Exception ex)
        {
            errorMessage = Loc["staff.details.loadFailed", ex.Message];
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task ProvisionAccountAsync()
    {
        isProvisioning = true;
        provisionError = null;
        provisionedCredentials = null;

        try
        {
            provisionedCredentials = await StaffService.ProvisionAccountAsync(OrganizationId, PractitionerId);

            // Reload so the linked-account state reflects the new identifier.
            practitioner = await StaffService.GetPractitionerAsync(PractitionerId);
        }
        catch (Exception ex)
        {
            provisionError = Loc["staff.details.provisionFailed", ex.Message];
        }
        finally
        {
            isProvisioning = false;
        }
    }
}
