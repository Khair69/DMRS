@page "/service-requests/{Id}"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN,ROLE_PRACTITIONER")]
@inherits DMRS.Client.Components.LocalizedComponentBase
@inject DMRS.Client.Features.ServiceRequests.Services.ServiceRequestFeatureService ServiceRequestService

<PageTitle>@Loc["serviceRequests.details.title"]</PageTitle>

<h1>@Loc["serviceRequests.details.title"]</h1>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<div class="mb-3">
    <NavLink class="btn btn-sm btn-outline-secondary me-1" href="@($"/service-requests/{Id}/edit")">@Loc["common.edit"]</NavLink>
    <NavLink class="btn btn-sm btn-outline-info" href="@($"/service-requests/{Id}/history")">@Loc["common.history"]</NavLink>
</div>

<FhirJsonView Resource="request" />

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;

    private Hl7.Fhir.Model.ServiceRequest? request;
    private string? errorMessage;

    protected override async Task OnParametersSetAsync()
    {
        errorMessage = null;
        try
        {
            request = await ServiceRequestService.GetAsync(Id);
            if (request is null)
            {
                errorMessage = Loc["serviceRequests.notFound", Id];
            }
        }
        catch (Exception ex)
        {
            errorMessage = Loc["serviceRequests.loadFailed", ex.Message];
        }
    }
}
