@page "/service-requests/new"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN,ROLE_PRACTITIONER")]
@inject DMRS.Client.Features.ServiceRequests.Services.ServiceRequestFeatureService ServiceRequestService
@inject NavigationManager NavigationManager

<PageTitle>Create Service Request</PageTitle>

<h1>Create Service Request</h1>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<ServiceRequestForm Model="model" IsBusy="@isSaving" SubmitText="Create Service Request" OnSave="Save" />

@code {
    private readonly DMRS.Client.Features.ServiceRequests.Models.ServiceRequestEditModel model = new();
    private bool isSaving;
    private string? errorMessage;

    private async Task Save()
    {
        isSaving = true;
        errorMessage = null;
        try
        {
            var created = await ServiceRequestService.CreateAsync(model);
            if (created?.Id is null)
            {
                errorMessage = "Service request was created but no id was returned.";
                return;
            }

            NavigationManager.NavigateTo($"/service-requests/{created.Id}");
        }
        catch (Exception ex)
        {
            errorMessage = $"An error occurred while creating the service request: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }
}
