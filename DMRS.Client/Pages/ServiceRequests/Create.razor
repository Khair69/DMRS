@page "/service-requests/new"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN,ROLE_PRACTITIONER")]
@inherits DMRS.Client.Components.LocalizedComponentBase
@inject DMRS.Client.Features.ServiceRequests.Services.ServiceRequestFeatureService ServiceRequestService
@inject NavigationManager NavigationManager

<PageTitle>@Loc["serviceRequests.create.title"]</PageTitle>

<h1>@Loc["serviceRequests.create.title"]</h1>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<ServiceRequestForm Model="model" IsBusy="@isSaving" SubmitText="@Loc["serviceRequests.create.submit"]" OnSave="Save" />

@code {
    private readonly DMRS.Client.Features.ServiceRequests.Models.ServiceRequestEditModel model = new();
    private bool isSaving;
    private string? errorMessage;

    private async Task Save()
    {
        isSaving = true;
        errorMessage = null;
        try
        {
            var created = await ServiceRequestService.CreateAsync(model);
            if (created?.Id is null)
            {
                errorMessage = Loc["serviceRequests.noIdReturned"];
                return;
            }

            NavigationManager.NavigateTo($"/service-requests/{created.Id}");
        }
        catch (Exception ex)
        {
            errorMessage = Loc["serviceRequests.createError", ex.Message];
        }
        finally
        {
            isSaving = false;
        }
    }
}
