@page "/procedures/{Id}/edit"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN,ROLE_PRACTITIONER")]
@inherits DMRS.Client.Components.LocalizedComponentBase
@inject DMRS.Client.Features.Procedures.Services.ProcedureFeatureService ProcedureService
@inject NavigationManager Navigation

<PageTitle>@Loc["procedures.edit.title"]</PageTitle>

<h1>@Loc["procedures.edit.title"]</h1>

@if (isLoading)
{
    <div class="spinner-border" role="status"></div>
}
else
{
    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    <ProcedureForm Model="model" IsBusy="@isSaving" SubmitText="@Loc["procedures.edit.submit"]" OnSave="Save" />
}

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;

    private DMRS.Client.Features.Procedures.Models.ProcedureEditModel model = new();
    private bool isLoading;
    private bool isSaving;
    private string? errorMessage;

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var procedure = await ProcedureService.GetAsync(Id);
            if (procedure is null)
            {
                errorMessage = Loc["procedures.notFound", Id];
                return;
            }

            model = DMRS.Client.Features.Procedures.Models.ProcedureEditModel.FromProcedure(procedure);
        }
        catch (Exception ex)
        {
            errorMessage = Loc["procedures.loadFailed", ex.Message];
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task Save()
    {
        errorMessage = null;
        isSaving = true;

        try
        {
            await ProcedureService.UpdateAsync(Id, model);
            Navigation.NavigateTo($"/procedures/{Id}");
        }
        catch (Exception ex)
        {
            errorMessage = Loc["procedures.updateFailed", ex.Message];
        }
        finally
        {
            isSaving = false;
        }
    }
}
