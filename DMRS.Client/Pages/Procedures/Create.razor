@page "/procedures/new"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN,ROLE_PRACTITIONER")]
@inherits DMRS.Client.Components.LocalizedComponentBase
@inject DMRS.Client.Features.Procedures.Services.ProcedureFeatureService ProcedureService
@inject NavigationManager NavigationManager

<PageTitle>@Loc["procedures.create.title"]</PageTitle>

<ResourceCreatePage Eyebrow="@Loc["procedures.workflow.eyebrow"]"
                    Title="@Loc["procedures.create.title"]"
                    Subtitle="@Loc["procedures.create.heroSubtitle"]"
                    FormPanelTitle="@Loc["procedures.create.draftTitle"]"
                    FormPanelSubtitle="@Loc["procedures.create.draftSubtitle"]"
                    GuidePanelTitle="@Loc["procedures.guide.title"]"
                    ErrorMessage="@errorMessage">
    <ChildContent>
        <ProcedureForm Model="model" IsBusy="@isSaving" SubmitText="@Loc["procedures.create.submit"]" OnSave="Save" />
    </ChildContent>
    <Guide>
        <div class="d-grid gap-3">
            <div class="dmrs-note-card">
                <div class="dmrs-note-card__title">@Loc["procedures.guide.whatTitle"]</div>
                <p class="mb-0">@Loc["procedures.guide.whatBody"]</p>
            </div>
            <div class="dmrs-note-card">
                <div class="dmrs-note-card__title">@Loc["procedures.guide.statusTitle"]</div>
                <p class="mb-0">@Loc["procedures.guide.statusBody"]</p>
            </div>
        </div>
    </Guide>
</ResourceCreatePage>

@code {
    private readonly DMRS.Client.Features.Procedures.Models.ProcedureEditModel model = new();
    private bool isSaving;
    private string? errorMessage;

    // Prefill the patient when arriving from a patient's Quick Links (e.g. /procedures/new?patient={id}).
    [SupplyParameterFromQuery(Name = "patient")]
    private string? PatientId { get; set; }

    protected override void OnInitialized()
    {
        if (!string.IsNullOrWhiteSpace(PatientId))
        {
            model.PatientId = PatientId;
        }
    }

    private async Task Save()
    {
        isSaving = true;
        errorMessage = null;
        try
        {
            var created = await ProcedureService.CreateAsync(model);
            if (created?.Id is null)
            {
                errorMessage = Loc["procedures.noIdReturned"];
                return;
            }

            NavigationManager.NavigateTo($"/procedures/{created.Id}");
        }
        catch (Exception ex)
        {
            errorMessage = Loc["procedures.createError", ex.Message];
        }
        finally
        {
            isSaving = false;
        }
    }
}
