@page "/procedures/new"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN,ROLE_PRACTITIONER")]
@inherits DMRS.Client.Components.LocalizedComponentBase
@inject DMRS.Client.Features.Procedures.Services.ProcedureFeatureService ProcedureService
@inject NavigationManager NavigationManager

<PageTitle>@Loc["procedures.create.title"]</PageTitle>

<h1>@Loc["procedures.create.title"]</h1>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<ProcedureForm Model="model" IsBusy="@isSaving" SubmitText="@Loc["procedures.create.submit"]" OnSave="Save" />

@code {
    private readonly DMRS.Client.Features.Procedures.Models.ProcedureEditModel model = new();
    private bool isSaving;
    private string? errorMessage;

    private async Task Save()
    {
        isSaving = true;
        errorMessage = null;
        try
        {
            var created = await ProcedureService.CreateAsync(model);
            if (created?.Id is null)
            {
                errorMessage = Loc["procedures.noIdReturned"];
                return;
            }

            NavigationManager.NavigateTo($"/procedures/{created.Id}");
        }
        catch (Exception ex)
        {
            errorMessage = Loc["procedures.createError", ex.Message];
        }
        finally
        {
            isSaving = false;
        }
    }
}
