@page "/procedures/{Id}"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN,ROLE_PRACTITIONER")]
@using DMRS.Client.Features.Procedures.Models
@inherits DMRS.Client.Components.LocalizedComponentBase
@inject DMRS.Client.Features.Procedures.Services.ProcedureFeatureService ProcedureService

<PageTitle>@Loc["procedures.details.title"]</PageTitle>

<ResourceDetailsPage Eyebrow="@Loc["procedures.workflow.eyebrow"]"
                     Title="@DisplayName"
                     Subtitle="@Loc["procedures.details.subline", PatientId]"
                     SummaryTitle="@Loc["procedures.summary.title"]"
                     SummarySubtitle="@Loc["procedures.summary.subtitle"]"
                     EditHref="@($"/procedures/{Id}/edit")"
                     HistoryHref="@($"/procedures/{Id}/history")"
                     IsLoading="isLoading"
                     ErrorMessage="@errorMessage"
                     Resource="procedure">
    <DetailRow Label="@Loc["common.field.code"]" Value="@DisplayName" />
    <DetailRow Label="@Loc["common.field.patient"]" Value="@PatientId">
        <a href="@($"/patients/{PatientId}")">@PatientId</a>
    </DetailRow>
    <DetailRow Label="@Loc["common.field.status"]">
        <StatusPill Status="@summary?.Status" />
    </DetailRow>
    <DetailRow Label="@Loc["common.field.performedDate"]" Value="@PerformedDisplay" />
</ResourceDetailsPage>

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;

    private Hl7.Fhir.Model.Procedure? procedure;
    private ProcedureEditModel? summary;
    private bool isLoading = true;
    private string? errorMessage;

    private string DisplayName => string.IsNullOrWhiteSpace(summary?.CodeText)
        ? Loc["procedures.details.title"]
        : summary!.CodeText;

    private string PatientId => summary?.PatientId ?? string.Empty;

    private string? PerformedDisplay => summary?.PerformedDateTime?.ToString("dd MMM yyyy HH:mm");

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        errorMessage = null;
        procedure = null;
        summary = null;
        try
        {
            procedure = await ProcedureService.GetAsync(Id);
            if (procedure is null)
            {
                errorMessage = Loc["procedures.notFound", Id];
                return;
            }

            summary = ProcedureEditModel.FromProcedure(procedure);
        }
        catch (Exception ex)
        {
            errorMessage = Loc["procedures.loadFailed", ex.Message];
        }
        finally
        {
            isLoading = false;
        }
    }
}
