@page "/procedures/{Id}"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN,ROLE_PRACTITIONER")]
@inherits DMRS.Client.Components.LocalizedComponentBase
@inject DMRS.Client.Features.Procedures.Services.ProcedureFeatureService ProcedureService

<PageTitle>@Loc["procedures.details.title"]</PageTitle>

<h1>@Loc["procedures.details.title"]</h1>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<div class="mb-3">
    <NavLink class="btn btn-sm btn-outline-secondary me-1" href="@($"/procedures/{Id}/edit")">@Loc["common.edit"]</NavLink>
    <NavLink class="btn btn-sm btn-outline-info" href="@($"/procedures/{Id}/history")">@Loc["common.history"]</NavLink>
</div>

<FhirJsonView Resource="procedure" />

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;

    private Hl7.Fhir.Model.Procedure? procedure;
    private string? errorMessage;

    protected override async Task OnParametersSetAsync()
    {
        errorMessage = null;
        try
        {
            procedure = await ProcedureService.GetAsync(Id);
            if (procedure is null)
            {
                errorMessage = Loc["procedures.notFound", Id];
            }
        }
        catch (Exception ex)
        {
            errorMessage = Loc["procedures.loadFailed", ex.Message];
        }
    }
}
