@page "/cds/admin"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN")]
@implements IDisposable
@using System.Text.Json
@using DMRS.Client.Features.Cds.Models
@inject DMRS.Client.Features.Cds.Services.CdsAdminFeatureService CdsService

<PageTitle>CDS Admin</PageTitle>

<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
        <h1 class="mb-1">CDS Admin</h1>
        <p class="text-body-secondary mb-0">Author, inspect, test, and manage medication CDS rules from one admin console.</p>
    </div>
    <button class="btn btn-outline-primary" @onclick="LoadAllAsync" disabled="@isLoading">
        @(isLoading ? "Refreshing..." : "Refresh Console")
    </button>
</div>

@if (!string.IsNullOrWhiteSpace(loadError))
{
    <div class="alert alert-danger">@loadError</div>
}

<div class="row g-4">
    <div class="col-12 col-xl-4">
        <div class="card shadow-sm border-0 cds-admin-card">
            <div class="card-header bg-white border-0 pb-0">
                <h2 class="h5 mb-1">Template Builder</h2>
                <p class="text-body-secondary mb-0">Start from a supported medication rule template and load it into the editor.</p>
            </div>
            <div class="card-body">
                <EditForm Model="templateModel" OnSubmit="CompileTemplateAsync">
                    <div class="mb-3">
                        <label class="form-label">Template</label>
                        <InputSelect @bind-Value="templateModel.TemplateId" class="form-select" @onchange="OnTemplateChanged">
                            @foreach (var template in templates)
                            {
                                <option value="@template.TemplateId">@template.Title</option>
                            }
                        </InputSelect>
                    </div>
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label">Rule Name</label>
                            <InputText @bind-Value="templateModel.Name" class="form-control" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Description</label>
                            <InputTextArea @bind-Value="templateModel.Description" class="form-control" rows="2" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Priority</label>
                            <InputNumber @bind-Value="templateModel.Priority" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Indicator</label>
                            <InputSelect @bind-Value="templateModel.Indicator" class="form-select">
                                <option value="info">info</option>
                                <option value="warning">warning</option>
                                <option value="hard-stop">hard-stop</option>
                            </InputSelect>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Source Label</label>
                            <InputText @bind-Value="templateModel.SourceLabel" class="form-control" />
                        </div>
                        @if (NeedsMedicationRxCui)
                        {
                            <div class="col-12">
                                <label class="form-label">Medication RxCUI</label>
                                <InputText @bind-Value="templateModel.MedicationRxCui" class="form-control" />
                            </div>
                        }
                        @if (NeedsPregnancyCategory)
                        {
                            <div class="col-12">
                                <label class="form-label">Pregnancy Category</label>
                                <InputText @bind-Value="templateModel.PregnancyCategory" class="form-control" />
                            </div>
                        }
                        @if (NeedsIndicationCode)
                        {
                            <div class="col-12">
                                <label class="form-label">Indication Code</label>
                                <InputText @bind-Value="templateModel.IndicationCode" class="form-control" />
                            </div>
                        }
                    </div>
                    <div class="d-flex gap-2 mt-4">
                        <button class="btn btn-primary" type="submit" disabled="@isCompiling">Compile</button>
                        <button class="btn btn-outline-success" type="button" @onclick="CreateFromTemplateAsync" disabled="@isSaving">Save From Template</button>
                    </div>
                </EditForm>

                @if (!string.IsNullOrWhiteSpace(builderError))
                {
                    <div class="alert alert-danger mt-3 mb-0">@builderError</div>
                }

                @if (!string.IsNullOrWhiteSpace(builderSuccess))
                {
                    <div class="alert alert-success mt-3 mb-0">@builderSuccess</div>
                }
            </div>
        </div>

        <div class="card shadow-sm border-0 cds-admin-card mt-4">
            <div class="card-header bg-white border-0 pb-0">
                <h2 class="h5 mb-1">Variables and Templates</h2>
                <p class="text-body-secondary mb-0">Reference the supported CDS inputs and starter templates.</p>
            </div>
            <div class="card-body">
                <div class="mb-4">
                    <div class="fw-semibold mb-2">Templates</div>
                    <div class="cds-scroll-panel-sm">
                        @foreach (var template in templates)
                        {
                            <div class="border rounded-3 p-2 mb-2">
                                <div class="fw-semibold">@template.Title</div>
                                <div class="small text-body-secondary">@template.Description</div>
                            </div>
                        }
                    </div>
                </div>
                <div>
                    <div class="fw-semibold mb-2">Variables</div>
                    <div class="cds-scroll-panel-sm">
                        @foreach (var variable in variables)
                        {
                            <div class="border rounded-3 p-2 mb-2">
                                <div><code>@variable.Path</code></div>
                                <div class="small text-body-secondary">@variable.Type | @variable.Description</div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0 cds-admin-card mt-4">
            <div class="card-header bg-white border-0 pb-0">
                <h2 class="h5 mb-1">Medicine Knowledge</h2>
                <p class="text-body-secondary mb-0">Browse the normalized medicine knowledge now available to CDS.</p>
            </div>
            <div class="card-body">
                <EditForm Model="this" OnSubmit="SearchMedicinesAsync">
                    <div class="input-group mb-3">
                        <InputText @bind-Value="medicineSearch" class="form-control" placeholder="Search by name or RxCUI" />
                        <button class="btn btn-outline-primary" type="submit" disabled="@isSearchingMedicines">Search</button>
                    </div>
                </EditForm>

                @if (medicineResults.Count == 0)
                {
                    <div class="alert alert-secondary mb-0">No medicine results loaded.</div>
                }
                else
                {
                    <div class="cds-scroll-panel">
                        @foreach (var medicine in medicineResults)
                        {
                            <div class="border rounded-3 p-3 mb-3">
                                <div class="d-flex justify-content-between gap-3">
                                    <div>
                                        <div class="fw-semibold">@medicine.Name</div>
                                        <div class="small text-body-secondary">RxCUI: @medicine.RxCui</div>
                                    </div>
                                    @if (medicine.IsControlled == true)
                                    {
                                        <span class="badge text-bg-warning">Controlled</span>
                                    }
                                </div>
                                <div class="small mt-2">
                                    Max daily: @DisplayDose(medicine.MaxDailyMg) | Pregnancy: @(medicine.PregnancyCategory ?? "n/a")
                                </div>
                                <div class="small text-body-secondary mt-1">
                                    Ingredients: @string.Join(", ", medicine.Ingredients.Select(i => i.Name))
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-12 col-xl-8">
        <div class="card shadow-sm border-0 cds-admin-card mb-4">
            <div class="card-header bg-white border-0 pb-0">
                <div class="d-flex justify-content-between align-items-start gap-3">
                    <div>
                        <h2 class="h5 mb-1">Rule Workspace</h2>
                        <p class="text-body-secondary mb-0">Edit draft rules, validate them, preview them, and publish only when ready.</p>
                    </div>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="StartNewRule">New Raw Rule</button>
                </div>
            </div>
            <div class="card-body">
                @if (editableRule is null)
                {
                    <div class="alert alert-secondary mb-0">Select a stored rule or compile a template to start editing.</div>
                }
                else
                {
                    <div class="d-flex flex-wrap gap-2 mb-3">
                        <span class="badge text-bg-light border">Status: @editableRule.Status</span>
                        @if (editableRule.PublishedVersionNumber is not null)
                        {
                            <span class="badge text-bg-light border">Published v@editableRule.PublishedVersionNumber</span>
                        }
                        @if (editableRule.HasUnpublishedChanges)
                        {
                            <span class="badge text-bg-warning">Draft Changes Pending</span>
                        }
                        @if (editableRule.IsActive)
                        {
                            <span class="badge text-bg-success">Live</span>
                        }
                        else if (editableRule.PublishedVersionId is not null && editableRule.Status == "Published")
                        {
                            <span class="badge text-bg-secondary">Published but Off</span>
                        }
                    </div>
                    <EditForm Model="editableRule" OnSubmit="SaveEditableRuleAsync">
                        <div class="row g-3">
                            <div class="col-md-7">
                                <label class="form-label">Rule Name</label>
                                <InputText @bind-Value="editableRule.Name" class="form-control" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Hook</label>
                                <InputText @bind-Value="editableRule.HookId" class="form-control" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">Priority</label>
                                <InputNumber @bind-Value="editableRule.Priority" class="form-control" />
                            </div>
                            <div class="col-12">
                                <label class="form-label">Description</label>
                                <InputTextArea @bind-Value="editableRule.Description" class="form-control" rows="2" />
                            </div>
                            <div class="col-12">
                                <label class="form-label">Expression JSON</label>
                                <InputTextArea @bind-Value="editableRule.ExpressionJson" class="form-control font-monospace" rows="8"
                                              @oninput="OnExpressionJsonInput" />
                            </div>
                            <div class="col-12">
                                <label class="form-label">Card Template JSON</label>
                                <InputTextArea @bind-Value="editableRule.CardTemplateJson" class="form-control font-monospace" rows="8"
                                              @oninput="OnCardTemplateJsonInput" />
                            </div>
                        </div>
                        <div class="d-flex flex-wrap gap-2 mt-4">
                            <button class="btn btn-primary" type="submit" disabled="@isSaving">Save Draft</button>
                            <button class="btn btn-outline-dark" type="button" @onclick="PublishEditableRuleAsync" disabled="@(!CanPublishEditableRule || isPublishing)">Publish</button>
                            <button class="btn btn-outline-primary" type="button" @onclick="ValidateEditableRuleAsync" disabled="@isValidating">Validate</button>
                            <button class="btn btn-outline-success" type="button" @onclick="PreviewEditableRuleAsync" disabled="@isPreviewing">Preview</button>
                            <button class="btn btn-outline-warning" type="button" @onclick="ToggleEditableRuleAsync" disabled="@(!CanToggleEditableRule || isToggling)">
                                @(editableRule.IsActive ? "Deactivate" : "Activate")
                            </button>
                            <button class="btn btn-outline-secondary" type="button" @onclick="CloneEditableRuleAsync" disabled="@(!CanCloneEditableRule || isCloning)">Clone</button>
                            <button class="btn btn-outline-danger" type="button" @onclick="ArchiveEditableRuleAsync" disabled="@(!CanArchiveEditableRule || isArchiving)">Archive</button>
                        </div>
                    </EditForm>

                    @if (validationResult is not null)
                    {
                        <div class="alert @(validationResult.IsValid ? "alert-success" : "alert-danger") mt-3 mb-0">
                            @if (validationResult.IsValid)
                            {
                                <div>Rule validation passed.</div>
                            }
                            else
                            {
                                @foreach (var error in validationResult.Errors)
                                {
                                    <div>@error</div>
                                }
                            }
                        </div>
                    }
                }
            </div>
        </div>

        <div class="card shadow-sm border-0 cds-admin-card mb-4">
            <div class="card-header bg-white border-0 pb-0">
                <h2 class="h5 mb-1">Preview Payload</h2>
                <p class="text-body-secondary mb-0">Edit the sample hook payload directly before previewing a rule.</p>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label">Preview Context JSON</label>
                        <InputTextArea @bind-Value="previewContextJson" class="form-control font-monospace" rows="12" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Preview Prefetch JSON</label>
                        <InputTextArea @bind-Value="previewPrefetchJson" class="form-control font-monospace" rows="5" />
                    </div>
                </div>
                <div class="d-flex gap-2 mt-4">
                    <button class="btn btn-outline-secondary" type="button" @onclick="ResetPreviewPayload">Reset Sample Payload</button>
                    <button class="btn btn-outline-success" type="button" @onclick="PreviewEditableRuleAsync" disabled="@(editableRule is null || isPreviewing)">Preview Current Rule</button>
                </div>
                @if (!string.IsNullOrWhiteSpace(previewError))
                {
                    <div class="alert alert-danger mt-3 mb-0">@previewError</div>
                }
            </div>
        </div>

        <div class="card shadow-sm border-0 cds-admin-card mb-4">
            <div class="card-header bg-white border-0 pb-0">
                <div class="d-flex justify-content-between align-items-start gap-3">
                    <div>
                        <h2 class="h5 mb-1">Preview Cards</h2>
                        <p class="text-body-secondary mb-0">The result of previewing the current rule against the current sample payload.</p>
                    </div>
                    @if (isAutoPreviewPending || isPreviewing)
                    {
                        <span class="text-body-secondary small d-flex align-items-center gap-1 pt-1">
                            <span class="spinner-border spinner-border-sm"></span>Updating…
                        </span>
                    }
                </div>
            </div>
            <div class="card-body">
                @if (previewResponse is null)
                {
                    <div class="alert alert-secondary mb-0">Preview a rule to see resulting CDS cards.</div>
                }
                else if (!previewResponse.Validation.IsValid)
                {
                    <div class="alert alert-danger mb-0">
                        <div class="fw-semibold mb-2">Preview validation failed</div>
                        @foreach (var error in previewResponse.Validation.Errors)
                        {
                            <div>@error</div>
                        }
                    </div>
                }
                else if (previewResponse.Cards.Count == 0)
                {
                    <div class="alert alert-warning mb-0">The preview ran successfully, but the current payload did not trigger any cards.</div>
                }
                else
                {
                    <div class="row g-3">
                        @foreach (var card in previewResponse.Cards)
                        {
                            <div class="col-12">
                                <div class="border rounded-3 p-3 cds-preview-card">
                                    <div class="d-flex justify-content-between gap-3">
                                        <div>
                                            <div class="fw-semibold">@card.Summary</div>
                                            @if (!string.IsNullOrWhiteSpace(card.Detail))
                                            {
                                                <div class="text-body-secondary mt-1">@card.Detail</div>
                                            }
                                        </div>
                                        <span class="badge text-bg-light border">@card.Indicator</span>
                                    </div>
                                    <div class="small text-body-secondary mt-2">
                                        Source: @card.Source.Label
                                        @if (!string.IsNullOrWhiteSpace(card.Source.Url))
                                        {
                                            <span> | </span><a href="@card.Source.Url" target="_blank">link</a>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="card shadow-sm border-0 cds-admin-card mb-4">
            <div class="card-header bg-white border-0 pb-0">
                <h2 class="h5 mb-1">Version History</h2>
                <p class="text-body-secondary mb-0">Published snapshots stay immutable and are what live CDS actually evaluates.</p>
            </div>
            <div class="card-body">
                @if (editableRule is null || editableRule.Id == Guid.Empty)
                {
                    <div class="alert alert-secondary mb-0">Save a rule first to start building version history.</div>
                }
                else if (selectedRuleVersions.Count == 0)
                {
                    <div class="alert alert-secondary mb-0">This rule has not been published yet.</div>
                }
                else
                {
                    <div class="cds-scroll-panel-sm">
                        @foreach (var version in selectedRuleVersions)
                        {
                            <div class="border rounded-3 p-3 mb-3">
                                <div class="d-flex justify-content-between gap-3">
                                    <div>
                                        <div class="fw-semibold">Version @version.VersionNumber</div>
                                        <div class="small text-body-secondary">@version.Name</div>
                                    </div>
                                    @if (editableRule.PublishedVersionId == version.Id)
                                    {
                                        <span class="badge text-bg-success">Current Live Snapshot</span>
                                    }
                                </div>
                                <div class="small text-body-secondary mt-2">
                                    Published @(version.PublishedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")) by @(version.PublishedBy ?? "system")
                                </div>
                                <div class="small text-body-secondary mt-1">
                                    Hook: <code>@version.HookId</code> | Priority: @version.Priority
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="card shadow-sm border-0 cds-admin-card">
            <div class="card-header bg-white border-0 pb-0">
                <h2 class="h5 mb-1">Stored CDS Rules</h2>
                <p class="text-body-secondary mb-0">Select a rule to edit its draft, publish it, clone it, or toggle its live state.</p>
            </div>
            <div class="card-body">
                @if (rules.Count == 0)
                {
                    <div class="alert alert-secondary mb-0">No CDS rules found.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Hook</th>
                                    <th>Priority</th>
                                    <th>Status</th>
                                    <th>Version</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var rule in rules)
                                {
                                    <tr class="@(editableRule?.Id == rule.Id ? "table-primary" : null)">
                                        <td>
                                            <div class="fw-semibold">@rule.Name</div>
                                            @if (!string.IsNullOrWhiteSpace(rule.Description))
                                            {
                                                <div class="small text-body-secondary">@rule.Description</div>
                                            }
                                        </td>
                                        <td><code>@rule.HookId</code></td>
                                        <td>@rule.Priority</td>
                                        <td>
                                            <div class="d-flex flex-wrap gap-1 justify-content-start">
                                                <span class="badge @(rule.Status == "Archived" ? "text-bg-dark" : "text-bg-light border")">@rule.Status</span>
                                                @if (rule.IsActive)
                                                {
                                                    <span class="badge text-bg-success">Live</span>
                                                }
                                                else if (rule.PublishedVersionId is not null && rule.Status == "Published")
                                                {
                                                    <span class="badge text-bg-secondary">Off</span>
                                                }
                                                @if (rule.HasUnpublishedChanges)
                                                {
                                                    <span class="badge text-bg-warning">Draft</span>
                                                }
                                            </div>
                                        </td>
                                        <td>@(rule.PublishedVersionNumber is null ? "-" : $"v{rule.PublishedVersionNumber}")</td>
                                        <td class="text-end">
                                            <div class="d-flex justify-content-end gap-2">
                                                <button class="btn btn-sm btn-outline-primary" @onclick="() => EditRuleAsync(rule)">Edit</button>
                                                <button class="btn btn-sm btn-outline-dark" @onclick="() => PublishStoredRuleAsync(rule)" disabled="@(rule.Status == "Archived")">Publish</button>
                                                <button class="btn btn-sm @(rule.IsActive ? "btn-outline-warning" : "btn-outline-success")"
                                                        disabled="@(rule.PublishedVersionId is null || rule.Status != "Published")"
                                                        @onclick="() => ToggleStoredRuleAsync(rule)">
                                                    @(rule.IsActive ? "Deactivate" : "Activate")
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private const string DefaultPreviewPrefetchJson = "null";

    private bool isLoading;
    private bool isCompiling;
    private bool isSaving;
    private bool isPreviewing;
    private bool isValidating;
    private bool isToggling;
    private bool isPublishing;
    private bool isArchiving;
    private bool isCloning;
    private bool isSearchingMedicines;
    private bool isAutoPreviewPending;
    private CancellationTokenSource? _debounceCts;
    private string? loadError;
    private string? builderError;
    private string? builderSuccess;
    private string? previewError;
    private string medicineSearch = "acetaminophen";
    private string previewContextJson = string.Empty;
    private string previewPrefetchJson = DefaultPreviewPrefetchJson;
    private IReadOnlyList<CdsRuleSummary> rules = [];
    private IReadOnlyList<CdsVariableDefinitionModel> variables = [];
    private IReadOnlyList<CdsRuleTemplateDefinitionModel> templates = [];
    private IReadOnlyList<CdsMedicineKnowledgeModel> medicineResults = [];
    private IReadOnlyList<CdsRuleVersionModel> selectedRuleVersions = [];
    private CdsRuleTemplateRequestModel templateModel = new();
    private CdsRuleSummary? editableRule;
    private CdsRuleValidationResultModel? validationResult;
    private CdsRulePreviewResponseModel? previewResponse;

    private bool NeedsMedicationRxCui => string.Equals(templateModel.TemplateId, "max-dose-exceeded", StringComparison.OrdinalIgnoreCase);
    private bool NeedsPregnancyCategory => string.Equals(templateModel.TemplateId, "pregnancy-category-warning", StringComparison.OrdinalIgnoreCase);
    private bool NeedsIndicationCode => string.Equals(templateModel.TemplateId, "indication-mismatch", StringComparison.OrdinalIgnoreCase);
    private bool CanToggleEditableRule => editableRule is not null && editableRule.PublishedVersionId != null && editableRule.Status == "Published";
    private bool CanPublishEditableRule => editableRule is not null && editableRule.Id != Guid.Empty && editableRule.Status != "Archived";
    private bool CanArchiveEditableRule => editableRule is not null && editableRule.Id != Guid.Empty && editableRule.Status != "Archived";
    private bool CanCloneEditableRule => editableRule is not null && editableRule.Id != Guid.Empty;

    protected override async Task OnInitializedAsync()
    {
        ResetPreviewPayload();
        await LoadAllAsync();
    }

    private async Task LoadAllAsync()
    {
        isLoading = true;
        loadError = null;

        try
        {
            var rulesTask = CdsService.ListRulesAsync();
            var variablesTask = CdsService.ListVariablesAsync();
            var templatesTask = CdsService.ListTemplatesAsync();
            var medicinesTask = CdsService.SearchMedicinesAsync(medicineSearch);

            await Task.WhenAll(rulesTask, variablesTask, templatesTask, medicinesTask);

            rules = rulesTask.Result;
            variables = variablesTask.Result;
            templates = templatesTask.Result;
            medicineResults = medicinesTask.Result;

            if (templates.Count > 0 && string.IsNullOrWhiteSpace(templateModel.TemplateId))
            {
                templateModel.TemplateId = templates[0].TemplateId;
                templateModel.IsActive = false;
            }
        }
        catch (Exception ex)
        {
            loadError = $"Unable to load CDS admin console: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SearchMedicinesAsync()
    {
        isSearchingMedicines = true;
        try
        {
            medicineResults = await CdsService.SearchMedicinesAsync(medicineSearch);
        }
        finally
        {
            isSearchingMedicines = false;
        }
    }

    private Task OnTemplateChanged(ChangeEventArgs _)
    {
        builderError = null;
        builderSuccess = null;
        return Task.CompletedTask;
    }

    private async Task CompileTemplateAsync()
    {
        isCompiling = true;
        builderError = null;
        builderSuccess = null;

        try
        {
            var compiled = await CdsService.CompileTemplateAsync(templateModel);
            if (compiled is not null)
            {
                await EditRuleAsync(compiled);
                builderSuccess = $"Compiled template '{templateModel.TemplateId}' into the rule workspace.";
            }
        }
        catch (Exception ex)
        {
            builderError = $"Failed to compile rule template: {ex.Message}";
        }
        finally
        {
            isCompiling = false;
        }
    }

    private async Task CreateFromTemplateAsync()
    {
        isSaving = true;
        builderError = null;
        builderSuccess = null;

        try
        {
            var saved = await CdsService.CreateFromTemplateAsync(templateModel);
            if (saved is not null)
            {
                builderSuccess = $"Saved CDS draft '{saved.Name}' with id {saved.Id}.";
                rules = await CdsService.ListRulesAsync();
                await EditRuleAsync(saved);
            }
        }
        catch (Exception ex)
        {
            builderError = $"Failed to save template rule: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task EditRuleAsync(CdsRuleSummary rule)
    {
        editableRule = CloneRule(rule);
        validationResult = null;
        previewResponse = null;
        previewError = null;
        selectedRuleVersions = rule.Id == Guid.Empty
            ? []
            : await CdsService.ListRuleVersionsAsync(rule.Id);
    }

    private void StartNewRule()
    {
        editableRule = new CdsRuleSummary
        {
            HookId = "medication-prescribe",
            Name = "New CDS Rule",
            Priority = 1,
            IsActive = false,
            Status = "Draft",
            HasUnpublishedChanges = true,
            ExpressionJson = "{\n  \"==\": [\n    { \"var\": \"safety.isControlled\" },\n    true\n  ]\n}",
            CardTemplateJson = "{\n  \"summary\": \"Controlled medication selected: {{medication.name}}\",\n  \"detail\": \"This medication is flagged as controlled.\",\n  \"indicator\": \"warning\",\n  \"source\": {\n    \"label\": \"DMRS CDS\"\n  }\n}"
        };
        validationResult = null;
        previewResponse = null;
        previewError = null;
        selectedRuleVersions = [];
    }

    private async Task SaveEditableRuleAsync()
    {
        if (editableRule is null)
        {
            return;
        }

        isSaving = true;
        builderError = null;
        builderSuccess = null;

        try
        {
            if (editableRule.Id == Guid.Empty)
            {
                var created = await CdsService.CreateRuleAsync(editableRule);
                if (created is not null)
                {
                    editableRule = CloneRule(created);
                    builderSuccess = $"Created CDS draft '{created.Name}'.";
                    rules = await CdsService.ListRulesAsync();
                    selectedRuleVersions = [];
                }
                return;
            }

            var updated = await CdsService.UpdateRuleAsync(editableRule);
            if (updated is not null)
            {
                editableRule = CloneRule(updated);
                builderSuccess = $"Saved draft changes for '{updated.Name}'.";
                rules = await CdsService.ListRulesAsync();
            }
        }
        catch (Exception ex)
        {
            builderError = $"Failed to save rule: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task ValidateEditableRuleAsync()
    {
        if (editableRule is null)
        {
            return;
        }

        isValidating = true;
        builderError = null;

        try
        {
            validationResult = await CdsService.ValidateRuleAsync(editableRule);
        }
        catch (Exception ex)
        {
            builderError = $"Failed to validate rule: {ex.Message}";
        }
        finally
        {
            isValidating = false;
        }
    }

    private async Task PreviewEditableRuleAsync()
    {
        if (editableRule is null)
        {
            return;
        }

        isPreviewing = true;
        previewError = null;

        try
        {
            var context = JsonSerializer.Deserialize<JsonElement>(previewContextJson);
            JsonElement? prefetch = null;

            if (!string.IsNullOrWhiteSpace(previewPrefetchJson) && !string.Equals(previewPrefetchJson.Trim(), "null", StringComparison.OrdinalIgnoreCase))
            {
                prefetch = JsonSerializer.Deserialize<JsonElement>(previewPrefetchJson);
            }

            previewResponse = await CdsService.PreviewRuleAsync(new CdsRulePreviewRequestModel
            {
                Hook = editableRule.HookId,
                Rule = editableRule,
                Context = context,
                Prefetch = prefetch
            });
        }
        catch (Exception ex)
        {
            previewError = $"Failed to preview rule: {ex.Message}";
        }
        finally
        {
            isPreviewing = false;
        }
    }

    private async Task ToggleEditableRuleAsync()
    {
        if (!CanToggleEditableRule)
        {
            return;
        }

        var currentRule = editableRule;
        if (currentRule is null)
        {
            return;
        }

        isToggling = true;
        builderError = null;

        try
        {
            await CdsService.SetRuleActiveAsync(currentRule.Id, !currentRule.IsActive);
            currentRule.IsActive = !currentRule.IsActive;
            rules = await CdsService.ListRulesAsync();
        }
        catch (Exception ex)
        {
            builderError = $"Failed to toggle rule status: {ex.Message}";
        }
        finally
        {
            isToggling = false;
        }
    }

    private async Task ToggleStoredRuleAsync(CdsRuleSummary rule)
    {
        if (rule.PublishedVersionId is null || rule.Status != "Published")
        {
            return;
        }

        isToggling = true;
        builderError = null;

        try
        {
            await CdsService.SetRuleActiveAsync(rule.Id, !rule.IsActive);
            rules = await CdsService.ListRulesAsync();

            if (editableRule?.Id == rule.Id)
            {
                editableRule.IsActive = !rule.IsActive;
            }
        }
        catch (Exception ex)
        {
            builderError = $"Failed to toggle rule status: {ex.Message}";
        }
        finally
        {
            isToggling = false;
        }
    }

    private async Task PublishEditableRuleAsync()
    {
        if (!CanPublishEditableRule)
        {
            return;
        }

        isPublishing = true;
        builderError = null;
        builderSuccess = null;

        try
        {
            var published = await CdsService.PublishRuleAsync(editableRule!.Id);
            if (published is not null)
            {
                editableRule = CloneRule(published);
                selectedRuleVersions = await CdsService.ListRuleVersionsAsync(published.Id);
                rules = await CdsService.ListRulesAsync();
                builderSuccess = $"Published rule '{published.Name}' as version {published.PublishedVersionNumber}.";
            }
        }
        catch (Exception ex)
        {
            builderError = $"Failed to publish rule: {ex.Message}";
        }
        finally
        {
            isPublishing = false;
        }
    }

    private async Task PublishStoredRuleAsync(CdsRuleSummary rule)
    {
        isPublishing = true;
        builderError = null;

        try
        {
            var published = await CdsService.PublishRuleAsync(rule.Id);
            rules = await CdsService.ListRulesAsync();

            if (published is not null && editableRule?.Id == rule.Id)
            {
                editableRule = CloneRule(published);
                selectedRuleVersions = await CdsService.ListRuleVersionsAsync(rule.Id);
            }
        }
        catch (Exception ex)
        {
            builderError = $"Failed to publish rule: {ex.Message}";
        }
        finally
        {
            isPublishing = false;
        }
    }

    private async Task ArchiveEditableRuleAsync()
    {
        if (!CanArchiveEditableRule)
        {
            return;
        }

        isArchiving = true;
        builderError = null;
        builderSuccess = null;

        try
        {
            await CdsService.ArchiveRuleAsync(editableRule!.Id);
            rules = await CdsService.ListRulesAsync();
            var archived = rules.FirstOrDefault(r => r.Id == editableRule.Id);
            if (archived is not null)
            {
                editableRule = CloneRule(archived);
            }
            builderSuccess = "Archived the current rule.";
        }
        catch (Exception ex)
        {
            builderError = $"Failed to archive rule: {ex.Message}";
        }
        finally
        {
            isArchiving = false;
        }
    }

    private async Task CloneEditableRuleAsync()
    {
        if (!CanCloneEditableRule)
        {
            return;
        }

        isCloning = true;
        builderError = null;
        builderSuccess = null;

        try
        {
            var cloned = await CdsService.CloneRuleAsync(editableRule!.Id);
            if (cloned is not null)
            {
                rules = await CdsService.ListRulesAsync();
                await EditRuleAsync(cloned);
                builderSuccess = $"Cloned rule into draft '{cloned.Name}'.";
            }
        }
        catch (Exception ex)
        {
            builderError = $"Failed to clone rule: {ex.Message}";
        }
        finally
        {
            isCloning = false;
        }
    }

    private void ResetPreviewPayload()
    {
        previewContextJson = JsonSerializer.Serialize(
            BuildDefaultPreviewContext(templateModel.MedicationRxCui),
            new JsonSerializerOptions { WriteIndented = true });
        previewPrefetchJson = DefaultPreviewPrefetchJson;
    }

    private static object BuildDefaultPreviewContext(string? medicationRxCui)
    {
        var rxCui = string.IsNullOrWhiteSpace(medicationRxCui) ? "161" : medicationRxCui.Trim();
        var display = rxCui == "5640" ? "Ibuprofen (Advil)" : "Acetaminophen (Tylenol)";

        return new
        {
            patientId = "cds-test-patient",
            medicationRequest = new
            {
                resourceType = "MedicationRequest",
                medication = new
                {
                    concept = new
                    {
                        coding = new[]
                        {
                            new
                            {
                                system = "http://www.nlm.nih.gov/research/umls/rxnorm",
                                code = rxCui,
                                display
                            }
                        },
                        text = display
                    }
                },
                dosageInstruction = new[]
                {
                    new
                    {
                        doseAndRate = new[]
                        {
                            new
                            {
                                doseQuantity = new
                                {
                                    value = 1500,
                                    unit = "mg",
                                    code = "mg"
                                }
                            }
                        },
                        timing = new
                        {
                            repeat = new
                            {
                                frequency = 3,
                                period = 1,
                                periodUnit = "d"
                            }
                        }
                    }
                }
            }
        };
    }

    private static CdsRuleSummary CloneRule(CdsRuleSummary rule)
        => new()
        {
            Id = rule.Id,
            HookId = rule.HookId,
            Name = rule.Name,
            Description = rule.Description,
            Priority = rule.Priority,
            IsActive = rule.IsActive,
            Status = rule.Status,
            HasUnpublishedChanges = rule.HasUnpublishedChanges,
            PublishedVersionId = rule.PublishedVersionId,
            PublishedVersionNumber = rule.PublishedVersionNumber,
            PublishedAt = rule.PublishedAt,
            CreatedBy = rule.CreatedBy,
            UpdatedBy = rule.UpdatedBy,
            PublishedBy = rule.PublishedBy,
            ExpressionJson = rule.ExpressionJson,
            CardTemplateJson = rule.CardTemplateJson,
            CreatedAt = rule.CreatedAt,
            UpdatedAt = rule.UpdatedAt
        };

    private static string DisplayDose(decimal? dose) => dose is null ? "n/a" : $"{dose:0.##} mg";

    // ── Debounced auto-preview ─────────────────────────────────────────────────

    private Task OnExpressionJsonInput(ChangeEventArgs e)
    {
        if (editableRule is null) return Task.CompletedTask;
        editableRule.ExpressionJson = e.Value?.ToString() ?? string.Empty;
        return DebouncePreviewAsync();
    }

    private Task OnCardTemplateJsonInput(ChangeEventArgs e)
    {
        if (editableRule is null) return Task.CompletedTask;
        editableRule.CardTemplateJson = e.Value?.ToString() ?? string.Empty;
        return DebouncePreviewAsync();
    }

    private async Task DebouncePreviewAsync()
    {
        if (editableRule is null) return;

        _debounceCts?.Cancel();
        _debounceCts?.Dispose();
        _debounceCts = new CancellationTokenSource();
        var token = _debounceCts.Token;

        isAutoPreviewPending = true;

        try
        {
            await Task.Delay(800, token);

            if (!token.IsCancellationRequested)
            {
                isAutoPreviewPending = false;
                await PreviewEditableRuleAsync();
            }
        }
        catch (OperationCanceledException)
        {
            // A newer keystroke cancelled this debounce — do nothing.
        }
        finally
        {
            if (!token.IsCancellationRequested)
            {
                isAutoPreviewPending = false;
            }
        }
    }

    public void Dispose()
    {
        _debounceCts?.Cancel();
        _debounceCts?.Dispose();
    }
}
