@page "/external-ai/admin"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN")]
@using DMRS.Client.Features.ExternalAi.Models
@inherits DMRS.Client.Components.LocalizedComponentBase
@inject DMRS.Client.Features.ExternalAi.Services.ExternalAiFeatureService ExternalAiService

<PageTitle>@Loc["externalAi.panel.title"]</PageTitle>

<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
        <h1 class="mb-1">@Loc["externalAi.panel.title"]</h1>
        <p class="text-body-secondary mb-0">
            @Loc["externalAi.admin.subtitle"]
        </p>
    </div>
    <button class="btn btn-primary" @onclick="StartCreate" disabled="@isSaving">@Loc["externalAi.admin.register"]</button>
</div>

@if (!string.IsNullOrWhiteSpace(loadError))
{
    <div class="alert alert-danger">@loadError</div>
}

<div class="row g-4">
    <div class="@(editing is null ? "col-12" : "col-12 col-xl-7")">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                @if (isLoading)
                {
                    <div class="d-flex align-items-center gap-2 text-muted">
                        <div class="spinner-border spinner-border-sm" role="status"></div>
                        <span>@Loc["externalAi.admin.loading"]</span>
                    </div>
                }
                else if (models.Count == 0)
                {
                    <div class="dmrs-empty-state mb-0">@Loc["externalAi.admin.noneRegistered"]</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>@Loc["common.field.name"]</th>
                                    <th>@Loc["externalAi.admin.colEndpoint"]</th>
                                    <th>@Loc["externalAi.admin.colAuth"]</th>
                                    <th>@Loc["common.field.status"]</th>
                                    <th class="text-end">@Loc["common.actions"]</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var model in models)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">@model.Name</div>
                                            @if (!string.IsNullOrWhiteSpace(model.Description))
                                            {
                                                <div class="small text-muted">@model.Description</div>
                                            }
                                        </td>
                                        <td class="small text-break" style="max-width:260px;">@model.EndpointUrl</td>
                                        <td>
                                            <span class="badge bg-secondary">@model.AuthType</span>
                                            @if (model.AuthType != ExternalAiAuthType.None && model.HasSecret)
                                            {
                                                <span class="small text-success ms-1" title="@Loc["externalAi.admin.secretStored"]">🔒</span>
                                            }
                                        </td>
                                        <td>
                                            @if (model.IsActive)
                                            {
                                                <span class="badge bg-success">@Loc["externalAi.admin.active"]</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-light text-dark">@Loc["externalAi.admin.disabled"]</span>
                                            }
                                        </td>
                                        <td class="text-end">
                                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => StartEdit(model)">@Loc["common.edit"]</button>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(model)">@Loc["common.delete"]</button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

    @if (editing is not null)
    {
        <div class="col-12 col-xl-5">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white border-0 pb-0">
                    <h2 class="h5 mb-0">@(editingId is null ? Loc["externalAi.admin.registerTitle"] : Loc["externalAi.admin.editTitle"])</h2>
                </div>
                <div class="card-body">
                    <EditForm Model="editing" OnValidSubmit="SaveAsync">
                        <DataAnnotationsValidator />
                        <div class="mb-3">
                            <label class="form-label">@Loc["common.field.name"]</label>
                            <InputText @bind-Value="editing.Name" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">@Loc["common.field.description"]</label>
                            <InputTextArea @bind-Value="editing.Description" class="form-control" rows="2" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">@Loc["externalAi.admin.endpointLabel"]</label>
                            <InputText @bind-Value="editing.EndpointUrl" class="form-control" placeholder="https://…" />
                        </div>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">@Loc["externalAi.admin.authType"]</label>
                                <InputSelect @bind-Value="editing.AuthType" class="form-select">
                                    <option value="@ExternalAiAuthType.None">@Loc["externalAi.admin.authNone"]</option>
                                    <option value="@ExternalAiAuthType.ApiKey">@Loc["externalAi.admin.authApiKey"]</option>
                                    <option value="@ExternalAiAuthType.Bearer">@Loc["externalAi.admin.authBearer"]</option>
                                </InputSelect>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">@Loc["externalAi.admin.timeout"]</label>
                                <InputNumber @bind-Value="editing.TimeoutSeconds" class="form-control" />
                            </div>
                        </div>

                        @if (editing.AuthType == ExternalAiAuthType.ApiKey)
                        {
                            <div class="mt-3">
                                <label class="form-label">@Loc["externalAi.admin.apiKeyHeader"]</label>
                                <InputText @bind-Value="editing.AuthHeaderName" class="form-control" placeholder="X-API-Key" />
                            </div>
                        }

                        @if (editing.AuthType != ExternalAiAuthType.None)
                        {
                            <div class="mt-3">
                                <label class="form-label">@Loc["externalAi.admin.secret"] (@(editingId is null ? Loc["externalAi.admin.secretRequired"] : Loc["externalAi.admin.secretKeep"]))</label>
                                <InputText type="password" @bind-Value="editing.Secret" class="form-control" autocomplete="new-password" />
                            </div>
                        }

                        <div class="mt-3">
                            <label class="form-label">@Loc["externalAi.admin.decisionPath"]</label>
                            <InputText @bind-Value="editing.DecisionJsonPath" class="form-control" placeholder="e.g. result.label" />
                            <div class="form-text">@Loc["externalAi.admin.decisionPathHelp"]</div>
                        </div>

                        <div class="form-check mt-3">
                            <InputCheckbox @bind-Value="editing.IsActive" class="form-check-input" id="isActive" />
                            <label class="form-check-label" for="isActive">@Loc["externalAi.admin.active"]</label>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(formError))
                        {
                            <div class="alert alert-danger mt-3 mb-0">@formError</div>
                        }

                        <div class="d-flex gap-2 mt-4">
                            <button class="btn btn-primary" type="submit" disabled="@isSaving">
                                @(isSaving ? Loc["externalAi.admin.saving"] : Loc["common.save"])
                            </button>
                            <button class="btn btn-outline-secondary" type="button" @onclick="CancelEdit" disabled="@isSaving">@Loc["common.cancel"]</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private bool isSaving;
    private string? loadError;
    private string? formError;
    private List<ExternalAiModelDto> models = [];

    private ExternalAiModelInput? editing;
    private Guid? editingId;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        isLoading = true;
        loadError = null;
        try
        {
            models = (await ExternalAiService.ListModelsAsync()).ToList();
        }
        catch (Exception ex)
        {
            loadError = Loc["externalAi.admin.loadFailed", ex.Message];
        }
        finally
        {
            isLoading = false;
        }
    }

    private void StartCreate()
    {
        editingId = null;
        formError = null;
        editing = new ExternalAiModelInput();
    }

    private void StartEdit(ExternalAiModelDto model)
    {
        editingId = model.Id;
        formError = null;
        editing = new ExternalAiModelInput
        {
            Name = model.Name,
            Description = model.Description,
            EndpointUrl = model.EndpointUrl,
            AuthType = model.AuthType,
            AuthHeaderName = model.AuthHeaderName,
            Secret = null,
            TimeoutSeconds = model.TimeoutSeconds,
            DecisionJsonPath = model.DecisionJsonPath,
            IsActive = model.IsActive
        };
    }

    private void CancelEdit()
    {
        editing = null;
        editingId = null;
        formError = null;
    }

    private async Task SaveAsync()
    {
        if (editing is null)
        {
            return;
        }

        isSaving = true;
        formError = null;
        try
        {
            if (editingId is null)
            {
                await ExternalAiService.CreateModelAsync(editing);
            }
            else
            {
                await ExternalAiService.UpdateModelAsync(editingId.Value, editing);
            }

            CancelEdit();
            await LoadAsync();
        }
        catch (Exception ex)
        {
            formError = Loc["externalAi.admin.saveFailed", ex.Message];
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task DeleteAsync(ExternalAiModelDto model)
    {
        isSaving = true;
        try
        {
            await ExternalAiService.DeleteModelAsync(model.Id);
            if (editingId == model.Id)
            {
                CancelEdit();
            }
            await LoadAsync();
        }
        catch (Exception ex)
        {
            loadError = Loc["externalAi.admin.deleteFailed", ex.Message];
        }
        finally
        {
            isSaving = false;
        }
    }
}
