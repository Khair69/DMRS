@page "/appointments/{Id}"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN,ROLE_PRACTITIONER")]
@inherits DMRS.Client.Components.LocalizedComponentBase
@inject DMRS.Client.Features.Appointments.Services.AppointmentFeatureService AppointmentService

<PageTitle>@Loc["appointments.details.title"]</PageTitle>

<h1>@Loc["appointments.details.title"]</h1>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<div class="mb-3">
    <NavLink class="btn btn-sm btn-outline-secondary me-1" href="@($"/appointments/{Id}/edit")">@Loc["common.edit"]</NavLink>
    <NavLink class="btn btn-sm btn-outline-info" href="@($"/appointments/{Id}/history")">@Loc["common.history"]</NavLink>
</div>

<FhirJsonView Resource="appointment" />

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;

    private Hl7.Fhir.Model.Appointment? appointment;
    private string? errorMessage;

    protected override async Task OnParametersSetAsync()
    {
        errorMessage = null;
        try
        {
            appointment = await AppointmentService.GetAsync(Id);
            if (appointment is null)
            {
                errorMessage = Loc["appointments.notFound", Id];
            }
        }
        catch (Exception ex)
        {
            errorMessage = Loc["appointments.loadFailed", ex.Message];
        }
    }
}
