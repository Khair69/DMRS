@page "/appointments/{Id}/history"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN,ROLE_PRACTITIONER")]
@inherits DMRS.Client.Components.LocalizedComponentBase
@inject DMRS.Client.Features.Appointments.Services.AppointmentFeatureService AppointmentService

<PageTitle>@Loc["appointments.history.title"]</PageTitle>

<h1>@Loc["appointments.history.title"]</h1>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<FhirJsonListView Resources="historyResources" />

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;

    private IReadOnlyList<Hl7.Fhir.Model.Resource> historyResources = [];
    private string? errorMessage;

    protected override async Task OnParametersSetAsync()
    {
        errorMessage = null;

        try
        {
            var history = await AppointmentService.GetHistoryAsync(Id);
            historyResources = history.Cast<Hl7.Fhir.Model.Resource>().ToList();
        }
        catch (Exception ex)
        {
            errorMessage = Loc["common.historyLoadFailed", ex.Message];
            historyResources = [];
        }
    }
}
