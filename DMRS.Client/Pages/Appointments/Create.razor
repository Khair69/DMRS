@page "/appointments/new"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN,ROLE_PRACTITIONER")]
@inherits DMRS.Client.Components.LocalizedComponentBase
@inject DMRS.Client.Features.Appointments.Services.AppointmentFeatureService AppointmentService
@inject NavigationManager NavigationManager

<PageTitle>@Loc["appointments.create.title"]</PageTitle>

<h1>@Loc["appointments.create.title"]</h1>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<AppointmentForm Model="model" IsBusy="@isSaving" SubmitText="@Loc["appointments.create.submit"]" OnSave="Save" />

@code {
    private readonly DMRS.Client.Features.Appointments.Models.AppointmentEditModel model = new();
    private bool isSaving;
    private string? errorMessage;

    private async Task Save()
    {
        isSaving = true;
        errorMessage = null;
        try
        {
            var created = await AppointmentService.CreateAsync(model);
            if (created?.Id is null)
            {
                errorMessage = Loc["appointments.noIdReturned"];
                return;
            }

            NavigationManager.NavigateTo($"/appointments/{created.Id}");
        }
        catch (Exception ex)
        {
            errorMessage = Loc["appointments.createError", ex.Message];
        }
        finally
        {
            isSaving = false;
        }
    }
}
