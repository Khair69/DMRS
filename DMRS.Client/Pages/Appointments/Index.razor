@page "/appointments"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN,ROLE_PRACTITIONER")]
@inherits DMRS.Client.Components.LocalizedComponentBase
@using DMRS.Client.Features.Appointments.Models
@inject DMRS.Client.Features.Appointments.Services.AppointmentFeatureService AppointmentService

<PageTitle>@Loc["appointments.title"]</PageTitle>

<ResourceIndexPage TSummary="AppointmentSummaryViewModel"
                   Title="@Loc["appointments.title"]"
                   NewLink="/appointments/new"
                   NewLabel="@Loc["appointments.new"]"
                   EntityName="@Loc["appointments.entityName"]"
                   EmptyText="@Loc["appointments.empty"]"
                   SearchFields="SearchFieldList"
                   LoadDefault="cap => AppointmentService.ListAsync(cap)"
                   Search="(p, v) => AppointmentService.SearchAsync(p, v)">
    <HeaderTemplate>
        <th>@Loc["common.field.id"]</th>
        <th>@Loc["common.field.patient"]</th>
        <th>@Loc["common.field.status"]</th>
        <th>@Loc["common.field.start"]</th>
    </HeaderTemplate>
    <RowTemplate Context="appointment">
        <td><NavLink href="@($"/appointments/{appointment.Id}")">@appointment.Id</NavLink></td>
        <td>@appointment.PatientId</td>
        <td>@appointment.Status</td>
        <td>@appointment.Start</td>
    </RowTemplate>
</ResourceIndexPage>

@code {
    private IReadOnlyList<SearchField> SearchFieldList =>
    [
        new("patient", Loc["common.field.patient"], Loc["appointments.search.patient.placeholder"]),
        new("date", Loc["common.field.date"], Loc["appointments.search.date.placeholder"]),
    ];
}
