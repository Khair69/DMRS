@page "/observations"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN,ROLE_PRACTITIONER")]
@inherits DMRS.Client.Components.LocalizedComponentBase
@using DMRS.Client.Features.Observations.Models
@inject DMRS.Client.Features.Observations.Services.ObservationFeatureService ObservationService

<PageTitle>@Loc["observations.title"]</PageTitle>

<ResourceIndexPage TSummary="ObservationSummaryViewModel"
                   Title="@Loc["observations.title"]"
                   NewLink="/observations/new"
                   NewLabel="@Loc["observations.new"]"
                   EntityName="@Loc["observations.entityName"]"
                   EmptyText="@Loc["observations.empty"]"
                   SearchFields="SearchFieldList"
                   LoadDefault="cap => ObservationService.ListAsync(cap)"
                   Search="(p, v) => ObservationService.SearchAsync(p, v)">
    <HeaderTemplate>
        <th>@Loc["common.field.id"]</th>
        <th>@Loc["common.field.patient"]</th>
        <th>@Loc["common.field.code"]</th>
        <th>@Loc["common.field.status"]</th>
    </HeaderTemplate>
    <RowTemplate Context="observation">
        <td><NavLink href="@($"/observations/{observation.Id}")">@observation.Id</NavLink></td>
        <td>@observation.PatientId</td>
        <td>@observation.CodeText</td>
        <td>@observation.Status</td>
    </RowTemplate>
</ResourceIndexPage>

@code {
    private IReadOnlyList<SearchField> SearchFieldList =>
    [
        new("patient", Loc["common.field.patient"], Loc["observations.search.patient.placeholder"]),
        new("code", Loc["common.field.code"], Loc["observations.search.code.placeholder"]),
    ];
}
