@page "/observations"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN,ROLE_PRACTITIONER")]
@using DMRS.Client.Features.Observations.Models
@inject DMRS.Client.Features.Observations.Services.ObservationFeatureService ObservationService

<PageTitle>Observations</PageTitle>

<ResourceIndexPage TSummary="ObservationSummaryViewModel"
                   Title="Observations"
                   NewLink="/observations/new"
                   NewLabel="New Observation"
                   EntityName="observations"
                   EmptyText="No observations found."
                   SearchFields="_searchFields"
                   LoadDefault="cap => ObservationService.ListAsync(cap)"
                   Search="(p, v) => ObservationService.SearchAsync(p, v)">
    <HeaderTemplate>
        <th>Id</th>
        <th>Patient</th>
        <th>Code</th>
        <th>Status</th>
    </HeaderTemplate>
    <RowTemplate Context="observation">
        <td><NavLink href="@($"/observations/{observation.Id}")">@observation.Id</NavLink></td>
        <td>@observation.PatientId</td>
        <td>@observation.CodeText</td>
        <td>@observation.Status</td>
    </RowTemplate>
</ResourceIndexPage>

@code {
    private static readonly IReadOnlyList<SearchField> _searchFields =
    [
        new("patient", "Patient", "e.g. 123 (patient id)"),
        new("code", "Code", "e.g. 8867-4"),
    ];
}
