@page "/observations/{Id}/edit"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN,ROLE_PRACTITIONER")]
@inherits DMRS.Client.Components.LocalizedComponentBase
@inject DMRS.Client.Features.Observations.Services.ObservationFeatureService ObservationService
@inject NavigationManager Navigation

<PageTitle>@Loc["observations.edit.title"]</PageTitle>

<h1>@Loc["observations.edit.title"]</h1>

@if (isLoading)
{
    <div class="spinner-border" role="status"></div>
}
else
{
    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    <ObservationForm Model="model" IsBusy="@isSaving" SubmitText="@Loc["observations.edit.submit"]" OnSave="Save" />
}

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;

    private DMRS.Client.Features.Observations.Models.ObservationEditModel model = new();
    private bool isLoading;
    private bool isSaving;
    private string? errorMessage;

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var observation = await ObservationService.GetAsync(Id);
            if (observation is null)
            {
                errorMessage = Loc["observations.notFound", Id];
                return;
            }

            model = DMRS.Client.Features.Observations.Models.ObservationEditModel.FromObservation(observation);
        }
        catch (Exception ex)
        {
            errorMessage = Loc["observations.loadFailed", ex.Message];
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task Save()
    {
        errorMessage = null;
        isSaving = true;

        try
        {
            await ObservationService.UpdateAsync(Id, model);
            Navigation.NavigateTo($"/observations/{Id}");
        }
        catch (Exception ex)
        {
            errorMessage = Loc["observations.updateFailed", ex.Message];
        }
        finally
        {
            isSaving = false;
        }
    }
}
