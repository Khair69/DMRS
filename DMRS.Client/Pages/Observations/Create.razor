@page "/observations/new"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN,ROLE_PRACTITIONER")]
@inherits DMRS.Client.Components.LocalizedComponentBase
@inject DMRS.Client.Features.Observations.Services.ObservationFeatureService ObservationService
@inject NavigationManager NavigationManager

<PageTitle>@Loc["observations.create.title"]</PageTitle>

<h1>@Loc["observations.create.title"]</h1>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<ObservationForm Model="model" IsBusy="@isSaving" SubmitText="@Loc["observations.create.submit"]" OnSave="Save" />

@code {
    private readonly DMRS.Client.Features.Observations.Models.ObservationEditModel model = new();
    private bool isSaving;
    private string? errorMessage;

    private async Task Save()
    {
        isSaving = true;
        errorMessage = null;
        try
        {
            var created = await ObservationService.CreateAsync(model);
            if (created?.Id is null)
            {
                errorMessage = Loc["observations.noIdReturned"];
                return;
            }

            NavigationManager.NavigateTo($"/observations/{created.Id}");
        }
        catch (Exception ex)
        {
            errorMessage = Loc["observations.createError", ex.Message];
        }
        finally
        {
            isSaving = false;
        }
    }
}
