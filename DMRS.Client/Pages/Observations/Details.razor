@page "/observations/{Id}"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN,ROLE_PRACTITIONER")]
@inherits DMRS.Client.Components.LocalizedComponentBase
@inject DMRS.Client.Features.Observations.Services.ObservationFeatureService ObservationService

<PageTitle>@Loc["observations.details.title"]</PageTitle>

<h1>@Loc["observations.details.title"]</h1>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<div class="mb-3">
    <NavLink class="btn btn-sm btn-outline-secondary me-1" href="@($"/observations/{Id}/edit")">@Loc["common.edit"]</NavLink>
    <NavLink class="btn btn-sm btn-outline-info" href="@($"/observations/{Id}/history")">@Loc["common.history"]</NavLink>
</div>

<FhirJsonView Resource="observation" />

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;

    private Hl7.Fhir.Model.Observation? observation;
    private string? errorMessage;

    protected override async Task OnParametersSetAsync()
    {
        errorMessage = null;
        try
        {
            observation = await ObservationService.GetAsync(Id);
            if (observation is null)
            {
                errorMessage = Loc["observations.notFound", Id];
            }
        }
        catch (Exception ex)
        {
            errorMessage = Loc["observations.loadFailed", ex.Message];
        }
    }
}
