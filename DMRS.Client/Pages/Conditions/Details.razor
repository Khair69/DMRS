@page "/conditions/{Id}"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN,ROLE_PRACTITIONER")]
@inject DMRS.Client.Features.Conditions.Services.ConditionFeatureService ConditionService

<PageTitle>Condition Details</PageTitle>

<h1>Condition Details</h1>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<div class="mb-3">
    <NavLink class="btn btn-sm btn-outline-secondary me-1" href="@($"/conditions/{Id}/edit")">Edit</NavLink>
    <NavLink class="btn btn-sm btn-outline-info" href="@($"/conditions/{Id}/history")">History</NavLink>
</div>

<FhirJsonView Resource="condition" />

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;

    private Hl7.Fhir.Model.Condition? condition;
    private string? errorMessage;

    protected override async Task OnParametersSetAsync()
    {
        errorMessage = null;
        try
        {
            condition = await ConditionService.GetAsync(Id);
            if (condition is null)
            {
                errorMessage = $"Condition {Id} not found.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load condition: {ex.Message}";
        }
    }
}
