@page "/conditions/{Id}"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN,ROLE_PRACTITIONER")]
@inherits DMRS.Client.Components.LocalizedComponentBase
@inject DMRS.Client.Features.Conditions.Services.ConditionFeatureService ConditionService

<PageTitle>@Loc["conditions.details.title"]</PageTitle>

<h1>@Loc["conditions.details.title"]</h1>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<div class="mb-3">
    <NavLink class="btn btn-sm btn-outline-secondary me-1" href="@($"/conditions/{Id}/edit")">@Loc["common.edit"]</NavLink>
    <NavLink class="btn btn-sm btn-outline-info" href="@($"/conditions/{Id}/history")">@Loc["common.history"]</NavLink>
</div>

<FhirJsonView Resource="condition" />

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;

    private Hl7.Fhir.Model.Condition? condition;
    private string? errorMessage;

    protected override async Task OnParametersSetAsync()
    {
        errorMessage = null;
        try
        {
            condition = await ConditionService.GetAsync(Id);
            if (condition is null)
            {
                errorMessage = Loc["conditions.notFound", Id];
            }
        }
        catch (Exception ex)
        {
            errorMessage = Loc["conditions.loadFailed", ex.Message];
        }
    }
}
