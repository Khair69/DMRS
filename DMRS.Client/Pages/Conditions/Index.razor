@page "/conditions"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN,ROLE_PRACTITIONER")]
@using DMRS.Client.Features.Conditions.Models
@inject DMRS.Client.Features.Conditions.Services.ConditionFeatureService ConditionService

<PageTitle>Conditions</PageTitle>

<ResourceIndexPage TSummary="ConditionSummaryViewModel"
                   Title="Conditions"
                   NewLink="/conditions/new"
                   NewLabel="New Condition"
                   EntityName="conditions"
                   EmptyText="No conditions found."
                   SearchFields="_searchFields"
                   LoadDefault="cap => ConditionService.ListAsync(cap)"
                   Search="(p, v) => ConditionService.SearchAsync(p, v)">
    <HeaderTemplate>
        <th>Id</th>
        <th>Patient</th>
        <th>Code</th>
        <th>Status</th>
    </HeaderTemplate>
    <RowTemplate Context="condition">
        <td><NavLink href="@($"/conditions/{condition.Id}")">@condition.Id</NavLink></td>
        <td>@condition.PatientId</td>
        <td>@condition.CodeText</td>
        <td>@condition.ClinicalStatus</td>
    </RowTemplate>
</ResourceIndexPage>

@code {
    private static readonly IReadOnlyList<SearchField> _searchFields =
    [
        new("patient", "Patient", "e.g. 123 (patient id)"),
        new("code", "Code", "e.g. 38341003"),
    ];
}
