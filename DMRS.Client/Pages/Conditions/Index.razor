@page "/conditions"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN,ROLE_PRACTITIONER")]
@using DMRS.Client.Features.Conditions.Models
@inject DMRS.Client.Features.Conditions.Services.ConditionFeatureService ConditionService

<PageTitle>Conditions</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Conditions</h1>
    <NavLink class="btn btn-primary" href="/conditions/new">New Condition</NavLink>
</div>

<div class="card mb-3">
    <div class="card-body">
        <EditForm Model="this" OnSubmit="HandleSubmit">
            <div class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label">Search Field</label>
                    <InputSelect @bind-Value="searchParam" class="form-select">
                        <option value="patient">Patient</option>
                        <option value="code">Code</option>
                    </InputSelect>
                </div>
                <div class="col-md-7">
                    <label class="form-label">Search Value</label>
                    <InputText @bind-Value="searchValue" class="form-control" placeholder="e.g. Patient/123" />
                </div>
                <div class="col-md-2 d-grid">
                    <button class="btn btn-primary" disabled="@isBusy" type="submit">Search</button>
                </div>
            </div>
        </EditForm>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (conditions.Count == 0)
{
    <div class="alert alert-secondary">No conditions found.</div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Id</th>
                <th>Patient</th>
                <th>Code</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var condition in conditions)
            {
                <tr>
                    <td>
                        <NavLink href="@($"/conditions/{condition.Id}")">@condition.Id</NavLink>
                    </td>
                    <td>@condition.PatientId</td>
                    <td>@condition.CodeText</td>
                    <td>@condition.ClinicalStatus</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private string searchParam = "patient";
    private string searchValue = string.Empty;
    private bool isBusy;
    private string? errorMessage;
    private IReadOnlyList<ConditionSummaryViewModel> conditions = [];

    private async Task HandleSubmit()
    {
        errorMessage = null;
        isBusy = true;

        if (string.IsNullOrWhiteSpace(searchValue))
        {
            conditions = [];
            isBusy = false;
            return;
        }

        try
        {
            conditions = await ConditionService.SearchAsync(searchParam, searchValue);
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load conditions: {ex.Message}";
            conditions = [];
        }
        finally
        {
            isBusy = false;
        }
    }
}
