@page "/conditions"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN,ROLE_PRACTITIONER")]
@inherits DMRS.Client.Components.LocalizedComponentBase
@using DMRS.Client.Features.Conditions.Models
@inject DMRS.Client.Features.Conditions.Services.ConditionFeatureService ConditionService

<PageTitle>@Loc["conditions.title"]</PageTitle>

<ResourceIndexPage TSummary="ConditionSummaryViewModel"
                   Title="@Loc["conditions.title"]"
                   NewLink="/conditions/new"
                   NewLabel="@Loc["conditions.new"]"
                   EntityName="@Loc["conditions.entityName"]"
                   EmptyText="@Loc["conditions.empty"]"
                   SearchFields="SearchFieldList"
                   LoadDefault="cap => ConditionService.ListAsync(cap)"
                   Search="(p, v) => ConditionService.SearchAsync(p, v)">
    <HeaderTemplate>
        <th>@Loc["common.field.id"]</th>
        <th>@Loc["common.field.patient"]</th>
        <th>@Loc["common.field.code"]</th>
        <th>@Loc["common.field.status"]</th>
    </HeaderTemplate>
    <RowTemplate Context="condition">
        <td><NavLink href="@($"/conditions/{condition.Id}")">@condition.Id</NavLink></td>
        <td>@condition.PatientId</td>
        <td>@condition.CodeText</td>
        <td>@condition.ClinicalStatus</td>
    </RowTemplate>
</ResourceIndexPage>

@code {
    private IReadOnlyList<SearchField> SearchFieldList =>
    [
        new("patient", Loc["common.field.patient"], Loc["conditions.search.patient.placeholder"]),
        new("code", Loc["common.field.code"], Loc["conditions.search.code.placeholder"]),
    ];
}
