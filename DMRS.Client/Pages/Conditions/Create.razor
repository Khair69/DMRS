@page "/conditions/new"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN,ROLE_PRACTITIONER")]
@inherits DMRS.Client.Components.LocalizedComponentBase
@inject DMRS.Client.Features.Conditions.Services.ConditionFeatureService ConditionService
@inject NavigationManager NavigationManager

<PageTitle>@Loc["conditions.create.title"]</PageTitle>

<h1>@Loc["conditions.create.title"]</h1>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<ConditionForm Model="model" IsBusy="@isSaving" SubmitText="@Loc["conditions.create.submit"]" OnSave="Save" />

@code {
    private readonly DMRS.Client.Features.Conditions.Models.ConditionEditModel model = new();
    private bool isSaving;
    private string? errorMessage;

    // Prefill the patient when arriving from a patient's Quick Links (e.g. /conditions/new?patient={id}).
    [SupplyParameterFromQuery(Name = "patient")]
    private string? PatientId { get; set; }

    protected override void OnInitialized()
    {
        if (!string.IsNullOrWhiteSpace(PatientId))
        {
            model.PatientId = PatientId;
        }
    }

    private async Task Save()
    {
        isSaving = true;
        errorMessage = null;
        try
        {
            var created = await ConditionService.CreateAsync(model);
            if (created?.Id is null)
            {
                errorMessage = Loc["conditions.noIdReturned"];
                return;
            }

            NavigationManager.NavigateTo($"/conditions/{created.Id}");
        }
        catch (Exception ex)
        {
            errorMessage = Loc["conditions.createError", ex.Message];
        }
        finally
        {
            isSaving = false;
        }
    }
}
