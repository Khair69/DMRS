@page "/conditions/new"
@attribute [Authorize(Roles = "ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN,ROLE_PRACTITIONER")]
@inject DMRS.Client.Features.Conditions.Services.ConditionFeatureService ConditionService
@inject NavigationManager NavigationManager

<PageTitle>Create Condition</PageTitle>

<h1>Create Condition</h1>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<ConditionForm Model="model" IsBusy="@isSaving" SubmitText="Create Condition" OnSave="Save" />

@code {
    private readonly DMRS.Client.Features.Conditions.Models.ConditionEditModel model = new();
    private bool isSaving;
    private string? errorMessage;

    private async Task Save()
    {
        isSaving = true;
        errorMessage = null;
        try
        {
            var created = await ConditionService.CreateAsync(model);
            if (created?.Id is null)
            {
                errorMessage = "Condition was created but no id was returned.";
                return;
            }

            NavigationManager.NavigateTo($"/conditions/{created.Id}");
        }
        catch (Exception ex)
        {
            errorMessage = $"An error occurred while creating the condition: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }
}
