@using DMRS.Client.Features.Observations.Models
@inherits DMRS.Client.Components.LocalizedComponentBase

<EditForm Model="Model" OnValidSubmit="OnSubmit">
    <DataAnnotationsValidator />

    <div class="row g-3">
        <div class="col-md-4">
            <label class="form-label">@Loc["common.field.patientId"]</label>
            <InputText @bind-Value="Model.PatientId" class="form-control" />
            <ValidationMessage For="() => Model.PatientId" />
        </div>
        <div class="col-md-8">
            <label class="form-label">@Loc["common.field.code"]</label>
            <InputText @bind-Value="Model.CodeText" class="form-control" />
            <ValidationMessage For="() => Model.CodeText" />
        </div>
        <div class="col-md-4">
            <label class="form-label">@Loc["common.field.status"]</label>
            <InputSelect @bind-Value="Model.Status" class="form-select">
                <option value="registered">@Loc["observations.status.registered"]</option>
                <option value="preliminary">@Loc["observations.status.preliminary"]</option>
                <option value="final">@Loc["observations.status.final"]</option>
                <option value="amended">@Loc["observations.status.amended"]</option>
                <option value="cancelled">@Loc["observations.status.cancelled"]</option>
                <option value="unknown">@Loc["observations.status.unknown"]</option>
            </InputSelect>
        </div>
        <div class="col-md-4">
            <label class="form-label">@Loc["common.field.effectiveDate"]</label>
            <InputDate @bind-Value="Model.EffectiveDateTime" class="form-control" />
        </div>
        <div class="col-md-8">
            <label class="form-label">@Loc["common.field.value"]</label>
            <InputText @bind-Value="Model.ValueText" class="form-control" />
        </div>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary" disabled="@IsBusy">@SubmitText</button>
    </div>
</EditForm>

@code {
    [Parameter, EditorRequired]
    public ObservationEditModel Model { get; set; } = new();

    [Parameter]
    public string SubmitText { get; set; } = "Save Observation";

    [Parameter]
    public bool IsBusy { get; set; }

    [Parameter]
    public EventCallback OnSave { get; set; }

    private async Task OnSubmit()
    {
        await OnSave.InvokeAsync();
    }
}
