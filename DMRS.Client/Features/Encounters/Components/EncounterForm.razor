@using DMRS.Client.Features.Encounters.Models
@inherits DMRS.Client.Components.LocalizedComponentBase

<EditForm Model="Model" OnValidSubmit="OnSubmit">
    <DataAnnotationsValidator />

    <div class="row g-3">
        <div class="col-md-4">
            <label class="form-label">@Loc["common.field.patientId"]</label>
            <InputText @bind-Value="Model.PatientId" class="form-control" />
            <ValidationMessage For="() => Model.PatientId" />
        </div>
        <div class="col-md-4">
            <label class="form-label">@Loc["common.field.status"]</label>
            <InputSelect @bind-Value="Model.Status" class="form-select">
                <option value="planned">@Loc["common.status.planned"]</option>
                <option value="arrived">@Loc["common.status.arrived"]</option>
                <option value="triaged">@Loc["common.status.triaged"]</option>
                <option value="in-progress">@Loc["common.status.inProgress"]</option>
                <option value="onleave">@Loc["common.status.onleave"]</option>
                <option value="finished">@Loc["common.status.finished"]</option>
                <option value="cancelled">@Loc["common.status.cancelled"]</option>
                <option value="unknown">@Loc["common.status.unknown"]</option>
            </InputSelect>
        </div>
        <div class="col-md-4">
            <label class="form-label">@Loc["common.field.classCode"]</label>
            <InputText @bind-Value="Model.ClassCode" class="form-control" />
            <ValidationMessage For="() => Model.ClassCode" />
        </div>
        <div class="col-md-4">
            <label class="form-label">@Loc["common.field.start"]</label>
            <InputDate @bind-Value="Model.Start" class="form-control" />
        </div>
        <div class="col-md-4">
            <label class="form-label">@Loc["common.field.end"]</label>
            <InputDate @bind-Value="Model.End" class="form-control" />
        </div>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary" disabled="@IsBusy">@SubmitText</button>
    </div>
</EditForm>

@code {
    [Parameter, EditorRequired]
    public EncounterEditModel Model { get; set; } = new();

    [Parameter]
    public string SubmitText { get; set; } = "Save Encounter";

    [Parameter]
    public bool IsBusy { get; set; }

    [Parameter]
    public EventCallback OnSave { get; set; }

    private async Task OnSubmit()
    {
        await OnSave.InvokeAsync();
    }
}
