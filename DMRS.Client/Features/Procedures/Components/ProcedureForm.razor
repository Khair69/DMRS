@using DMRS.Client.Features.Procedures.Models

<EditForm Model="Model" OnValidSubmit="OnSubmit">
    <DataAnnotationsValidator />

    <div class="row g-3">
        <div class="col-md-4">
            <label class="form-label">Patient Id</label>
            <InputText @bind-Value="Model.PatientId" class="form-control" />
            <ValidationMessage For="() => Model.PatientId" />
        </div>
        <div class="col-md-8">
            <label class="form-label">Code</label>
            <InputText @bind-Value="Model.CodeText" class="form-control" />
            <ValidationMessage For="() => Model.CodeText" />
        </div>
        <div class="col-md-4">
            <label class="form-label">Status</label>
            <InputSelect @bind-Value="Model.Status" class="form-select">
                <option value="preparation">Preparation</option>
                <option value="in-progress">In Progress</option>
                <option value="not-done">Not Done</option>
                <option value="on-hold">On Hold</option>
                <option value="stopped">Stopped</option>
                <option value="completed">Completed</option>
                <option value="entered-in-error">Entered in Error</option>
                <option value="unknown">Unknown</option>
            </InputSelect>
        </div>
        <div class="col-md-4">
            <label class="form-label">Performed Date</label>
            <InputDate @bind-Value="Model.PerformedDateTime" class="form-control" />
        </div>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary" disabled="@IsBusy">@SubmitText</button>
    </div>
</EditForm>

@code {
    [Parameter, EditorRequired]
    public ProcedureEditModel Model { get; set; } = new();

    [Parameter]
    public string SubmitText { get; set; } = "Save Procedure";

    [Parameter]
    public bool IsBusy { get; set; }

    [Parameter]
    public EventCallback OnSave { get; set; }

    private async Task OnSubmit()
    {
        await OnSave.InvokeAsync();
    }
}
