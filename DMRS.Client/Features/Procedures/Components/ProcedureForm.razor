@using DMRS.Client.Features.Procedures.Models
@inherits DMRS.Client.Components.LocalizedComponentBase

<EditForm Model="Model" OnValidSubmit="OnSubmit">
    <DataAnnotationsValidator />

    <div class="row g-3">
        <div class="col-md-4">
            <label class="form-label">@Loc["common.field.patientId"]</label>
            <InputText @bind-Value="Model.PatientId" class="form-control" />
            <ValidationMessage For="() => Model.PatientId" />
        </div>
        <div class="col-md-8">
            <label class="form-label">@Loc["common.field.code"]</label>
            <InputText @bind-Value="Model.CodeText" class="form-control" />
            <ValidationMessage For="() => Model.CodeText" />
        </div>
        <div class="col-md-4">
            <label class="form-label">@Loc["common.field.status"]</label>
            <InputSelect @bind-Value="Model.Status" class="form-select">
                <option value="preparation">@Loc["common.status.preparation"]</option>
                <option value="in-progress">@Loc["common.status.inProgress"]</option>
                <option value="not-done">@Loc["common.status.notDone"]</option>
                <option value="on-hold">@Loc["common.status.onHold"]</option>
                <option value="stopped">@Loc["common.status.stopped"]</option>
                <option value="completed">@Loc["common.status.completed"]</option>
                <option value="entered-in-error">@Loc["common.status.enteredInError"]</option>
                <option value="unknown">@Loc["common.status.unknown"]</option>
            </InputSelect>
        </div>
        <div class="col-md-4">
            <label class="form-label">@Loc["common.field.performedDate"]</label>
            <InputDate @bind-Value="Model.PerformedDateTime" class="form-control" />
        </div>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary" disabled="@IsBusy">@SubmitText</button>
    </div>
</EditForm>

@code {
    [Parameter, EditorRequired]
    public ProcedureEditModel Model { get; set; } = new();

    [Parameter]
    public string SubmitText { get; set; } = "Save Procedure";

    [Parameter]
    public bool IsBusy { get; set; }

    [Parameter]
    public EventCallback OnSave { get; set; }

    private async Task OnSubmit()
    {
        await OnSave.InvokeAsync();
    }
}
