@using DMRS.Client.Features.ServiceRequests.Models
@inherits DMRS.Client.Components.LocalizedComponentBase

<EditForm Model="Model" OnValidSubmit="OnSubmit">
    <DataAnnotationsValidator />

    <div class="row g-3">
        <div class="col-md-4">
            <label class="form-label">@Loc["common.field.patientId"]</label>
            <InputText @bind-Value="Model.PatientId" class="form-control" />
            <ValidationMessage For="() => Model.PatientId" />
        </div>
        <div class="col-md-8">
            <label class="form-label">@Loc["common.field.code"]</label>
            <InputText @bind-Value="Model.CodeText" class="form-control" />
            <ValidationMessage For="() => Model.CodeText" />
        </div>
        <div class="col-md-4">
            <label class="form-label">@Loc["common.field.status"]</label>
            <InputSelect @bind-Value="Model.Status" class="form-select">
                <option value="draft">@Loc["common.status.draft"]</option>
                <option value="active">@Loc["common.status.active"]</option>
                <option value="on-hold">@Loc["common.status.onHold"]</option>
                <option value="revoked">@Loc["common.status.revoked"]</option>
                <option value="completed">@Loc["common.status.completed"]</option>
                <option value="entered-in-error">@Loc["common.status.enteredInError"]</option>
                <option value="unknown">@Loc["common.status.unknown"]</option>
            </InputSelect>
        </div>
        <div class="col-md-4">
            <label class="form-label">@Loc["common.field.intent"]</label>
            <InputSelect @bind-Value="Model.Intent" class="form-select">
                <option value="order">@Loc["medications.intent.order"]</option>
                <option value="plan">@Loc["medications.intent.plan"]</option>
                <option value="proposal">@Loc["medications.intent.proposal"]</option>
                <option value="original-order">@Loc["medications.intent.originalOrder"]</option>
                <option value="reflex-order">@Loc["medications.intent.reflexOrder"]</option>
                <option value="filler-order">@Loc["medications.intent.fillerOrder"]</option>
                <option value="instance-order">@Loc["medications.intent.instanceOrder"]</option>
                <option value="option">@Loc["medications.intent.option"]</option>
            </InputSelect>
        </div>
        <div class="col-md-4">
            <label class="form-label">@Loc["common.field.occurrenceDate"]</label>
            <InputDate @bind-Value="Model.OccurrenceDateTime" class="form-control" />
        </div>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary" disabled="@IsBusy">@SubmitText</button>
    </div>
</EditForm>

@code {
    [Parameter, EditorRequired]
    public ServiceRequestEditModel Model { get; set; } = new();

    [Parameter]
    public string SubmitText { get; set; } = "Save Service Request";

    [Parameter]
    public bool IsBusy { get; set; }

    [Parameter]
    public EventCallback OnSave { get; set; }

    private async Task OnSubmit()
    {
        await OnSave.InvokeAsync();
    }
}
