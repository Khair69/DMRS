@using DMRS.Client.Features.Dashboard
@using DMRS.Client.Features.Dashboard.Models
@using DMRS.Client.Features.Staff.Models
@inherits DMRS.Client.Components.LocalizedComponentBase
@inject DMRS.Client.Services.OrganizationContextService OrgContext
@inject DMRS.Client.Features.Organizations.Services.OrganizationFeatureService OrganizationService
@inject DMRS.Client.Features.Dashboard.Services.DashboardFeatureService DashboardService
@inject DMRS.Client.Features.Staff.Services.StaffFeatureService StaffService

@if (isLoading)
{
    <div class="dmrs-loading-shell">
        <div class="spinner-border text-primary" role="status"></div>
    </div>
}
else if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (organizationIds.Count == 0)
{
    <div class="alert alert-warning">
        @Loc["dashboard.orgAdmin.noOrg"]
    </div>
}
else
{
    <div class="workspace-hero">
        <div>
            <span class="workspace-eyebrow">@Loc["dashboard.orgAdmin.eyebrow"]</span>
            <h1>@orgHeading</h1>
            <p>@Loc["dashboard.orgAdmin.subtitle"]</p>
        </div>
        <div class="workspace-hero__actions">
            <a class="btn btn-light" href="@($"/organizations/{PrimaryOrgId}/staff/new")">@Loc["staff.index.invite"]</a>
            <a class="btn btn-outline-light" href="@($"/organizations/{PrimaryOrgId}/staff")">@Loc["organizations.manageStaff"]</a>
            <a class="btn btn-outline-light" href="@($"/organizations/{PrimaryOrgId}")">@Loc["dashboard.orgAdmin.viewOrganization"]</a>
        </div>
    </div>

    <section class="dmrs-metrics-grid">
        <a class="dmrs-metric-card metric-ocean" href="/patients">
            <div class="dmrs-metric-card__label">@Loc["dashboard.doctor.patients"]</div>
            <div class="dmrs-metric-card__value">@summary.Patients</div>
            <div class="dmrs-metric-card__helper">@Loc["dashboard.orgAdmin.inYourOrg"]</div>
        </a>
        <div class="dmrs-metric-card metric-ink">
            <div class="dmrs-metric-card__label">@Loc["dashboard.orgAdmin.practitioners"]</div>
            <div class="dmrs-metric-card__value">@roster.Count</div>
            <div class="dmrs-metric-card__helper">@Loc["dashboard.orgAdmin.practitionersHelper", doctorCount, adminCount]</div>
        </div>
        <a class="dmrs-metric-card metric-sky" href="/appointments">
            <div class="dmrs-metric-card__label">@Loc["nav.appointments"]</div>
            <div class="dmrs-metric-card__value">@upcomingAppointmentCount</div>
            <div class="dmrs-metric-card__helper">@Loc["dashboard.orgAdmin.appointmentsHelper"]</div>
        </a>
        <a class="dmrs-metric-card metric-gold" href="/medication-requests">
            <div class="dmrs-metric-card__label">@Loc["dashboard.metric.activeMeds"]</div>
            <div class="dmrs-metric-card__value">@summary.ActiveMedications</div>
            <div class="dmrs-metric-card__helper">@Loc["dashboard.metric.activeMedsHelper"]</div>
        </a>
        <a class="dmrs-metric-card metric-rose" href="/conditions">
            <div class="dmrs-metric-card__label">@Loc["nav.conditions"]</div>
            <div class="dmrs-metric-card__value">@summary.Conditions</div>
            <div class="dmrs-metric-card__helper">@Loc["dashboard.metric.conditionsHelper"]</div>
        </a>
        <a class="dmrs-metric-card metric-emerald" href="/service-requests">
            <div class="dmrs-metric-card__label">@Loc["nav.serviceRequests"]</div>
            <div class="dmrs-metric-card__value">@summary.ServiceRequests</div>
            <div class="dmrs-metric-card__helper">@Loc["dashboard.metric.serviceRequestsHelper"]</div>
        </a>
    </section>

    <section class="row g-4 mt-1">
        <div class="col-12 col-xl-7">
            <div class="dmrs-panel h-100">
                <div class="dmrs-panel__header">
                    <div>
                        <div class="dmrs-panel__title">@Loc["dashboard.orgAdmin.teamTitle"]</div>
                        <div class="dmrs-panel__subtitle">@Loc["dashboard.orgAdmin.teamSubtitle"]</div>
                    </div>
                    <a class="btn btn-sm btn-outline-primary" href="@($"/organizations/{PrimaryOrgId}/staff")">@Loc["organizations.manageStaff"]</a>
                </div>

                @if (staffNeedingAccounts > 0)
                {
                    <div class="alert alert-warning py-2 mb-2">
                        @Loc["dashboard.orgAdmin.needAccounts", staffNeedingAccounts]
                    </div>
                }

                @if (roster.Count == 0)
                {
                    <div class="dmrs-empty-state">@Loc["dashboard.orgAdmin.teamEmpty"]</div>
                }
                else
                {
                    <div class="dmrs-list">
                        @foreach (var member in roster.Take(8))
                        {
                            <a class="dmrs-list-item" href="@($"/organizations/{PrimaryOrgId}/staff/{member.PractitionerId}")">
                                <div style="min-width:0;">
                                    <div class="dmrs-list-item__title text-truncate">@member.DisplayName</div>
                                    <div class="dmrs-list-item__subtitle">@member.RoleDisplay@(string.IsNullOrWhiteSpace(member.Email) ? "" : $" · {member.Email}")</div>
                                </div>
                                @if (member.HasLoginAccount)
                                {
                                    <span class="dmrs-pill dmrs-pill--neutral" style="flex-shrink:0;">@Loc["staff.table.linked"]</span>
                                }
                                else
                                {
                                    <span class="dmrs-pill dmrs-pill--warning" style="flex-shrink:0;">@Loc["staff.table.noAccount"]</span>
                                }
                            </a>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="col-12 col-xl-5">
            <div class="dmrs-panel h-100">
                <div class="dmrs-panel__header">
                    <div>
                        <div class="dmrs-panel__title">@Loc["dashboard.watchlist.title"]</div>
                        <div class="dmrs-panel__subtitle">@Loc["dashboard.orgAdmin.watchlistSubtitle"]</div>
                    </div>
                    <a class="btn btn-sm btn-outline-primary" href="/ai-insights">@Loc["nav.aiInsights"]</a>
                </div>

                <div class="d-flex gap-3 mb-2" style="font-size:0.8rem;">
                    <span class="dmrs-pill dmrs-pill--danger">@highRiskCount @Loc["dashboard.level.high"]</span>
                    <span class="dmrs-pill dmrs-pill--warning">@mediumRiskCount @Loc["dashboard.level.medium"]</span>
                    <span class="dmrs-pill dmrs-pill--neutral">@lowRiskCount @Loc["dashboard.level.low"]</span>
                </div>

                @if (watchlist.Count == 0)
                {
                    <div class="dmrs-empty-state">@Loc["dashboard.noAssessable"]</div>
                }
                else
                {
                    <div class="dmrs-list">
                        @foreach (var patient in watchlist)
                        {
                            <a class="dmrs-list-item" href="@patient.Href">
                                <div style="min-width:0;">
                                    <div class="dmrs-list-item__title text-truncate">@patient.DisplayName</div>
                                    <div class="dmrs-list-item__subtitle">@DashboardText.WatchlistSummary(Loc, patient)</div>
                                </div>
                                <span class="dmrs-pill @RiskLevelPillClass(patient.RiskLevel)" style="flex-shrink:0;">@DashboardText.RiskLevel(Loc, patient.RiskLevel)</span>
                            </a>
                        }
                    </div>
                }
            </div>
        </div>
    </section>

    <section class="row g-4 mt-1">
        <div class="col-12">
            <div class="dmrs-panel">
                <div class="dmrs-panel__header">
                    <div>
                        <div class="dmrs-panel__title">@Loc["dashboard.recentAlerts.title"]</div>
                        <div class="dmrs-panel__subtitle">@Loc["dashboard.orgAdmin.alertsSubtitle"]</div>
                    </div>
                </div>
                @if (recentAlerts.Count == 0)
                {
                    <div class="dmrs-empty-state">@Loc["dashboard.orgAdmin.alertsEmpty"]</div>
                }
                else
                {
                    <div class="dmrs-list">
                        @foreach (var alert in recentAlerts.Take(8))
                        {
                            <a class="dmrs-list-item" href="/patients/@alert.PatientId">
                                <div style="min-width:0;">
                                    <div class="dmrs-list-item__title text-truncate">@alert.CardSummary</div>
                                    <div class="dmrs-list-item__subtitle">@alert.Hook · @TimeAgo(alert.FiredAt)</div>
                                </div>
                                <span class="dmrs-pill @IndicatorPillClass(alert.Indicator)" style="flex-shrink:0;">@alert.Indicator</span>
                            </a>
                        }
                    </div>
                }
            </div>
        </div>
    </section>
}

@code {
    private bool isLoading = true;
    private string? errorMessage;

    private IReadOnlyList<string> organizationIds = [];
    private string orgHeading = string.Empty;
    private string PrimaryOrgId => organizationIds.FirstOrDefault() ?? string.Empty;

    private DashboardSummaryModel summary = new();
    private List<StaffSummaryViewModel> roster = [];
    private List<DashboardWatchlistItemModel> watchlist = [];
    private List<CdsAlertEventModel> recentAlerts = [];

    private int upcomingAppointmentCount;
    private int highRiskCount;
    private int mediumRiskCount;
    private int lowRiskCount;

    private int doctorCount => roster.Count(m => string.Equals(m.RoleCode, StaffRoleCodes.Doctor, StringComparison.OrdinalIgnoreCase));
    private int adminCount => roster.Count(m => string.Equals(m.RoleCode, StaffRoleCodes.OrganizationAdmin, StringComparison.OrdinalIgnoreCase));
    private int staffNeedingAccounts => roster.Count(m => !m.HasLoginAccount);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            organizationIds = await OrgContext.GetOrganizationIdsAsync();
            if (organizationIds.Count == 0)
            {
                return;
            }

            // These three loads are independent. Running them concurrently (rather than awaiting
            // each in turn) stops the snapshot, staff roster, and org-header latencies from stacking
            // additively — the snapshot's own internal calls are already parallelized. The aggregate
            // endpoints are scoped server-side to this admin's organization(s).
            var snapshotTask = DashboardService.GetSnapshotAsync();
            var headingTask = LoadOrgHeadingAsync();
            var rosterTask = LoadRosterAsync();
            await Task.WhenAll(snapshotTask, headingTask, rosterTask);

            var snapshot = await snapshotTask;
            summary = new DashboardSummaryModel
            {
                Patients = CountMetric(snapshot, "Patients"),
                ActiveMedications = CountMetric(snapshot, "Active Meds"),
                Conditions = CountMetric(snapshot, "Conditions"),
                ServiceRequests = CountMetric(snapshot, "Service Requests"),
                Encounters = CountMetric(snapshot, "Encounters")
            };
            upcomingAppointmentCount = CountMetric(snapshot, "Appointments");
            watchlist = snapshot.HighRiskPatients;
            recentAlerts = snapshot.RecentAlerts;
            highRiskCount = snapshot.HighRiskCount;
            mediumRiskCount = snapshot.MediumRiskCount;
            lowRiskCount = snapshot.LowRiskCount;
        }
        catch (Exception ex)
        {
            errorMessage = Loc["dashboard.orgAdmin.loadFailed", ex.Message];
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadOrgHeadingAsync()
    {
        var names = new List<string>();
        foreach (var orgId in organizationIds)
        {
            try
            {
                var org = await OrganizationService.GetAsync(orgId);
                names.Add(string.IsNullOrWhiteSpace(org?.Name) ? orgId : org!.Name);
            }
            catch
            {
                names.Add(orgId);
            }
        }

        orgHeading = names.Count switch
        {
            0 => Loc["dashboard.orgAdmin.defaultHeading"],
            1 => names[0],
            _ => Loc["dashboard.orgHeadingMore", names[0], names.Count - 1]
        };
    }

    private async Task LoadRosterAsync()
    {
        var combined = new Dictionary<string, StaffSummaryViewModel>(StringComparer.OrdinalIgnoreCase);
        foreach (var orgId in organizationIds)
        {
            var staff = await StaffService.GetByOrganizationAsync(orgId, "ALL", null);
            foreach (var member in staff)
            {
                combined[member.PractitionerId] = member;
            }
        }

        roster = combined.Values
            .OrderBy(m => m.DisplayName, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    // The shared snapshot exposes tile values as strings; pull the ones we reuse back as ints.
    private static int CountMetric(DashboardSnapshotModel snapshot, string label)
    {
        var metric = snapshot.Metrics.FirstOrDefault(m => string.Equals(m.Label, label, StringComparison.OrdinalIgnoreCase));
        return metric is not null && int.TryParse(metric.Value, out var value) ? value : 0;
    }

    private static string RiskLevelPillClass(string riskLevel) => riskLevel switch
    {
        "High" => "dmrs-pill--danger",
        "Medium" => "dmrs-pill--warning",
        _ => "dmrs-pill--neutral"
    };

    private static string IndicatorPillClass(string indicator) => indicator switch
    {
        "hard-stop" => "dmrs-pill--danger",
        "warning" => "dmrs-pill--warning",
        _ => "dmrs-pill--neutral"
    };

    private string TimeAgo(DateTimeOffset firedAt)
    {
        var elapsed = DateTimeOffset.UtcNow - firedAt;
        if (elapsed.TotalSeconds < 60) return Loc["common.time.justNow"];
        if (elapsed.TotalMinutes < 60) return Loc["common.time.minutesAgo", (int)elapsed.TotalMinutes];
        if (elapsed.TotalHours < 24) return Loc["common.time.hoursAgo", (int)elapsed.TotalHours];
        return Loc["common.time.daysAgo", (int)elapsed.TotalDays];
    }
}
