@using DMRS.Client.Features.Dashboard
@using DMRS.Client.Features.Dashboard.Models
@inherits DMRS.Client.Components.LocalizedComponentBase
@inject DMRS.Client.Features.Dashboard.Services.DashboardFeatureService DashboardService
@inject DMRS.Client.Services.OrganizationContextService OrgContext
@inject DMRS.Client.Features.Organizations.Services.OrganizationFeatureService OrganizationService

<div class="workspace-hero">
    <div>
        <span class="workspace-eyebrow">@Loc["dashboard.doctor.eyebrow"]</span>
        <h1>@Loc["dashboard.doctor.title"]</h1>
        <p>@Loc["dashboard.doctor.subtitle"]</p>
        @if (!string.IsNullOrWhiteSpace(organizationName))
        {
            <p style="margin:0.35rem 0 0; font-weight:600; opacity:0.95;">
                <span style="opacity:0.75;">@Loc["dashboard.orgLabel"]</span> @organizationName
            </p>
        }
    </div>
    <div class="workspace-hero__actions">
        <a class="btn btn-light" href="/patients">@Loc["dashboard.doctor.allPatients"]</a>
        <a class="btn btn-outline-light" href="/appointments">@Loc["nav.appointments"]</a>
    </div>
</div>

<div style="display:flex; align-items:center; gap:0.75rem; margin:1.5rem 0 1.25rem;">
    <span style="color:var(--dmrs-muted); font-size:0.72rem; font-weight:700; letter-spacing:0.06em; text-transform:uppercase;">@Loc["dashboard.doctor.showing"]</span>
    <div role="group" aria-label="Patient scope"
         style="display:inline-flex; gap:4px; padding:4px; background:var(--dmrs-panel); border:1px solid var(--dmrs-border); border-radius:999px; box-shadow:var(--dmrs-shadow);">
        <button type="button" style="@SegStyle(mine)" disabled="@isLoading" @onclick="@(() => SetScope(true))">@Loc["dashboard.doctor.scopeMine"]</button>
        <button type="button" style="@SegStyle(!mine)" disabled="@isLoading" @onclick="@(() => SetScope(false))">@Loc["dashboard.doctor.scopeAllOrg"]</button>
    </div>
</div>

@if (isLoading)
{
    <div class="dmrs-loading-shell">
        <div class="spinner-border text-primary" role="status"></div>
    </div>
}
else if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
else
{
    <section class="dmrs-metrics-grid">
        <a class="dmrs-metric-card metric-ocean" href="/patients">
            <div class="dmrs-metric-card__label">@(mine ? Loc["dashboard.doctor.scopeMine"] : Loc["dashboard.doctor.patients"])</div>
            <div class="dmrs-metric-card__value">@snapshot.PatientCount</div>
            <div class="dmrs-metric-card__helper">@(mine ? Loc["dashboard.doctor.myPatientsHelper"] : Loc["dashboard.doctor.patientsHelper"])</div>
        </a>
        <a class="dmrs-metric-card metric-gold" href="/medication-requests">
            <div class="dmrs-metric-card__label">@Loc["dashboard.metric.activeMeds"]</div>
            <div class="dmrs-metric-card__value">@snapshot.ActiveMedications</div>
            <div class="dmrs-metric-card__helper">@Loc["dashboard.metric.activeMedsHelper"]</div>
        </a>
        <a class="dmrs-metric-card metric-rose" href="/conditions">
            <div class="dmrs-metric-card__label">@Loc["nav.conditions"]</div>
            <div class="dmrs-metric-card__value">@snapshot.Conditions</div>
            <div class="dmrs-metric-card__helper">@Loc["dashboard.metric.conditionsHelper"]</div>
        </a>
        <a class="dmrs-metric-card metric-emerald" href="/encounters">
            <div class="dmrs-metric-card__label">@Loc["nav.encounters"]</div>
            <div class="dmrs-metric-card__value">@snapshot.Encounters</div>
            <div class="dmrs-metric-card__helper">@Loc["dashboard.metric.encountersHelper"]</div>
        </a>
        <a class="dmrs-metric-card metric-ink" href="/service-requests">
            <div class="dmrs-metric-card__label">@Loc["nav.serviceRequests"]</div>
            <div class="dmrs-metric-card__value">@snapshot.ServiceRequests</div>
            <div class="dmrs-metric-card__helper">@Loc["dashboard.metric.serviceRequestsHelper"]</div>
        </a>
    </section>

    <section class="row g-4 mt-1">
        <div class="col-12 col-xl-7">
            <div class="dmrs-panel h-100">
                <div class="dmrs-panel__header">
                    <div>
                        <div class="dmrs-panel__title">@Loc["dashboard.watchlist.title"]</div>
                        <div class="dmrs-panel__subtitle">@(mine ? Loc["dashboard.doctor.watchlistMine"] : Loc["dashboard.doctor.watchlistOrg"])</div>
                    </div>
                    <div class="d-flex gap-2" style="font-size:0.8rem;">
                        <span class="dmrs-pill dmrs-pill--danger">@snapshot.HighRiskCount @Loc["dashboard.level.high"]</span>
                        <span class="dmrs-pill dmrs-pill--warning">@snapshot.MediumRiskCount @Loc["dashboard.level.medium"]</span>
                        <span class="dmrs-pill dmrs-pill--neutral">@snapshot.LowRiskCount @Loc["dashboard.level.low"]</span>
                    </div>
                </div>

                @if (snapshot.Watchlist.Count == 0)
                {
                    <div class="dmrs-empty-state">@Loc["dashboard.noAssessable"]</div>
                }
                else
                {
                    <div class="dmrs-list">
                        @foreach (var patient in snapshot.Watchlist)
                        {
                            <a class="dmrs-list-item" href="@patient.Href">
                                <div style="min-width:0;">
                                    <div class="dmrs-list-item__title text-truncate">@patient.DisplayName</div>
                                    <div class="dmrs-list-item__subtitle">@DashboardText.WatchlistSummary(Loc, patient)</div>
                                </div>
                                <span class="dmrs-pill @RiskLevelPillClass(patient.RiskLevel)" style="flex-shrink:0;">@DashboardText.RiskLevel(Loc, patient.RiskLevel)</span>
                            </a>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="col-12 col-xl-5">
            <div class="dmrs-panel h-100">
                <div class="dmrs-panel__header">
                    <div>
                        <div class="dmrs-panel__title">@Loc["dashboard.recentAlerts.title"]</div>
                        <div class="dmrs-panel__subtitle">@(mine ? Loc["dashboard.doctor.alertsMine"] : Loc["dashboard.doctor.alertsOrg"])</div>
                    </div>
                </div>
                @if (snapshot.RecentAlerts.Count == 0)
                {
                    <div class="dmrs-empty-state">@Loc["dashboard.alerts.empty"]</div>
                }
                else
                {
                    <div class="dmrs-list">
                        @foreach (var alert in snapshot.RecentAlerts.Take(8))
                        {
                            <a class="dmrs-list-item" href="/patients/@alert.PatientId">
                                <div style="min-width:0;">
                                    <div class="dmrs-list-item__title text-truncate">@alert.CardSummary</div>
                                    <div class="dmrs-list-item__subtitle">@alert.Hook · @TimeAgo(alert.FiredAt)</div>
                                </div>
                                <span class="dmrs-pill @IndicatorPillClass(alert.Indicator)" style="flex-shrink:0;">@alert.Indicator</span>
                            </a>
                        }
                    </div>
                }
            </div>
        </div>
    </section>
}

@code {
    private bool mine = true;
    private bool isLoading = true;
    private string? errorMessage;
    private string? organizationName;
    private DoctorSnapshotModel snapshot = new();

    protected override async Task OnInitializedAsync()
    {
        // Resolve the org label once, concurrently with the first data load.
        await Task.WhenAll(LoadOrganizationAsync(), LoadAsync());
    }

    private async Task LoadOrganizationAsync()
    {
        try
        {
            var organizationIds = await OrgContext.GetOrganizationIdsAsync();
            var names = new List<string>();
            foreach (var organizationId in organizationIds)
            {
                var org = await OrganizationService.GetAsync(organizationId);
                names.Add(string.IsNullOrWhiteSpace(org?.Name) ? organizationId : org!.Name);
            }

            organizationName = names.Count switch
            {
                0 => null,
                1 => names[0],
                _ => Loc["dashboard.orgHeadingMore", names[0], names.Count - 1]
            };
        }
        catch
        {
            organizationName = null;
        }
    }

    private async Task SetScope(bool scopeMine)
    {
        if (mine == scopeMine)
        {
            return;
        }

        mine = scopeMine;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        isLoading = true;
        errorMessage = null;
        try
        {
            snapshot = await DashboardService.GetDoctorSnapshotAsync(mine);
        }
        catch (Exception ex)
        {
            errorMessage = Loc["dashboard.doctor.loadFailed", ex.Message];
        }
        finally
        {
            isLoading = false;
        }
    }

    // Segmented-toggle button style, on-theme with the teal accent used across the dashboard.
    private static string SegStyle(bool active)
    {
        const string baseStyle = "border:none; border-radius:999px; padding:0.45rem 1.1rem; font-size:0.85rem; font-weight:600; cursor:pointer; transition:background .15s ease,color .15s ease,box-shadow .15s ease; white-space:nowrap;";
        return active
            ? baseStyle + "background:linear-gradient(135deg,#0f6d93,#0b8f86); color:#fff; box-shadow:0 6px 16px rgba(15,109,147,0.35);"
            : baseStyle + "background:transparent; color:var(--dmrs-muted);";
    }

    private static string RiskLevelPillClass(string riskLevel) => riskLevel switch
    {
        "High" => "dmrs-pill--danger",
        "Medium" => "dmrs-pill--warning",
        _ => "dmrs-pill--neutral"
    };

    private static string IndicatorPillClass(string indicator) => indicator switch
    {
        "hard-stop" => "dmrs-pill--danger",
        "warning" => "dmrs-pill--warning",
        _ => "dmrs-pill--neutral"
    };

    private string TimeAgo(DateTimeOffset firedAt)
    {
        var elapsed = DateTimeOffset.UtcNow - firedAt;
        if (elapsed.TotalSeconds < 60) return Loc["common.time.justNow"];
        if (elapsed.TotalMinutes < 60) return Loc["common.time.minutesAgo", (int)elapsed.TotalMinutes];
        if (elapsed.TotalHours < 24) return Loc["common.time.hoursAgo", (int)elapsed.TotalHours];
        return Loc["common.time.daysAgo", (int)elapsed.TotalDays];
    }
}
