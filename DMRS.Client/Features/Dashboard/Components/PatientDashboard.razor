@using Hl7.Fhir.Model
@using DMRS.Client.Features.Patients.Models
@using Task = System.Threading.Tasks.Task
@inject DMRS.Client.Features.Patients.Services.PatientPortalFeatureService PortalService

<div class="workspace-hero workspace-hero--patient">
    <div>
        <span class="workspace-eyebrow">Patient Portal</span>
        <h1>@Greeting</h1>
        <p>Your health summary, upcoming care, and everything in your medical record — all in one place.</p>
    </div>
    <div class="workspace-hero__actions">
        <a class="btn btn-light" href="/my-health">View My Records</a>
        <a class="btn btn-outline-light" href="/my-profile">Edit My Profile</a>
    </div>
</div>

@if (isLoading)
{
    <div class="dmrs-loading-shell">
        <div class="spinner-border text-primary" role="status"></div>
    </div>
}
else if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (model is null)
{
    <div class="dmrs-panel mt-4">
        <div class="dmrs-empty-state">
            We couldn't find a medical record linked to your account yet. If you recently received an
            invitation, please <a href="/patients/claim">claim it here</a>, or contact your clinic.
        </div>
    </div>
}
else
{
    <section class="dmrs-metrics-grid">
        <a class="dmrs-metric-card metric-sky" href="/my-health?tab=appointments">
            <div class="dmrs-metric-card__label">Upcoming Visits</div>
            <div class="dmrs-metric-card__value">@model.UpcomingAppointmentCount</div>
            <div class="dmrs-metric-card__helper">Scheduled appointments ahead</div>
        </a>
        <a class="dmrs-metric-card metric-gold" href="/my-health?tab=medications">
            <div class="dmrs-metric-card__label">Active Medications</div>
            <div class="dmrs-metric-card__value">@model.ActiveMedicationCount</div>
            <div class="dmrs-metric-card__helper">Currently on your plan</div>
        </a>
        <a class="dmrs-metric-card metric-emerald" href="/my-health?tab=conditions">
            <div class="dmrs-metric-card__label">Conditions</div>
            <div class="dmrs-metric-card__value">@model.ConditionCount</div>
            <div class="dmrs-metric-card__helper">Tracked in your record</div>
        </a>
        <a class="dmrs-metric-card metric-rose" href="/my-health?tab=allergies">
            <div class="dmrs-metric-card__label">Allergies</div>
            <div class="dmrs-metric-card__value">@model.AllergyCount</div>
            <div class="dmrs-metric-card__helper">Known allergies on file</div>
        </a>
    </section>

    <section class="row g-4 mt-1">
        <div class="col-12 col-xl-7">
            <div class="dmrs-panel h-100">
                <div class="dmrs-panel__header">
                    <div>
                        <div class="dmrs-panel__title">Upcoming Appointments</div>
                        <div class="dmrs-panel__subtitle">Your next scheduled visits and care moments.</div>
                    </div>
                    <a class="btn btn-sm btn-outline-primary" href="/my-health?tab=appointments">View all</a>
                </div>
                @if (model.UpcomingAppointments.Count == 0)
                {
                    <div class="dmrs-empty-state">You have no upcoming appointments scheduled.</div>
                }
                else
                {
                    <div class="dmrs-list">
                        @foreach (var appointment in model.UpcomingAppointments)
                        {
                            <div class="dmrs-list-item">
                                <div style="min-width:0;">
                                    <div class="dmrs-list-item__title text-truncate">@AppointmentLabel(appointment)</div>
                                    <div class="dmrs-list-item__subtitle">@appointment.SafeStatus()</div>
                                </div>
                                <span class="dmrs-list-item__meta">@AppointmentWhen(appointment)</span>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="col-12 col-xl-5">
            <div class="dmrs-panel h-100 @WellnessPanelClass">
                <div class="dmrs-panel__header">
                    <div>
                        <div class="dmrs-panel__title">@model.Wellness.Headline</div>
                        <div class="dmrs-panel__subtitle">A friendly look at how things are going.</div>
                    </div>
                    <span class="dmrs-pill @WellnessPillClass">@WellnessBadge</span>
                </div>
                <p class="mb-3">@model.Wellness.Message</p>
                @if (model.Wellness.Tips.Count > 0)
                {
                    <div class="dmrs-subpanel">
                        <div class="dmrs-subpanel__title">Helpful tips</div>
                        <ul class="mb-0 ps-3" style="line-height:1.9;">
                            @foreach (var tip in model.Wellness.Tips)
                            {
                                <li>@tip</li>
                            }
                        </ul>
                    </div>
                }
            </div>
        </div>
    </section>

    <section class="row g-4 mt-1">
        <div class="col-12 col-xl-7">
            <div class="dmrs-panel h-100">
                <div class="dmrs-panel__header">
                    <div>
                        <div class="dmrs-panel__title">Current Medications</div>
                        <div class="dmrs-panel__subtitle">Medications that are active on your care plan.</div>
                    </div>
                    <a class="btn btn-sm btn-outline-primary" href="/my-health?tab=medications">View all</a>
                </div>
                @if (model.ActiveMedications.Count == 0)
                {
                    <div class="dmrs-empty-state">No active medications are on file.</div>
                }
                else
                {
                    <div class="dmrs-list">
                        @foreach (var medication in model.ActiveMedications)
                        {
                            <div class="dmrs-list-item">
                                <div style="min-width:0;">
                                    <div class="dmrs-list-item__title text-truncate">@MedicationLabel(medication)</div>
                                    <div class="dmrs-list-item__subtitle">@DosageText(medication)</div>
                                </div>
                                <span class="dmrs-pill dmrs-pill--success">@medication.SafeStatus()</span>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="col-12 col-xl-5">
            <div class="dmrs-panel h-100">
                <div class="dmrs-panel__header">
                    <div>
                        <div class="dmrs-panel__title">Health Snapshot</div>
                        <div class="dmrs-panel__subtitle">Conditions and recent measurements.</div>
                    </div>
                </div>
                <div class="dmrs-subpanel">
                    <div class="dmrs-subpanel__title">Conditions</div>
                    @if (model.Conditions.Count == 0)
                    {
                        <div class="dmrs-empty-state dmrs-empty-state--inline">No conditions recorded.</div>
                    }
                    else
                    {
                        @foreach (var condition in model.Conditions)
                        {
                            <div class="dmrs-mini-row">
                                <div class="dmrs-mini-row__title">@ConditionLabel(condition)</div>
                                <div class="dmrs-mini-row__meta">@condition.ClinicalStatus?.Text</div>
                            </div>
                        }
                    }
                </div>
                <div class="dmrs-subpanel mt-3">
                    <div class="dmrs-subpanel__title">Recent Measurements</div>
                    @if (model.RecentObservations.Count == 0)
                    {
                        <div class="dmrs-empty-state dmrs-empty-state--inline">No recent measurements.</div>
                    }
                    else
                    {
                        @foreach (var observation in model.RecentObservations)
                        {
                            <div class="dmrs-mini-row">
                                <div class="dmrs-mini-row__title">@ObservationLabel(observation)</div>
                                <div class="dmrs-mini-row__meta">@ObservationValue(observation)</div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </section>
}

@code {
    private bool isLoading = true;
    private string? errorMessage;
    private PatientPortalDashboardModel? model;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            model = await PortalService.GetDashboardAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Unable to load your portal: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private string Greeting
    {
        get
        {
            var given = model?.Patient?.Name.FirstOrDefault()?.Given?.FirstOrDefault();
            return string.IsNullOrWhiteSpace(given) ? "Welcome back" : $"Welcome back, {given}";
        }
    }

    private string WellnessBadge => model?.Wellness.Tone switch
    {
        "attention" => "Stay connected",
        "watch" => "Keep it up",
        _ => "Looking good"
    };

    private string WellnessPillClass => model?.Wellness.Tone switch
    {
        "attention" => "dmrs-pill--warning",
        "watch" => "dmrs-pill--neutral",
        _ => "dmrs-pill--success"
    };

    private string WellnessPanelClass => model?.Wellness.Tone switch
    {
        "attention" => "dmrs-panel--accent-rose",
        _ => string.Empty
    };

    private static string AppointmentLabel(Appointment appointment)
        => appointment.Description
            ?? appointment.AppointmentType?.Text
            ?? appointment.AppointmentType?.Coding.FirstOrDefault()?.Display
            ?? "Appointment";

    private static string AppointmentWhen(Appointment appointment)
        => DateTimeOffset.TryParse(appointment.StartElement?.Value?.ToString(), out var start)
            ? start.ToLocalTime().ToString("ddd, dd MMM · HH:mm")
            : appointment.SafeStatus();

    private static string MedicationLabel(MedicationRequest medication)
        => medication.Medication?.Concept?.Text
            ?? medication.Medication?.Concept?.Coding.FirstOrDefault()?.Display
            ?? medication.Medication?.Concept?.Coding.FirstOrDefault()?.Code
            ?? "Medication";

    private static string DosageText(MedicationRequest medication)
    {
        var dosage = medication.DosageInstruction.FirstOrDefault();
        return dosage?.Text ?? "As directed";
    }

    private static string ConditionLabel(Condition condition)
        => condition.Code?.Text
            ?? condition.Code?.Coding.FirstOrDefault()?.Display
            ?? condition.Code?.Coding.FirstOrDefault()?.Code
            ?? "Condition";

    private static string ObservationLabel(Observation observation)
        => observation.Code?.Text
            ?? observation.Code?.Coding.FirstOrDefault()?.Display
            ?? observation.Code?.Coding.FirstOrDefault()?.Code
            ?? "Measurement";

    private static string ObservationValue(Observation observation)
    {
        if (observation.Value is Quantity quantity)
        {
            return $"{quantity.Value?.ToString("0.#")} {quantity.Unit}".Trim();
        }

        if (observation.Value is CodeableConcept concept)
        {
            return concept.Text ?? concept.Coding.FirstOrDefault()?.Display ?? observation.SafeStatus();
        }

        return observation.SafeStatus();
    }
}
