@using DMRS.Client.Features.Appointments.Models
@inherits DMRS.Client.Components.LocalizedComponentBase

<EditForm Model="Model" OnValidSubmit="OnSubmit">
    <DataAnnotationsValidator />

    <div class="row g-3">
        <div class="col-md-4">
            <label class="form-label">@Loc["common.field.patientId"]</label>
            <InputText @bind-Value="Model.PatientId" class="form-control" />
            <ValidationMessage For="() => Model.PatientId" />
        </div>
        <div class="col-md-4">
            <label class="form-label">@Loc["common.field.status"]</label>
            <InputSelect @bind-Value="Model.Status" class="form-select">
                <option value="proposed">@Loc["common.status.proposed"]</option>
                <option value="pending">@Loc["common.status.pending"]</option>
                <option value="booked">@Loc["common.status.booked"]</option>
                <option value="arrived">@Loc["common.status.arrived"]</option>
                <option value="fulfilled">@Loc["common.status.fulfilled"]</option>
                <option value="cancelled">@Loc["common.status.cancelled"]</option>
                <option value="noshow">@Loc["common.status.noshow"]</option>
                <option value="entered-in-error">@Loc["common.status.enteredInError"]</option>
            </InputSelect>
        </div>
        <div class="col-md-4">
            <label class="form-label">@Loc["common.field.start"]</label>
            <InputDate @bind-Value="Model.Start" class="form-control" />
        </div>
        <div class="col-md-4">
            <label class="form-label">@Loc["common.field.end"]</label>
            <InputDate @bind-Value="Model.End" class="form-control" />
        </div>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary" disabled="@IsBusy">@SubmitText</button>
    </div>
</EditForm>

@code {
    [Parameter, EditorRequired]
    public AppointmentEditModel Model { get; set; } = new();

    [Parameter]
    public string SubmitText { get; set; } = "Save Appointment";

    [Parameter]
    public bool IsBusy { get; set; }

    [Parameter]
    public EventCallback OnSave { get; set; }

    private async Task OnSubmit()
    {
        await OnSave.InvokeAsync();
    }
}
