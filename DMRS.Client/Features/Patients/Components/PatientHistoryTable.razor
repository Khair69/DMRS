@using Hl7.Fhir.Model
@inherits DMRS.Client.Components.LocalizedComponentBase

@if (History.Count == 0)
{
    <div class="alert alert-secondary">@Loc["patients.history.empty"]</div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>@Loc["common.field.version"]</th>
                <th>@Loc["common.field.lastUpdated"]</th>
                <th>@Loc["common.field.name"]</th>
                <th>@Loc["common.field.gender"]</th>
                <th>@Loc["common.field.birthDate"]</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var version in History)
            {
                var name = version.Name.FirstOrDefault();

                <tr>
                    <td>@version.Meta?.VersionId</td>
                    <td>@version.Meta?.LastUpdated?.ToString("u")</td>
                    <td>@string.Join(" ", name?.Given ?? []) @name?.Family</td>
                    <td>@version.Gender.ToString()</td>
                    <td>@version.BirthDate</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    [Parameter, EditorRequired]
    public IReadOnlyList<Patient> History { get; set; } = [];
}
