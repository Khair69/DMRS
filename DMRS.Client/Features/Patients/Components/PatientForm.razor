@using DMRS.Client.Features.Patients.Models

<EditForm Model="Model" OnValidSubmit="OnSubmit">
    <DataAnnotationsValidator />

    <div class="row g-3">
        <div class="col-md-6">
            <label class="form-label">Given Name</label>
            <InputText @bind-Value="Model.GivenName" class="form-control" />
            <ValidationMessage For="() => Model.GivenName" />
        </div>
        <div class="col-md-6">
            <label class="form-label">Family Name</label>
            <InputText @bind-Value="Model.FamilyName" class="form-control" />
            <ValidationMessage For="() => Model.FamilyName" />
        </div>
        <div class="col-md-4">
            <label class="form-label">Gender</label>
            <InputSelect @bind-Value="Model.Gender" class="form-select">
                <option value="Unknown">Unknown</option>
                <option value="Male">Male</option>
                <option value="Female">Female</option>
                <option value="Other">Other</option>
            </InputSelect>
        </div>
        <div class="col-md-4">
            <label class="form-label">Birth Date</label>
            <InputDate @bind-Value="Model.BirthDate" class="form-control" />
            <ValidationMessage For="() => Model.BirthDate" />
        </div>
        <div class="col-md-4">
            <label class="form-label">Identifier System</label>
            <InputText @bind-Value="Model.IdentifierSystem" class="form-control" />
        </div>
        <div class="col-md-6">
            <label class="form-label">Identifier Value</label>
            <InputText @bind-Value="Model.IdentifierValue" class="form-control" />
        </div>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary" disabled="@IsBusy">@SubmitText</button>
    </div>
</EditForm>

@code {
    [Parameter, EditorRequired]
    public PatientEditModel Model { get; set; } = new();

    [Parameter]
    public string SubmitText { get; set; } = "Save Patient";

    [Parameter]
    public bool IsBusy { get; set; }

    [Parameter]
    public EventCallback OnSave { get; set; }

    private async Task OnSubmit()
    {
        await OnSave.InvokeAsync();
    }
}
