@using Hl7.Fhir.Model
@inherits DMRS.Client.Components.LocalizedComponentBase

@if (History.Count == 0)
{
    <div class="alert alert-secondary">@Loc["organizations.history.empty"]</div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>@Loc["common.field.version"]</th>
                <th>@Loc["common.field.lastUpdated"]</th>
                <th>@Loc["common.field.name"]</th>
                <th>@Loc["common.field.active"]</th>
                <th>@Loc["common.field.email"]</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var version in History)
            {
                var email = version.Contact
                    .SelectMany(c => c.Telecom)
                    .FirstOrDefault(t => t.System == ContactPoint.ContactPointSystem.Email)
                    ?.Value;

                <tr>
                    <td>@version.Meta?.VersionId</td>
                    <td>@version.Meta?.LastUpdated?.ToString("u")</td>
                    <td>@version.Name</td>
                    <td>@version.Active</td>
                    <td>@email</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    [Parameter, EditorRequired]
    public IReadOnlyList<Organization> History { get; set; } = [];
}
