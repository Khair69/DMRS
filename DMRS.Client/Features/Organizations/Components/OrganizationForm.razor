@using DMRS.Client.Features.Organizations.Models

<EditForm Model="Model" OnValidSubmit="OnSubmit">
    <DataAnnotationsValidator />

    <div class="row g-3">
        <div class="col-md-8">
            <label class="form-label">Organization Name</label>
            <InputText @bind-Value="Model.Name" class="form-control" />
            <ValidationMessage For="() => Model.Name" />
        </div>
        <div class="col-md-4">
            <label class="form-label">Alias</label>
            <InputText @bind-Value="Model.Alias" class="form-control" />
        </div>
        <div class="col-md-3 d-flex align-items-end">
            <div class="form-check">
                <InputCheckbox @bind-Value="Model.Active" class="form-check-input" />
                <label class="form-check-label">Active</label>
            </div>
        </div>
        <div class="col-md-5">
            <label class="form-label">Identifier System</label>
            <InputText @bind-Value="Model.IdentifierSystem" class="form-control" />
        </div>
        <div class="col-md-4">
            <label class="form-label">Identifier Value</label>
            <InputText @bind-Value="Model.IdentifierValue" class="form-control" />
        </div>
        <div class="col-md-6">
            <label class="form-label">Email</label>
            <InputText @bind-Value="Model.Email" class="form-control" />
            <ValidationMessage For="() => Model.Email" />
        </div>
        <div class="col-md-6">
            <label class="form-label">Phone</label>
            <InputText @bind-Value="Model.Phone" class="form-control" />
        </div>
        <div class="col-md-12">
            <label class="form-label">Address Line</label>
            <InputText @bind-Value="Model.AddressLine" class="form-control" />
        </div>
        <div class="col-md-3">
            <label class="form-label">City</label>
            <InputText @bind-Value="Model.City" class="form-control" />
        </div>
        <div class="col-md-3">
            <label class="form-label">State</label>
            <InputText @bind-Value="Model.State" class="form-control" />
        </div>
        <div class="col-md-3">
            <label class="form-label">Postal Code</label>
            <InputText @bind-Value="Model.PostalCode" class="form-control" />
        </div>
        <div class="col-md-3">
            <label class="form-label">Country</label>
            <InputText @bind-Value="Model.Country" class="form-control" />
        </div>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary" disabled="@IsBusy">@SubmitText</button>
    </div>
</EditForm>

@code {
    [Parameter, EditorRequired]
    public OrganizationEditModel Model { get; set; } = new();

    [Parameter]
    public string SubmitText { get; set; } = "Save Organization";

    [Parameter]
    public bool IsBusy { get; set; }

    [Parameter]
    public EventCallback OnSave { get; set; }

    private async Task OnSubmit()
    {
        await OnSave.InvokeAsync();
    }
}
