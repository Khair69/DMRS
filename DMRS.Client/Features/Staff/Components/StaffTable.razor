@using DMRS.Client.Features.Staff.Models
@inherits DMRS.Client.Components.LocalizedComponentBase

@if (Staff.Count == 0)
{
    <div class="alert alert-secondary">@Loc["staff.table.empty"]</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>@Loc["common.field.name"]</th>
                    <th>@Loc["common.field.specialty"]</th>
                    <th>@Loc["common.field.phone"]</th>
                    <th>@Loc["common.field.role"]</th>
                    <th>@Loc["common.field.active"]</th>
                    <th>@Loc["common.field.login"]</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var staff in Staff)
                {
                    <tr>
                        <td>@staff.DisplayName</td>
                        <td>@(string.IsNullOrWhiteSpace(staff.Specialty) ? "—" : staff.Specialty)</td>
                        <td>@staff.Phone</td>
                        <td>
                            <span class="badge @(staff.RoleCode == StaffRoleCodes.OrganizationAdmin ? "bg-warning text-dark" : "bg-primary")">
                                @staff.RoleDisplay
                            </span>
                        </td>
                        <td>@staff.Active</td>
                        <td>
                            @if (staff.HasLoginAccount)
                            {
                                <span class="badge bg-success">@Loc["staff.table.linked"]</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">@Loc["staff.table.noAccount"]</span>
                            }
                        </td>
                        <td>
                            <NavLink class="btn btn-sm btn-outline-primary" href="@($"/organizations/{OrganizationId}/staff/{staff.PractitionerId}")">@Loc["common.details"]</NavLink>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    [Parameter, EditorRequired]
    public string OrganizationId { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public IReadOnlyList<StaffSummaryViewModel> Staff { get; set; } = [];
}
