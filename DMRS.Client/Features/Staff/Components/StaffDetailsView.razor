@using Hl7.Fhir.Model
@using DMRS.Client.Features.Staff.Services
@inherits DMRS.Client.Components.LocalizedComponentBase

@if (Practitioner is null)
{
    <div class="alert alert-warning">@Loc["staff.detailsView.notFound"]</div>
}
else
{
    var name = Practitioner.Name.FirstOrDefault();
    var email = Practitioner.Telecom.FirstOrDefault(t => t.System == ContactPoint.ContactPointSystem.Email)?.Value;
    var phone = Practitioner.Telecom.FirstOrDefault(t => t.System == ContactPoint.ContactPointSystem.Phone)?.Value;

    <div class="card">
        <div class="card-header">
            @Loc["staff.detailsView.practitioner"] @Practitioner.Id
        </div>
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">@Loc["common.field.name"]</dt>
                <dd class="col-sm-9">@string.Join(" ", name?.Given ?? []) @name?.Family</dd>

                <dt class="col-sm-3">@Loc["common.field.email"]</dt>
                <dd class="col-sm-9">@email</dd>

                <dt class="col-sm-3">@Loc["common.field.phone"]</dt>
                <dd class="col-sm-9">@phone</dd>

                <dt class="col-sm-3">@Loc["common.field.active"]</dt>
                <dd class="col-sm-9">@Practitioner.Active</dd>
            </dl>
        </div>
    </div>

    <div class="card mt-3">
        <div class="card-header">@Loc["staff.detailsView.roles"]</div>
        <div class="card-body">
            @if (Roles.Count == 0)
            {
                <div class="alert alert-secondary mb-0">@Loc["staff.detailsView.noRoles"]</div>
            }
            else
            {
                <table class="table table-sm mb-0">
                    <thead>
                        <tr>
                            <th>@Loc["common.field.role"]</th>
                            <th>@Loc["common.field.organization"]</th>
                            <th>@Loc["common.field.active"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var role in Roles)
                        {
                            var coding = role.Code.SelectMany(c => c.Coding).FirstOrDefault();
                            var roleName = coding?.Display ?? role.Code.FirstOrDefault()?.Text ?? coding?.Code ?? Loc["staff.detailsView.roleUnknown"];
                            <tr>
                                <td>@roleName</td>
                                <td>@role.Organization?.Reference</td>
                                <td>@role.Active</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>

    var linkedUsername = GetLinkedUsername();
    var hasAccount = HasLinkedAccount();

    <div class="card mt-3">
        <div class="card-header">@Loc["staff.detailsView.loginAccount"]</div>
        <div class="card-body">
            @if (ProvisionedCredentials is not null)
            {
                <div class="alert alert-success mb-0">
                    <div class="fw-semibold mb-1">@Loc["staff.detailsView.accountCreated"]</div>
                    <div>@Loc["staff.detailsView.username"] <code>@ProvisionedCredentials.Username</code></div>
                    <div>@Loc["staff.detailsView.password"] <code>@ProvisionedCredentials.Password</code></div>
                    <div class="small text-muted mt-1">@Loc["staff.detailsView.roleLabel"] @ProvisionedCredentials.AssignedRealmRole</div>
                </div>
            }
            else if (hasAccount)
            {
                <div class="alert alert-success mb-0">
                    <span class="fw-semibold">@Loc["staff.detailsView.accountLinked"]</span>
                    @if (!string.IsNullOrWhiteSpace(linkedUsername))
                    {
                        <span> @Loc["staff.detailsView.usernameInline"] <code>@linkedUsername</code></span>
                    }
                </div>
            }
            else
            {
                <p class="text-muted">@Loc["staff.detailsView.noAccountYet"]</p>

                @if (!string.IsNullOrWhiteSpace(ProvisionError))
                {
                    <div class="alert alert-danger">@ProvisionError</div>
                }

                <AuthorizeView Roles="ROLE_SYSTEM_ADMIN,ROLE_ORG_ADMIN">
                    <button type="button" class="btn btn-primary" disabled="@IsProvisioning" @onclick="OnProvisionAccount">
                        @if (IsProvisioning)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                            <span>@Loc["staff.detailsView.creatingAccount"]</span>
                        }
                        else
                        {
                            <span>@Loc["staff.detailsView.createAccount"]</span>
                        }
                    </button>
                </AuthorizeView>
            }
        </div>
    </div>
}

@code {
    [Parameter]
    public Practitioner? Practitioner { get; set; }

    [Parameter, EditorRequired]
    public IReadOnlyList<PractitionerRole> Roles { get; set; } = [];

    [Parameter]
    public EventCallback OnProvisionAccount { get; set; }

    [Parameter]
    public bool IsProvisioning { get; set; }

    [Parameter]
    public StaffProvisionResult? ProvisionedCredentials { get; set; }

    [Parameter]
    public string? ProvisionError { get; set; }

    private bool HasLinkedAccount()
    {
        return Practitioner?.Identifier?.Any(i =>
            !string.IsNullOrWhiteSpace(i.System)
            && i.System.EndsWith("/users", StringComparison.OrdinalIgnoreCase)) == true;
    }

    private string? GetLinkedUsername()
    {
        return Practitioner?.Identifier?
            .FirstOrDefault(i => !string.IsNullOrWhiteSpace(i.System)
                && i.System.EndsWith("/users/username", StringComparison.OrdinalIgnoreCase))?
            .Value;
    }
}
