@using DMRS.Client.Features.Staff.Models
@inherits DMRS.Client.Components.LocalizedComponentBase

<div class="card mb-3">
    <div class="card-body">
        <EditForm Model="this" OnSubmit="HandleSubmit">
            <div class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label">@Loc["common.field.role"]</label>
                    <InputSelect @bind-Value="RoleFilter" class="form-select">
                        <option value="ALL">@Loc["staff.search.all"]</option>
                        <option value="@StaffRoleCodes.Doctor">@Loc["staff.search.doctors"]</option>
                        <option value="@StaffRoleCodes.OrganizationAdmin">@Loc["staff.search.orgAdmins"]</option>
                    </InputSelect>
                </div>
                <div class="col-md-7">
                    <label class="form-label">@Loc["common.search"]</label>
                    <InputText @bind-Value="TextFilter" class="form-control" placeholder="@Loc["staff.search.placeholder"]" />
                </div>
                <div class="col-md-2 d-grid">
                    <button class="btn btn-primary" disabled="@IsBusy" type="submit">@Loc["common.search"]</button>
                </div>
            </div>
        </EditForm>
    </div>
</div>

@code {
    [Parameter]
    public string RoleFilter { get; set; } = "ALL";

    [Parameter]
    public string TextFilter { get; set; } = string.Empty;

    [Parameter]
    public bool IsBusy { get; set; }

    [Parameter]
    public EventCallback<(string RoleFilter, string TextFilter)> OnSearch { get; set; }

    private async Task HandleSubmit()
    {
        await OnSearch.InvokeAsync((RoleFilter, TextFilter));
    }
}
