@using DMRS.Client.Features.Staff.Models
@using DMRS.Shared.Constants
@inherits DMRS.Client.Components.LocalizedComponentBase

<EditForm Model="Model" OnValidSubmit="OnSubmit">
    <DataAnnotationsValidator />

    <div class="row g-3">
        <div class="col-md-6">
            <label class="form-label">@Loc["common.field.givenName"]</label>
            <InputText @bind-Value="Model.GivenName" class="form-control" />
            <ValidationMessage For="() => Model.GivenName" />
        </div>
        <div class="col-md-6">
            <label class="form-label">@Loc["common.field.familyName"]</label>
            <InputText @bind-Value="Model.FamilyName" class="form-control" />
            <ValidationMessage For="() => Model.FamilyName" />
        </div>
        <div class="col-md-6">
            <label class="form-label">@Loc["common.field.email"]</label>
            <InputText @bind-Value="Model.Email" class="form-control" />
            <ValidationMessage For="() => Model.Email" />
        </div>
        <div class="col-md-6">
            <label class="form-label">@Loc["common.field.phone"]</label>
            <InputText @bind-Value="Model.Phone" class="form-control" />
        </div>
        <div class="col-md-6">
            <label class="form-label">@Loc["common.field.identifierSystem"]</label>
            <InputSelect @bind-Value="Model.IdentifierSystem" class="form-select">
                <option value="@PractitionerIdentifierSystems.NationalId">@Loc["staff.form.identifierSystem.nationalId"]</option>
                <option value="@PractitionerIdentifierSystems.Passport">@Loc["staff.form.identifierSystem.passport"]</option>
                <option value="@PractitionerIdentifierSystems.MedicalLicense">@Loc["staff.form.identifierSystem.medicalLicense"]</option>
            </InputSelect>
        </div>
        <div class="col-md-6">
            <label class="form-label">@Loc["common.field.identifierValue"]</label>
            <InputText @bind-Value="Model.IdentifierValue" class="form-control" />
        </div>
        <div class="col-md-4">
            <label class="form-label">@Loc["common.field.role"]</label>
            <InputSelect @bind-Value="Model.RoleCode" class="form-select" @onchange="HandleRoleChange">
                <option value="@StaffRoleCodes.Doctor">@Loc["staff.role.doctor"]</option>
                <option value="@StaffRoleCodes.OrganizationAdmin">@Loc["staff.role.orgAdmin"]</option>
            </InputSelect>
        </div>
        <div class="col-md-4">
            <label class="form-label">@Loc["common.field.roleDisplay"]</label>
            <InputText @bind-Value="Model.RoleDisplay" class="form-control" />
        </div>
        <div class="col-md-4">
            <label class="form-label">@Loc["common.field.roleSystem"]</label>
            <InputText @bind-Value="Model.RoleSystem" class="form-control" />
        </div>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary" disabled="@IsBusy">@SubmitText</button>
    </div>
</EditForm>

@code {
    [Parameter, EditorRequired]
    public StaffInviteEditModel Model { get; set; } = new();

    [Parameter]
    public string SubmitText { get; set; } = "Create Invitation";

    [Parameter]
    public bool IsBusy { get; set; }

    [Parameter]
    public EventCallback OnSave { get; set; }

    private async Task OnSubmit()
    {
        await OnSave.InvokeAsync();
    }

    private void HandleRoleChange(ChangeEventArgs _)
    {
        Model.RoleDisplay = string.Equals(Model.RoleCode, StaffRoleCodes.OrganizationAdmin, StringComparison.OrdinalIgnoreCase)
            ? "Organization Administrator"
            : "Doctor";
    }
}
