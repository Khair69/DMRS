@using DMRS.Client.Features.Locations.Models
@inherits DMRS.Client.Components.LocalizedComponentBase

<EditForm Model="Model" OnValidSubmit="OnSubmit">
    <DataAnnotationsValidator />

    <div class="row g-3">
        <div class="col-md-6">
            <label class="form-label">@Loc["common.field.name"]</label>
            <InputText @bind-Value="Model.Name" class="form-control" />
            <ValidationMessage For="() => Model.Name" />
        </div>
        <div class="col-md-4">
            <label class="form-label">@Loc["common.field.status"]</label>
            <InputSelect @bind-Value="Model.Status" class="form-select">
                <option value="active">@Loc["common.status.active"]</option>
                <option value="suspended">@Loc["common.status.suspended"]</option>
                <option value="inactive">@Loc["common.status.inactive"]</option>
                <option value="unknown">@Loc["common.status.unknown"]</option>
            </InputSelect>
        </div>
        <div class="col-md-6">
            <label class="form-label">@Loc["common.field.managingOrgId"]</label>
            <InputText @bind-Value="Model.ManagingOrganizationId" class="form-control" />
        </div>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary" disabled="@IsBusy">@SubmitText</button>
    </div>
</EditForm>

@code {
    [Parameter, EditorRequired]
    public LocationEditModel Model { get; set; } = new();

    [Parameter]
    public string SubmitText { get; set; } = "Save Location";

    [Parameter]
    public bool IsBusy { get; set; }

    [Parameter]
    public EventCallback OnSave { get; set; }

    private async Task OnSubmit()
    {
        await OnSave.InvokeAsync();
    }
}
