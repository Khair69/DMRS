@using DMRS.Client.Features.Conditions.Models
@inherits DMRS.Client.Components.LocalizedComponentBase

<EditForm Model="Model" OnValidSubmit="OnSubmit">
    <DataAnnotationsValidator />

    <div class="row g-3">
        <div class="col-md-4">
            <PatientNumberInput @bind-Value="Model.PatientId" />
            <ValidationMessage For="() => Model.PatientId" />
        </div>
        <div class="col-md-8">
            <label class="form-label">@Loc["common.field.code"]</label>
            <InputText @bind-Value="Model.CodeText" class="form-control" />
            <div class="form-text">@Loc["common.field.codeTextHint"]</div>
            <ValidationMessage For="() => Model.CodeText" />
        </div>
        <div class="col-md-6">
            <label class="form-label">@Loc["common.field.clinicalStatus"]</label>
            <InputSelect @bind-Value="Model.ClinicalStatus" class="form-select">
                <option value="">@Loc["common.status.notSpecified"]</option>
                <option value="active">@Loc["common.status.active"]</option>
                <option value="recurrence">@Loc["common.status.recurrence"]</option>
                <option value="relapse">@Loc["common.status.relapse"]</option>
                <option value="inactive">@Loc["common.status.inactive"]</option>
                <option value="remission">@Loc["common.status.remission"]</option>
                <option value="resolved">@Loc["common.status.resolved"]</option>
            </InputSelect>
            <div class="form-text">@Loc["common.field.clinicalStatusHint"]</div>
        </div>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary" disabled="@IsBusy">@SubmitText</button>
    </div>
</EditForm>

@code {
    [Parameter, EditorRequired]
    public ConditionEditModel Model { get; set; } = new();

    [Parameter]
    public string SubmitText { get; set; } = "Save Condition";

    [Parameter]
    public bool IsBusy { get; set; }

    [Parameter]
    public EventCallback OnSave { get; set; }

    private async Task OnSubmit()
    {
        await OnSave.InvokeAsync();
    }
}
