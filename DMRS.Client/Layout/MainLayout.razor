@inherits LayoutComponentBase
@implements IDisposable
@inject DMRS.Client.Services.LocalizationService Loc

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4 auth">
            <div class="top-row__intro">
                <div class="top-row__title">@Loc["app.title"]</div>
                <div class="top-row__subtitle">@Loc["app.subtitle"]</div>
            </div>
            <div class="top-row__actions">
                <LanguageSwitcher />
                <LoginDisplay />
            </div>
        </div>

        <article class="content px-4 py-4">
            @Body
        </article>
    </main>
</div>

@code {
    protected override void OnInitialized() => Loc.OnChange += OnLanguageChanged;

    private void OnLanguageChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => Loc.OnChange -= OnLanguageChanged;
}
