@using Hl7.Fhir.Model
@using Hl7.Fhir.Serialization
@inherits DMRS.Client.Components.LocalizedComponentBase
@inject FhirJsonSerializer Serializer

@if (Resource is null)
{
    <div class="alert alert-secondary">@Loc["common.json.noResource"]</div>
}
else
{
    <pre class="bg-light p-3 border rounded">@Serializer.SerializeToString(Resource)</pre>
}

@code {
    [Parameter]
    public Resource? Resource { get; set; }
}
