@typeparam TItem

@ChildContent(PageItems)

@if (_totalItems > PageSize)
{
    <nav aria-label="Pagination" class="dmrs-paginator d-flex justify-content-between align-items-center flex-wrap gap-2 mt-3">
        <small class="text-muted">
            Showing @_rangeStart–@_rangeEnd of @_totalItems
        </small>
        <ul class="pagination mb-0">
            <li class="page-item @(_currentPage == 1 ? "disabled" : null)">
                <button type="button" class="page-link" aria-label="Previous"
                        disabled="@(_currentPage == 1)" @onclick="() => GoToPage(_currentPage - 1)">
                    &laquo;
                </button>
            </li>
            @foreach (var page in _pageNumbers)
            {
                <li class="page-item @(page == _currentPage ? "active" : null)">
                    <button type="button" class="page-link" @onclick="() => GoToPage(page)">@(page)</button>
                </li>
            }
            <li class="page-item @(_currentPage == _totalPages ? "disabled" : null)">
                <button type="button" class="page-link" aria-label="Next"
                        disabled="@(_currentPage == _totalPages)" @onclick="() => GoToPage(_currentPage + 1)">
                    &raquo;
                </button>
            </li>
        </ul>
    </nav>
}

@code {
    // Generic, presentation-only paginator: it slices an already-loaded list and renders the
    // current page through ChildContent. It does NOT fetch — the API returns the whole result set
    // in one bundle (no server-side paging), so this trims what the browser renders, not the fetch.

    [Parameter, EditorRequired]
    public IReadOnlyList<TItem> Items { get; set; } = [];

    [Parameter, EditorRequired]
    public RenderFragment<IReadOnlyList<TItem>> ChildContent { get; set; } = default!;

    [Parameter]
    public int PageSize { get; set; } = 10;

    // How many numbered page buttons to show at once, centred on the current page.
    private const int PageWindow = 5;

    private int _currentPage = 1;
    private int _totalItems;
    private int _totalPages = 1;
    private int _rangeStart;
    private int _rangeEnd;
    private IReadOnlyList<int> _pageNumbers = [];
    private IReadOnlyList<TItem> PageItems = [];
    private IReadOnlyList<TItem>? _lastItems;

    protected override void OnParametersSet()
    {
        // A new search swaps in a different list instance — reset to the first page so the user
        // isn't stranded on a page that no longer exists.
        if (!ReferenceEquals(_lastItems, Items))
        {
            _currentPage = 1;
            _lastItems = Items;
        }

        Recalculate();
    }

    private void Recalculate()
    {
        var pageSize = PageSize < 1 ? 1 : PageSize;
        _totalItems = Items?.Count ?? 0;
        _totalPages = Math.Max(1, (int)Math.Ceiling(_totalItems / (double)pageSize));
        _currentPage = Math.Clamp(_currentPage, 1, _totalPages);

        var skip = (_currentPage - 1) * pageSize;
        PageItems = Items is null ? [] : Items.Skip(skip).Take(pageSize).ToList();

        _rangeStart = _totalItems == 0 ? 0 : skip + 1;
        _rangeEnd = Math.Min(skip + pageSize, _totalItems);
        _pageNumbers = BuildPageNumbers();
    }

    private IReadOnlyList<int> BuildPageNumbers()
    {
        var start = Math.Max(1, _currentPage - PageWindow / 2);
        var end = Math.Min(_totalPages, start + PageWindow - 1);
        start = Math.Max(1, end - PageWindow + 1);

        var pages = new List<int>(end - start + 1);
        for (var p = start; p <= end; p++)
        {
            pages.Add(p);
        }
        return pages;
    }

    private void GoToPage(int page)
    {
        _currentPage = Math.Clamp(page, 1, _totalPages);
        Recalculate();
    }
}
