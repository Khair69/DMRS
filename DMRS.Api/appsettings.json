{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=DMRS;Username=postgres;Password=mkhroot"
  },
  "Keycloak": {
    "Authority": "http://localhost:8080/realms/DMRS",
    "Realm": "DMRS",
    "ClientId": "dmrs-api",
    "AdminApiBaseUrl": "http://localhost:8080",
    "AdminRealm": "master",
    "AdminClientId": "admin-cli",
    "AdminUsername": "admin",
    "AdminPassword": "admin"
  },
  "Cds": {
    "Knowledge": {
      "CacheTtlDays": 30,
      "RxNorm": {
        "BaseUrl": "https://rxnav.nlm.nih.gov/REST/"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "DMRS": "Debug"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.json",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      },
      {
        "Name": "Console"
      }
    ]
  },
  "AllowedHosts": "*"
}


