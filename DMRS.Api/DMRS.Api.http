### 1. Verify mock medicine API by RxCUI
GET {{MedicineInfo_HostAddress}}/api/medications/161
Accept: application/json

### 2. Verify mock medicine API by name
GET {{MedicineInfo_HostAddress}}/api/medications/Acetaminophen
Accept: application/json

### 3. Refresh local normalized medicine knowledge
POST {{DMRS.Api_HostAddress}}/cds/medications/161/refresh
Authorization: Bearer {{BearerToken}}
Accept: application/json

### 4. Read normalized medicine knowledge
GET {{DMRS.Api_HostAddress}}/cds/medications/161
Authorization: Bearer {{BearerToken}}
Accept: application/json

### 5. Search normalized medicine knowledge by name
GET {{DMRS.Api_HostAddress}}/cds/medications?q=acetaminophen
Authorization: Bearer {{BearerToken}}
Accept: application/json

### 6. Search normalized medicine knowledge by ingredient code
GET {{DMRS.Api_HostAddress}}/cds/medications?ingredient=UNII-L960UP28W1
Authorization: Bearer {{BearerToken}}
Accept: application/json

### 7. List CDS rule variables
GET {{DMRS.Api_HostAddress}}/cds/rules/variables
Authorization: Bearer {{BearerToken}}
Accept: application/json

### 8. List supported rule templates
GET {{DMRS.Api_HostAddress}}/cds/rules/templates
Authorization: Bearer {{BearerToken}}
Accept: application/json

### 9. Compile a max-dose template into a raw rule definition
POST {{DMRS.Api_HostAddress}}/cds/rules/templates/compile
Authorization: Bearer {{BearerToken}}
Content-Type: application/json
Accept: application/json

{
  "templateId": "max-dose-exceeded",
  "hookId": "medication-prescribe",
  "name": "High acetaminophen daily dose from template",
  "description": "Compiled from template.",
  "priority": 1,
  "isActive": true,
  "indicator": "warning",
  "sourceLabel": "DMRS CDS Template",
  "sourceUrl": "http://localhost:5210/cds/medications/{{medication.rxCui}}",
  "medicationRxCui": "161"
}

### 10. Create a persisted rule directly from a template
POST {{DMRS.Api_HostAddress}}/cds/rules/templates
Authorization: Bearer {{BearerToken}}
Content-Type: application/json
Accept: application/json

{
  "templateId": "allergy-conflict",
  "hookId": "medication-prescribe",
  "name": "Allergy conflict from template",
  "description": "Persisted from template.",
  "priority": 2,
  "isActive": true,
  "indicator": "hard-stop",
  "sourceLabel": "DMRS CDS Template"
}

### 11. Validate a valid CDS rule
POST {{DMRS.Api_HostAddress}}/cds/rules/validate
Authorization: Bearer {{BearerToken}}
Content-Type: application/json
Accept: application/json

{
  "id": "00000000-0000-0000-0000-000000000001",
  "hookId": "medication-prescribe",
  "name": "High acetaminophen daily dose",
  "description": "Warn when requested daily dose exceeds max daily dose.",
  "priority": 1,
  "isActive": true,
  "expressionJson": "{\"and\":[{\">\":[{\"var\":\"dose.requestedDailyMg\"},{\"var\":\"dose.maxDailyMg\"}]},{\"==\":[{\"var\":\"medication.rxCui\"},\"161\"]}]}",
  "cardTemplateJson": "{\"summary\":\"Dose too high for {{medication.name}}\",\"detail\":\"Requested {{dose.requestedDailyMg}} mg/day exceeds max {{dose.maxDailyMg}} mg/day.\",\"indicator\":\"warning\",\"source\":{\"label\":\"DMRS CDS\",\"url\":\"http://localhost:5210/cds/medications/{{medication.rxCui}}\"}}"
}

### 12. Validate an invalid CDS rule
POST {{DMRS.Api_HostAddress}}/cds/rules/validate
Authorization: Bearer {{BearerToken}}
Content-Type: application/json
Accept: application/json

{
  "id": "00000000-0000-0000-0000-000000000099",
  "hookId": "medication-prescribe",
  "name": "Invalid operator test",
  "description": "Should fail validation.",
  "priority": 99,
  "isActive": true,
  "expressionJson": "{\"contains\":[{\"var\":\"medication.ingredients\"},\"UNII-L960UP28W1\"]}",
  "cardTemplateJson": "{\"summary\":\"Invalid rule\",\"indicator\":\"info\",\"source\":{\"label\":\"DMRS CDS\"}}"
}

### 13. Preview max-dose rule against derived medication context
POST {{DMRS.Api_HostAddress}}/cds/rules/preview
Authorization: Bearer {{BearerToken}}
Content-Type: application/json
Accept: application/json

{
  "hook": "medication-prescribe",
  "rule": {
    "id": "00000000-0000-0000-0000-000000000001",
    "hookId": "medication-prescribe",
    "name": "High acetaminophen daily dose",
    "description": "Warn when requested daily dose exceeds max daily dose.",
    "priority": 1,
    "isActive": true,
    "expressionJson": "{\"and\":[{\">\":[{\"var\":\"dose.requestedDailyMg\"},{\"var\":\"dose.maxDailyMg\"}]},{\"==\":[{\"var\":\"medication.rxCui\"},\"161\"]}]}",
    "cardTemplateJson": "{\"summary\":\"Dose too high for {{medication.name}}\",\"detail\":\"Requested {{dose.requestedDailyMg}} mg/day exceeds max {{dose.maxDailyMg}} mg/day.\",\"indicator\":\"warning\",\"source\":{\"label\":\"DMRS CDS\",\"url\":\"http://localhost:5210/cds/medications/{{medication.rxCui}}\"}}"
  },
  "context": {
    "patientId": "cds-test-patient",
    "medicationRequest": {
      "resourceType": "MedicationRequest",
      "medication": {
        "concept": {
          "coding": [
            {
              "system": "http://www.nlm.nih.gov/research/umls/rxnorm",
              "code": "161",
              "display": "Acetaminophen (Tylenol)"
            }
          ],
          "text": "Acetaminophen (Tylenol)"
        }
      },
      "dosageInstruction": [
        {
          "doseAndRate": [
            {
              "doseQuantity": {
                "value": 1500,
                "unit": "mg",
                "code": "mg"
              }
            }
          ],
          "timing": {
            "repeat": {
              "frequency": 3,
              "period": 1,
              "periodUnit": "d"
            }
          }
        }
      ]
    }
  },
  "prefetch": null
}

### 14. Create the max-dose rule
POST {{DMRS.Api_HostAddress}}/cds/rules
Authorization: Bearer {{BearerToken}}
Content-Type: application/json
Accept: application/json

{
  "id": "11111111-1111-1111-1111-111111111111",
  "hookId": "medication-prescribe",
  "name": "High acetaminophen daily dose",
  "description": "Warn when requested daily dose exceeds max daily dose.",
  "priority": 1,
  "isActive": true,
  "expressionJson": "{\"and\":[{\">\":[{\"var\":\"dose.requestedDailyMg\"},{\"var\":\"dose.maxDailyMg\"}]},{\"==\":[{\"var\":\"medication.rxCui\"},\"161\"]}]}",
  "cardTemplateJson": "{\"summary\":\"Dose too high for {{medication.name}}\",\"detail\":\"Requested {{dose.requestedDailyMg}} mg/day exceeds max {{dose.maxDailyMg}} mg/day.\",\"indicator\":\"warning\",\"source\":{\"label\":\"DMRS CDS\",\"url\":\"http://localhost:5210/cds/medications/{{medication.rxCui}}\"}}"
}

