  "hookInstance": "manual-test-1",
  "context": {
    "patientId": "cds-test-patient",
    "medicationRequest": {
      "resourceType": "MedicationRequest",
      "medication": {
        "concept": {
          "coding": [
            {
              "system": "http://www.nlm.nih.gov/research/umls/rxnorm",
              "code": "161",
              "display": "Acetaminophen (Tylenol)"
            }
          ],
          "text": "Acetaminophen (Tylenol)"
        }
      },
      "dosageInstruction": [
        {
          "doseAndRate": [
            {
              "doseQuantity": {
                "value": 1500,
                "unit": "mg",
                "code": "mg"
              }
            }
          ],
          "timing": {
            "repeat": {
              "frequency": 3,
              "period": 1,
              "periodUnit": "d"
            }
          }
        }
      ]
    }
  }
}

### 18. Create test patient
POST {{DMRS.Api_HostAddress}}/fhir/Patient
Authorization: Bearer {{BearerToken}}
Content-Type: application/fhir+json
Accept: application/fhir+json

{
  "resourceType": "Patient",
  "id": "cds-test-patient",
  "name": [
    {
      "family": "Test",
      "given": ["CDS"]
    }
  ],
  "gender": "male"
}

### 19. Create matching allergy for acetaminophen ingredient
POST {{DMRS.Api_HostAddress}}/fhir/AllergyIntolerance
Authorization: Bearer {{BearerToken}}
Content-Type: application/fhir+json
Accept: application/fhir+json

{
  "resourceType": "AllergyIntolerance",
  "id": "cds-test-allergy",
  "clinicalStatus": {
    "coding": [
      {
        "system": "http://terminology.hl7.org/CodeSystem/allergyintolerance-clinical",
        "code": "active"
      }
    ]
  },
  "verificationStatus": {
    "coding": [
      {
        "system": "http://terminology.hl7.org/CodeSystem/allergyintolerance-verification",
        "code": "confirmed"
      }
    ]
  },
  "patient": {
    "reference": "Patient/cds-test-patient"
  },
  "code": {
    "coding": [
      {
        "system": "http://example.org/unii",
        "code": "UNII-L960UP28W1",
        "display": "Acetaminophen"
      }
    ],
    "text": "Acetaminophen"
  }
}

### 20. Preview allergy conflict rule
POST {{DMRS.Api_HostAddress}}/cds/rules/preview
Authorization: Bearer {{BearerToken}}
Content-Type: application/json
Accept: application/json

{
  "hook": "medication-prescribe",
  "rule": {
    "id": "00000000-0000-0000-0000-000000000002",
    "hookId": "medication-prescribe",
    "name": "Allergy conflict",
    "description": "Warn when patient allergy matches medication ingredient.",
    "priority": 2,
    "isActive": true,
    "expressionJson": "{\"==\":[{\"var\":\"safety.allergyConflict\"},true]}",
    "cardTemplateJson": "{\"summary\":\"Allergy conflict for {{medication.name}}\",\"detail\":\"Matched allergy ingredients: {{allergies.matches}}\",\"indicator\":\"hard-stop\",\"source\":{\"label\":\"DMRS CDS\"}}"
  },
  "context": {
    "patientId": "cds-test-patient",
    "medicationRequest": {
      "resourceType": "MedicationRequest",
      "medication": {
        "concept": {
          "coding": [
            {
              "system": "http://www.nlm.nih.gov/research/umls/rxnorm",
              "code": "161",
              "display": "Acetaminophen (Tylenol)"
            }
          ],
          "text": "Acetaminophen (Tylenol)"
        }
      }
    }
  },
  "prefetch": null
}

### 21. Create medication request to verify warmup
POST {{DMRS.Api_HostAddress}}/fhir/MedicationRequest
Authorization: Bearer {{BearerToken}}
Content-Type: application/fhir+json
Accept: application/fhir+json

{
  "resourceType": "MedicationRequest",
  "id": "cds-test-medreq-1",
  "status": "active",
  "intent": "order",
  "subject": {
    "reference": "Patient/cds-test-patient"
  },
  "medication": {
    "concept": {
      "coding": [
        {
          "system": "http://www.nlm.nih.gov/research/umls/rxnorm",
          "code": "5640",
          "display": "Ibuprofen (Advil)"
        }
      ],
      "text": "Ibuprofen (Advil)"
    }
  },
  "dosageInstruction": [
    {
      "doseAndRate": [
        {
          "doseQuantity": {
            "value": 400,
            "unit": "mg",
            "code": "mg"
          }
        }
      ],
      "timing": {
        "repeat": {
          "frequency": 3,
          "period": 1,
          "periodUnit": "d"
        }
      }
    }
  ]
}

