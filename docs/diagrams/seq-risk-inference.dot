// AUTO-GENERATED sequence diagram — verified against source (see README).
// CdsRiskInsightsController -> RiskService -> OnnxModelPool/InferenceSession; features are FHIR-derived.
// Render: dot -Tpng seq-risk-inference.dot -o seq-risk-inference.png  &&  dot -Tsvg seq-risk-inference.dot -o seq-risk-inference.svg
digraph SEQ {
  rankdir=TB;
  graph [fontname="Arial", fontsize=14, labelloc="t", label="تسلسل استدلال نماذج المخاطر — AI Risk-Model Inference",
         pad=0.35, nodesep=1.5, ranksep=0.62, splines=line, forcelabels=true];
  edge [fontname="Arial", fontsize=9];
  node [fontname="Arial", fontsize=10];

  // participants
  { rank=same;
    H_cli [shape=box, style="rounded,filled", fillcolor="#E8F1F8", color="#1F6FB2",
          fontcolor="black", margin="0.14,0.08", label="العميل\nمخطّط المريض / لوحة المخاطر"];
    H_ctl [shape=box, style="rounded,filled", fillcolor="#FFFFFF", color="#1F6FB2",
          fontcolor="black", margin="0.14,0.08", label="CdsRiskInsightsController\n/cds/risk/..."];
    H_auth [shape=box, style="rounded,filled", fillcolor="#FFFFFF", color="#1F6FB2",
          fontcolor="black", margin="0.14,0.08", label="SmartAuthorizationService\n(نطاق المرضى)"];
    H_svc [shape=box, style="rounded,filled", fillcolor="#FFFFFF", color="#1F6FB2",
          fontcolor="black", margin="0.14,0.08", label="RiskService\n(Readmission/Diabetes/CV)"];
    H_fhir [shape=box, style="rounded,filled", fillcolor="#E3F2E9", color="#2E8B57",
          fontcolor="black", margin="0.14,0.08", label="FhirRepository\n(بيانات FHIR)"];
    H_pool [shape=box, style="rounded,filled", fillcolor="#EFE8F8", color="#8E44AD",
          fontcolor="black", margin="0.14,0.08", label="OnnxModelPool"];
    H_onnx [shape=box, style="rounded,filled", fillcolor="#EFE8F8", color="#8E44AD",
          fontcolor="black", margin="0.14,0.08", label="InferenceSession\n(نموذج ONNX)"];
  }
  H_cli -> H_ctl -> H_auth -> H_svc -> H_fhir -> H_pool -> H_onnx [style=invis, weight=50];

  // lifeline nodes (invisible points)
  node [shape=point, width=0.012, color="#B9C4CC"];
  { rank=same; cli_1 ctl_1 auth_1 svc_1 fhir_1 pool_1 onnx_1 }
  { rank=same; cli_2 ctl_2 auth_2 svc_2 fhir_2 pool_2 onnx_2 }
  { rank=same; cli_3 ctl_3 auth_3 svc_3 fhir_3 pool_3 onnx_3 }
  { rank=same; cli_4 ctl_4 auth_4 svc_4 fhir_4 pool_4 onnx_4 }
  { rank=same; cli_5 ctl_5 auth_5 svc_5 fhir_5 pool_5 onnx_5 }
  { rank=same; cli_6 ctl_6 auth_6 svc_6 fhir_6 pool_6 onnx_6 }
  { rank=same; cli_7 ctl_7 auth_7 svc_7 fhir_7 pool_7 onnx_7 }
  { rank=same; cli_8 ctl_8 auth_8 svc_8 fhir_8 pool_8 onnx_8 }
  { rank=same; cli_9 ctl_9 auth_9 svc_9 fhir_9 pool_9 onnx_9 }
  { rank=same; cli_10 ctl_10 auth_10 svc_10 fhir_10 pool_10 onnx_10 }
  { rank=same; cli_11 ctl_11 auth_11 svc_11 fhir_11 pool_11 onnx_11 }
  { rank=same; cli_12 ctl_12 auth_12 svc_12 fhir_12 pool_12 onnx_12 }
  { rank=same; cli_13 ctl_13 auth_13 svc_13 fhir_13 pool_13 onnx_13 }
  { rank=same; cli_14 ctl_14 auth_14 svc_14 fhir_14 pool_14 onnx_14 }
  { rank=same; cli_15 ctl_15 auth_15 svc_15 fhir_15 pool_15 onnx_15 }

  // lifelines
  H_cli -> cli_1 -> cli_2 -> cli_3 -> cli_4 -> cli_5 -> cli_6 -> cli_7 -> cli_8 -> cli_9 -> cli_10 -> cli_11 -> cli_12 -> cli_13 -> cli_14 -> cli_15 [style=dashed, color="#C4CDD5", arrowhead=none, weight=100];
  H_ctl -> ctl_1 -> ctl_2 -> ctl_3 -> ctl_4 -> ctl_5 -> ctl_6 -> ctl_7 -> ctl_8 -> ctl_9 -> ctl_10 -> ctl_11 -> ctl_12 -> ctl_13 -> ctl_14 -> ctl_15 [style=dashed, color="#C4CDD5", arrowhead=none, weight=100];
  H_auth -> auth_1 -> auth_2 -> auth_3 -> auth_4 -> auth_5 -> auth_6 -> auth_7 -> auth_8 -> auth_9 -> auth_10 -> auth_11 -> auth_12 -> auth_13 -> auth_14 -> auth_15 [style=dashed, color="#C4CDD5", arrowhead=none, weight=100];
  H_svc -> svc_1 -> svc_2 -> svc_3 -> svc_4 -> svc_5 -> svc_6 -> svc_7 -> svc_8 -> svc_9 -> svc_10 -> svc_11 -> svc_12 -> svc_13 -> svc_14 -> svc_15 [style=dashed, color="#C4CDD5", arrowhead=none, weight=100];
  H_fhir -> fhir_1 -> fhir_2 -> fhir_3 -> fhir_4 -> fhir_5 -> fhir_6 -> fhir_7 -> fhir_8 -> fhir_9 -> fhir_10 -> fhir_11 -> fhir_12 -> fhir_13 -> fhir_14 -> fhir_15 [style=dashed, color="#C4CDD5", arrowhead=none, weight=100];
  H_pool -> pool_1 -> pool_2 -> pool_3 -> pool_4 -> pool_5 -> pool_6 -> pool_7 -> pool_8 -> pool_9 -> pool_10 -> pool_11 -> pool_12 -> pool_13 -> pool_14 -> pool_15 [style=dashed, color="#C4CDD5", arrowhead=none, weight=100];
  H_onnx -> onnx_1 -> onnx_2 -> onnx_3 -> onnx_4 -> onnx_5 -> onnx_6 -> onnx_7 -> onnx_8 -> onnx_9 -> onnx_10 -> onnx_11 -> onnx_12 -> onnx_13 -> onnx_14 -> onnx_15 [style=dashed, color="#C4CDD5", arrowhead=none, weight=100];

  // messages
  cli_1 -> ctl_1 [xlabel="1) GET risk score\n(patientId | batch?mine)", constraint=false, color="#1F6FB2", fontcolor="#154D7C", penwidth=1.3];
  ctl_2 -> auth_2 [xlabel="2) ResolveViewPatientIds (نطاق الدفعة)", constraint=false, color="#1F6FB2", fontcolor="#154D7C", penwidth=1.3];
  auth_3 -> ctl_3 [xlabel="3) قائمة المرضى المسموح بهم", constraint=false, style=dashed, color="#8A97A3", fontcolor="#5C6773", arrowhead=vee];
  ctl_4 -> svc_4 [xlabel="4) AssessPatientAsync / AssessAllAsync", constraint=false, color="#1F6FB2", fontcolor="#154D7C", penwidth=1.3];
  svc_5 -> pool_5 [xlabel="5) GetOrLoad(modelPath)", constraint=false, color="#1F6FB2", fontcolor="#154D7C", penwidth=1.3];
  pool_6 -> pool_6 [label="6) تحميل مرة واحدة ثم التخزين", constraint=false, color="#7A6BAA", fontcolor="#5B4C8A"];
  pool_7 -> svc_7 [xlabel="7) InferenceSession (مُخزّنة)", constraint=false, style=dashed, color="#8A97A3", fontcolor="#5C6773", arrowhead=vee];
  svc_8 -> fhir_8 [xlabel="8) Patient + Conditions/Meds\n+ عدّ Encounters/Procedures", constraint=false, color="#1F6FB2", fontcolor="#154D7C", penwidth=1.3];
  fhir_9 -> svc_9 [xlabel="9) الموارد + الأعداد", constraint=false, style=dashed, color="#8A97A3", fontcolor="#5C6773", arrowhead=vee];
  svc_10 -> svc_10 [label="10) بناء متجه الميزات [age, gender, …]", constraint=false, color="#7A6BAA", fontcolor="#5B4C8A"];
  svc_11 -> onnx_11 [xlabel="11) Run(inputTensor)", constraint=false, color="#1F6FB2", fontcolor="#154D7C", penwidth=1.3];
  onnx_12 -> svc_12 [xlabel="12) (label, probability)", constraint=false, style=dashed, color="#8A97A3", fontcolor="#5C6773", arrowhead=vee];
  svc_13 -> svc_13 [label="13) score -> High/Medium/Low (عتبات)", constraint=false, color="#7A6BAA", fontcolor="#5B4C8A"];
  svc_14 -> ctl_14 [xlabel="14) RiskAssessment", constraint=false, style=dashed, color="#8A97A3", fontcolor="#5C6773", arrowhead=vee];
  ctl_15 -> cli_15 [xlabel="15) 200 OK — عرض الدرجة والمستوى", constraint=false, style=dashed, color="#8A97A3", fontcolor="#5C6773", arrowhead=vee];
}
