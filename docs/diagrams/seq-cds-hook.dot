// AUTO-GENERATED sequence diagram — verified against source (see README).
// CdsHooksController -> CdsHookService -> RuleEngine (JSON-Logic) over a FHIR/Medicine/AI context.
// SIZED FOR PRINT: placed ~6.27in wide in كتاب المشروع (A4 portrait).
// Natural width ~9in => ~9-10pt message text on the page. If you edit this file,
// keep the header labels SHORT and the column count at 5 — the header boxes set
// the width, and every extra inch of width shrinks the text on the page.
// Render: dot -Tsvg seq-cds-hook.dot -o seq-cds-hook.svg  &&  dot -Gdpi=200 -Tpng seq-cds-hook.dot -o seq-cds-hook.png
digraph SEQ {
  rankdir=TB;
  graph [fontname="Arial", fontsize=16, labelloc="t", label="تسلسل تقييم دعم القرار (CDS Hook)\nCDS Hook Evaluation",
         pad=0.3, nodesep=0.40, ranksep=0.58, splines=line, forcelabels=false];
  edge [fontname="Arial", fontsize=14];
  node [fontname="Arial", fontsize=10];

  // participants — short labels keep the diagram narrow (see header note)
  { rank=same;
    H_cli [shape=box, style="rounded,filled", fillcolor="#E8F1F8", color="#1F6FB2",
          fontcolor="black", margin="0.09,0.06", label="العميل\nClient\n(Blazor)"];
    H_ctl [shape=box, style="rounded,filled", fillcolor="#FFFFFF", color="#1F6FB2",
          fontcolor="black", margin="0.09,0.06", label="CdsHooks\nController"];
    H_svc [shape=box, style="rounded,filled", fillcolor="#FFFFFF", color="#1F6FB2",
          fontcolor="black", margin="0.09,0.06", label="CdsHook\nService"];
    H_ctx [shape=box, style="rounded,filled", fillcolor="#FFFFFF", color="#1F6FB2",
          fontcolor="black", margin="0.09,0.06", label="CdsContext\nBuilder"];
    H_eng [shape=box, style="rounded,filled", fillcolor="#EFE8F8", color="#8E44AD",
          fontcolor="black", margin="0.09,0.06", label="القواعد والمحرّك\nRules Repo\n+ RuleEngine"];
  }
  H_cli -> H_ctl -> H_svc -> H_ctx -> H_eng [style=invis, weight=50];

  // lifeline nodes (invisible points)
  node [shape=point, width=0.012, color="#B9C4CC"];
  { rank=same; cli_1 ctl_1 svc_1 ctx_1 eng_1 }
  { rank=same; cli_2 ctl_2 svc_2 ctx_2 eng_2 }
  { rank=same; cli_3 ctl_3 svc_3 ctx_3 eng_3 }
  { rank=same; cli_4 ctl_4 svc_4 ctx_4 eng_4 }
  { rank=same; cli_5 ctl_5 svc_5 ctx_5 eng_5 }
  { rank=same; cli_6 ctl_6 svc_6 ctx_6 eng_6 }
  { rank=same; cli_7 ctl_7 svc_7 ctx_7 eng_7 }
  { rank=same; cli_8 ctl_8 svc_8 ctx_8 eng_8 }
  { rank=same; cli_9 ctl_9 svc_9 ctx_9 eng_9 }
  { rank=same; cli_10 ctl_10 svc_10 ctx_10 eng_10 }
  { rank=same; cli_11 ctl_11 svc_11 ctx_11 eng_11 }
  { rank=same; cli_12 ctl_12 svc_12 ctx_12 eng_12 }
  { rank=same; cli_13 ctl_13 svc_13 ctx_13 eng_13 }
  { rank=same; cli_14 ctl_14 svc_14 ctx_14 eng_14 }
  { rank=same; cli_15 ctl_15 svc_15 ctx_15 eng_15 }

  // lifelines
  H_cli -> cli_1 -> cli_2 -> cli_3 -> cli_4 -> cli_5 -> cli_6 -> cli_7 -> cli_8 -> cli_9 -> cli_10 -> cli_11 -> cli_12 -> cli_13 -> cli_14 -> cli_15 [style=dashed, color="#C4CDD5", arrowhead=none, weight=100];
  H_ctl -> ctl_1 -> ctl_2 -> ctl_3 -> ctl_4 -> ctl_5 -> ctl_6 -> ctl_7 -> ctl_8 -> ctl_9 -> ctl_10 -> ctl_11 -> ctl_12 -> ctl_13 -> ctl_14 -> ctl_15 [style=dashed, color="#C4CDD5", arrowhead=none, weight=100];
  H_svc -> svc_1 -> svc_2 -> svc_3 -> svc_4 -> svc_5 -> svc_6 -> svc_7 -> svc_8 -> svc_9 -> svc_10 -> svc_11 -> svc_12 -> svc_13 -> svc_14 -> svc_15 [style=dashed, color="#C4CDD5", arrowhead=none, weight=100];
  H_ctx -> ctx_1 -> ctx_2 -> ctx_3 -> ctx_4 -> ctx_5 -> ctx_6 -> ctx_7 -> ctx_8 -> ctx_9 -> ctx_10 -> ctx_11 -> ctx_12 -> ctx_13 -> ctx_14 -> ctx_15 [style=dashed, color="#C4CDD5", arrowhead=none, weight=100];
  H_eng -> eng_1 -> eng_2 -> eng_3 -> eng_4 -> eng_5 -> eng_6 -> eng_7 -> eng_8 -> eng_9 -> eng_10 -> eng_11 -> eng_12 -> eng_13 -> eng_14 -> eng_15 [style=dashed, color="#C4CDD5", arrowhead=none, weight=100];

  // messages
  cli_1 -> ctl_1 [xlabel="1) POST medication-prescribe\n{ patientId, medicationRequest }", constraint=false, color="#1F6FB2", fontcolor="#0F3E66", penwidth=1.9];
  ctl_2 -> svc_2 [xlabel="2) EvaluateAsync(hook, request)", constraint=false, color="#1F6FB2", fontcolor="#0F3E66", penwidth=1.9];
  svc_3 -> eng_3 [xlabel="3) GetActiveByHookAsync(hookId)", constraint=false, color="#1F6FB2", fontcolor="#0F3E66", penwidth=1.9];
  eng_4 -> svc_4 [xlabel="4) القواعد النشطة المنشورة", constraint=false, style=dashed, color="#7C8996", fontcolor="#3D4750", arrowhead=vee, penwidth=1.4];
  svc_5 -> ctx_5 [xlabel="5) BuildAsync(request)", constraint=false, color="#1F6FB2", fontcolor="#0F3E66", penwidth=1.9];
  ctx_6 -> ctx_6 [xlabel="6) جلب من FHIR: المريض، الحالات،\nالحساسية، الأدوية النشطة", constraint=false, color="#7A6BAA", fontcolor="#4A3C78"];
  ctx_7 -> ctx_7 [xlabel="7) معرفة الدواء (MedicineInfo)\n+ تقييم مخاطر AI", constraint=false, color="#7A6BAA", fontcolor="#4A3C78"];
  ctx_8 -> svc_8 [xlabel="8) CdsContext (سياق التقييم)", constraint=false, style=dashed, color="#7C8996", fontcolor="#3D4750", arrowhead=vee, penwidth=1.4];
  svc_9 -> eng_9 [xlabel="9) EvaluateAsync(context, rules)", constraint=false, color="#1F6FB2", fontcolor="#0F3E66", penwidth=1.9];
  eng_10 -> eng_10 [xlabel="10) تطبيق شروط JSON-Logic\nعلى السياق", constraint=false, color="#7A6BAA", fontcolor="#4A3C78"];
  eng_11 -> svc_11 [xlabel="11) البطاقات — Cards", constraint=false, style=dashed, color="#7C8996", fontcolor="#3D4750", arrowhead=vee, penwidth=1.4];
  svc_12 -> ctl_12 [xlabel="12) CdsHookResponse(cards)", constraint=false, style=dashed, color="#7C8996", fontcolor="#3D4750", arrowhead=vee, penwidth=1.4];
  ctl_13 -> ctl_13 [xlabel="13) إن وُجدت بطاقات:\nAlertFeed.Enqueue", constraint=false, color="#7A6BAA", fontcolor="#4A3C78"];
  ctl_14 -> cli_14 [xlabel="14) 200 OK { cards }", constraint=false, style=dashed, color="#7C8996", fontcolor="#3D4750", arrowhead=vee, penwidth=1.4];
  cli_15 -> cli_15 [xlabel="15) عرض بطاقات التحذير للطبيب", constraint=false, color="#7A6BAA", fontcolor="#4A3C78"];
}
